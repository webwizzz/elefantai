<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    {%- unless settings.type_header_font.system? and settings.type_body_font.system? -%}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {%- endunless -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {% render 'meta-tags' %}

    <script src="{{ 'constants.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'pubsub.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'global.js' | asset_url }}" defer="defer"></script>

    {%- if settings.animations_reveal_on_scroll -%}
      <script src="{{ 'animations.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}

    {{ content_for_header }}

    {%- liquid
      assign header_font_light = settings.type_header_font | font_modify: 'weight', '300'
      assign header_font_medium = settings.type_header_font | font_modify: 'weight', '500'
      assign header_font_semibold = settings.type_header_font | font_modify: 'weight', '600'
      assign header_font_bold = settings.type_header_font | font_modify: 'weight', 'bold'
      assign header_font_extrabold = settings.type_header_font | font_modify: 'weight', '800'
      assign header_font_italic = settings.type_header_font | font_modify: 'style', 'italic'

      assign header_font_light_italic = header_font_light | font_modify: 'style', 'italic'
      assign header_font_medium_italic = header_font_medium | font_modify: 'style', 'italic'
      assign header_font_semibold_italic = header_font_semibold | font_modify: 'style', 'italic'
      assign header_font_bold_italic = header_font_bold | font_modify: 'style', 'italic'
      assign header_font_extrabold_italic = header_font_extrabold | font_modify: 'style', 'italic'

      assign body_font_semibold = settings.type_body_font | font_modify: 'weight', '600'
      assign body_font_bold = settings.type_body_font | font_modify: 'weight', 'bold'
      assign body_font_italic = settings.type_body_font | font_modify: 'style', 'italic'

      assign body_font_semibold_italic = body_font_semibold | font_modify: 'style', 'italic'
      assign body_font_bold_italic = body_font_bold | font_modify: 'style', 'italic'
    %}

    {% style %}
          {{ settings.type_header_font | font_face: font_display: 'swap' }}
          {{ header_font_light | font_face: font_display: 'swap' }}
          {{ header_font_medium | font_face: font_display: 'swap' }}
          {{ header_font_semibold | font_face: font_display: 'swap' }}
          {{ header_font_bold | font_face: font_display: 'swap' }}
          {{ header_font_extrabold | font_face: font_display: 'swap' }}
          {{ header_font_italic | font_face: font_display: 'swap' }}
          {{ header_font_light_italic | font_face: font_display: 'swap' }}
          {{ header_font_medium_italic | font_face: font_display: 'swap' }}
          {{ header_font_semibold_italic | font_face: font_display: 'swap' }}
          {{ header_font_bold_italic | font_face: font_display: 'swap' }}
          {{ header_font_extrabold_italic | font_face: font_display: 'swap' }}

          {{ settings.type_body_font | font_face: font_display: 'swap' }}
          {{ body_font_semibold | font_face: font_display: 'swap' }}
          {{ body_font_bold | font_face: font_display: 'swap' }}
          {{ body_font_italic | font_face: font_display: 'swap' }}
          {{ body_font_semibold_italic | font_face: font_display: 'swap' }}
          {{ body_font_bold_italic | font_face: font_display: 'swap' }}

          :root {
            --font-body-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
            --font-body-style: {{ settings.type_body_font.style }};
            --font-body-weight: {{ settings.type_body_font.weight }};
            --font-body-weight-bold: {{ settings.type_body_font.weight | plus: 300 | at_most: 1000 }};

            --body-font-large: {{ settings.body_font_large | divided_by: 10.00 }}rem;
            --body-font-medium: {{ settings.body_font_medium | divided_by: 10.00 }}rem;
            --body-font-small: {{ settings.body_font_small | divided_by: 10.00 }}rem;

            --font-heading-family: {{ settings.type_header_font.family }}, {{ settings.type_header_font.fallback_families }};
            --font-heading-style: {{ settings.type_header_font.style }};
            --font-heading-weight: {{ settings.type_header_font.weight }};
            --font-heading-weight-medium: {{ settings.type_header_font.weight | plus: 100 | at_most: 1000 }};
            --font-heading-weight-semi-bold: {{ settings.type_header_font.weight | plus: 200 | at_most: 1000 }};
            --font-heading-weight-bold: {{ settings.type_header_font.weight | plus: 300 | at_most: 1000 }};

            --font-heading-hero-size: {{ settings.heading_hero_size | divided_by: 10.00 }}rem;
            --font-heading-hero-size-mb: {{ settings.heading_hero_size_mb | divided_by: 10.00 }}rem;
            --font-heading-1-size: {{ settings.heading_1_size | divided_by: 10.00 }}rem;
            --font-heading-1-size-mb: {{ settings.heading_1_size_mb | divided_by: 10.00 }}rem;
            --font-heading-2-size: {{ settings.heading_2_size | divided_by: 10.00 }}rem;
            --font-heading-2-size-mb: {{ settings.heading_2_size_mb | divided_by: 10.00 }}rem;
            --font-heading-3-size: {{ settings.heading_3_size | divided_by: 10.00 }}rem;
            --font-heading-3-size-mb: {{ settings.heading_3_size_mb | divided_by: 10.00 }}rem;
            --font-heading-4-size: {{ settings.heading_4_size | divided_by: 10.00 }}rem;
            --font-heading-4-size-mb: {{ settings.heading_4_size_mb | divided_by: 10.00 }}rem;
            --font-heading-5-size: {{ settings.heading_5_size | divided_by: 10.00 }}rem;
            --font-heading-5-size-mb: {{ settings.heading_5_size_mb | divided_by: 10.00 }}rem;
            --font-heading-6-size: {{ settings.heading_6_size | divided_by: 10.00 }}rem;
            --font-heading-6-size-mb: {{ settings.heading_6_size_mb | divided_by: 10.00 }}rem;

            --color-base-text: {{ settings.colors_text.red }}, {{ settings.colors_text.green }}, {{ settings.colors_text.blue }};
            --color-secondary-text: {{ settings.colors_secondary_text.red }}, {{ settings.colors_secondary_text.green }}, {{ settings.colors_secondary_text.blue }};
            --color-base-heading: {{ settings.colors_heading.red }}, {{ settings.colors_heading.green }}, {{ settings.colors_heading.blue }};
            --color-secondary-heading: {{ settings.colors_secondary_heading.red }}, {{ settings.colors_secondary_heading.green }}, {{ settings.colors_secondary_heading.blue }};

            --colors-background-main: {{ settings.colors_background_main.red }}, {{ settings.colors_background_main.green }}, {{ settings.colors_background_main.blue }};
            --colors-background-section-1: {{ settings.colors_background_section_1.red }}, {{ settings.colors_background_section_1.green }}, {{ settings.colors_background_section_1.blue }};
            --colors-background-section-2: {{ settings.colors_background_section_2.red }}, {{ settings.colors_background_section_2.green }}, {{ settings.colors_background_section_2.blue }};
            --colors-background-section-3: {{ settings.colors_background_section_3.red }}, {{ settings.colors_background_section_3.green }}, {{ settings.colors_background_section_3.blue }};
            --colors-background-section-4: {{ settings.colors_background_section_4.red }}, {{ settings.colors_background_section_4.green }}, {{ settings.colors_background_section_4.blue }};
            --colors-background-section-5: {{ settings.colors_background_section_5.red }}, {{ settings.colors_background_section_5.green }}, {{ settings.colors_background_section_5.blue }};

            --quick-add-background-color: {{ settings.quick_add_background_color.red }}, {{ settings.quick_add_background_color.green }}, {{ settings.quick_add_background_color.blue }};

            --color-shadow: {{ settings.colors_text.red }}, {{ settings.colors_text.green }}, {{ settings.colors_text.blue }};
            --color-base-background-1: {{ settings.colors_background_main.red }}, {{ settings.colors_background_main.green }}, {{ settings.colors_background_main.blue }};
            --color-base-accent-2: {{ settings.colors_accent_2.red }}, {{ settings.colors_accent_2.green }}, {{ settings.colors_accent_2.blue }};
            --payment-terms-background-color: {{ settings.colors_background_main }};

            --media-padding: {{ settings.media_padding }}px;
            --media-border-opacity: {{ settings.media_border_opacity | divided_by: 100.0 }};
            --media-border-width: {{ settings.media_border_thickness }}px;
            --media-radius: {{ settings.media_radius }}px;
            --media-shadow-opacity: {{ settings.media_shadow_opacity | divided_by: 100.0 }};
            --media-shadow-horizontal-offset: {{ settings.media_shadow_horizontal_offset }}px;
            --media-shadow-vertical-offset: {{ settings.media_shadow_vertical_offset }}px;
            --media-shadow-blur-radius: {{ settings.media_shadow_blur }}px;
            --media-shadow-visible: {% if settings.media_shadow_opacity > 0 %}1{% else %}0{% endif %};

            --header-width: {{ settings.header_width | divided_by: 10 }}rem;
            --page-width: {{ settings.page_width | divided_by: 10 }}rem;
            --page-width-margin: {% if settings.page_width == '1600' %}2{% else %}0{% endif %}rem;

            --product-card-image-padding: 0px;
            --product-card-corner-radius: {{ settings.card_corner_radius | divided_by: 10.0 }}rem;
            --product-card-text-alignment: {{ settings.card_text_alignment }};
            {%- if settings.mood_type == 'mood3' or settings.mood_type == 'mood4' or settings.mood_type == 'mood6' -%}
              --product-card-border-width: 1px;
            {% else %}
              --product-card-border-width: 0px;
            {% endif %}

            --product-card-shadow-visible: {% if settings.card_shadow_opacity > 0 %}1{% else %}0{% endif %};
            --product-card-shadow-horizontal-offset: {{ settings.card_shadow_horizontal_offset | divided_by: 10.0 }}rem;
            --product-card-shadow-vertical-offset: {{ settings.card_shadow_vertical_offset | divided_by: 10.0 }}rem;
            --product-card-shadow-blur-radius: {{ settings.card_shadow_blur | divided_by: 10.0 }}rem;

            --collection-card-image-padding: 0rem;
            --collection-card-corner-radius: {{ settings.collection_card_corner_radius | divided_by: 10.0 }}rem;
            --collection-card-text-alignment: {{ settings.collection_card_text_alignment }};
            --collection-card-border-width: 0rem;

            --blog-card-image-padding: 0rem;
            --blog-card-corner-radius: {{ settings.blog_card_corner_radius | divided_by: 10.0 }}rem;
            --blog-card-image-corner-radius: {{ settings.blog_card_image_corner_radius | divided_by: 10.0 }}rem;
            --blog-card-text-alignment: {{ settings.blog_card_text_alignment }};

            {%- if settings.mood_type == 'mood3' -%}
              --blog-card-border-width: 1px;
            {% else %}
              --blog-card-border-width: 0;
            {% endif %}

            --blog-card-border-opacity: {{ settings.blog_card_border_opacity | divided_by: 100.0 }};

            --badge-corner-radius: {{ settings.badge_corner_radius | divided_by: 10.0 }}rem;
            --color-badge-background-default: {{ settings.badge_color }};
            --color-badge-background-sale: {{ settings.sale_badge_color }};
            --color-badge-background-sold-out: {{ settings.sold_out_badge_color }};

            --popup-border-width: {{ settings.popup_border_thickness }}px;
            --popup-border-opacity: {{ settings.popup_border_opacity | divided_by: 100.0 }};
            --popup-corner-radius: {{ settings.popup_corner_radius }}px;
            --popup-shadow-opacity: 0;
            --popup-shadow-horizontal-offset: {{ settings.popup_shadow_horizontal_offset }}px;
            --popup-shadow-vertical-offset: {{ settings.popup_shadow_vertical_offset }}px;
            --popup-shadow-blur-radius: {{ settings.popup_shadow_blur }}px;

            --spacing-sections-desktop: {{ settings.spacing_sections }}px;
            --spacing-sections-mobile: {% if settings.spacing_sections < 24 %}{{ settings.spacing_sections }}{% else %}{{ settings.spacing_sections | times: 0.7 | round | at_least: 20 }}{% endif %}px;

            --grid-desktop-vertical-spacing: {{ settings.spacing_grid_vertical }}px;
            --grid-desktop-horizontal-spacing: {{ settings.spacing_grid_horizontal }}px;
            --grid-mobile-vertical-spacing: {{ settings.spacing_grid_vertical | divided_by: 1.5 }}px;
            --grid-mobile-horizontal-spacing: {{ settings.spacing_grid_horizontal | divided_by: 1.5 }}px;

            --text-boxes-border-opacity: {{ settings.text_boxes_border_opacity | divided_by: 100.0 }};
            --text-boxes-border-width: {{ settings.text_boxes_border_thickness }}px;
            --text-boxes-radius: 0px;
            --text-boxes-shadow-opacity: {{ settings.text_boxes_shadow_opacity | divided_by: 100.0 }};
            --text-boxes-shadow-visible: {% if settings.text_boxes_shadow_opacity > 0 %}1{% else %}0{% endif %};
            --text-boxes-shadow-horizontal-offset: {{ settings.text_boxes_shadow_horizontal_offset }}px;
            --text-boxes-shadow-vertical-offset: {{ settings.text_boxes_shadow_vertical_offset }}px;
            --text-boxes-shadow-blur-radius: {{ settings.text_boxes_shadow_blur }}px;


            --buttons-font-size: {{ settings.buttons_font_size | divided_by: 10.00 }}rem;
            --buttons-font-size-mobile: {{ settings.buttons_font_size_mobile | divided_by: 10.00 }}rem;
            --buttons-font-weight: {{ settings.button_font_weight }};
            --buttons-text-transform: {{ settings.button_text_transform }};
            --buttons-border-size: {{ settings.buttons_border_thickness }}px;
            --buttons-border-radius: {{ settings.buttons_radius }}px;

      		--border-color: {{ settings.border_color.red }}, {{ settings.border_color.green }}, {{ settings.border_color.blue }};

            --button-color-text: {{ settings.button_color_text.red }}, {{ settings.button_color_text.green }}, {{ settings.button_color_text.blue }};
            --button-color-bg: {{ settings.button_color_bg.red }}, {{ settings.button_color_bg.green }}, {{ settings.button_color_bg.blue }};
            --button-color-border: {{ settings.button_color_border.red }}, {{ settings.button_color_border.green }}, {{ settings.button_color_border.blue }};
            --button-color-text-hover: {{ settings.button_color_text_hover.red }}, {{ settings.button_color_text_hover.green }}, {{ settings.button_color_text_hover.blue }};
            --button-color-bg-hover: {{ settings.button_color_bg_hover.red }}, {{ settings.button_color_bg_hover.green }}, {{ settings.button_color_bg_hover.blue }};
            --button-color-border-hover: {{ settings.button_color_border_hover.red }}, {{ settings.button_color_border_hover.green }}, {{ settings.button_color_border_hover.blue }};

            --button-color-layer-1: {{ settings.button_color_layer.red }}, {{ settings.button_color_layer.green }}, {{ settings.button_color_layer.blue }};
            --button-color-layer-2: {{ settings.button_color_layer_second.red }}, {{ settings.button_color_layer_second.green }}, {{ settings.button_color_layer_second.blue }};
            --button-color-layer-3: {{ settings.button_color_layer_s3.red }}, {{ settings.button_color_layer_s3.green }}, {{ settings.button_color_layer_s3.blue }};

      --button-color-layer-4: {{ settings.button_color_layer_s6.red }}, {{ settings.button_color_layer_s6.green }}, {{ settings.button_color_layer_s6.blue }};

            --inline-button-color: {{ settings.inline_button_color.red }}, {{ settings.inline_button_color.green }}, {{ settings.inline_button_color.blue }};
            --inline-button-color-hover: {{ settings.inline_button_color_hover.red }}, {{ settings.inline_button_color_hover.green }}, {{ settings.inline_button_color_hover.blue }};

            --quick-add-text: {{ settings.quick_add_text.red }}, {{ settings.quick_add_text.green }}, {{ settings.quick_add_text.blue }};
            --quick-add-background: {{ settings.quick_add_background.red }}, {{ settings.quick_add_background.green }}, {{ settings.quick_add_background.blue }};
            --quick-add-border: {{ settings.quick_add_border.red }}, {{ settings.quick_add_border.green }}, {{ settings.quick_add_border.blue }};
            --quick-add-text-hover: {{ settings.quick_add_text_hover.red }}, {{ settings.quick_add_text_hover.green }}, {{ settings.quick_add_text_hover.blue }};
            --quick-add-background-hover: {{ settings.quick_add_background_hover.red }}, {{ settings.quick_add_background_hover.green }}, {{ settings.quick_add_background_hover.blue }};
            --quick-add-border-hover: {{ settings.quick_add_border_hover.red }}, {{ settings.quick_add_border_hover.green }}, {{ settings.quick_add_border_hover.blue }};
            --quick-add-background-color: {{ settings.quick_add_background_color.red }}, {{ settings.quick_add_background_color.green }}, {{ settings.quick_add_background_color.blue }};

            --buttons-radius: {{ settings.buttons_radius }}px;
            --buttons-radius-outset: {% if settings.buttons_radius > 0 %}{{ settings.buttons_radius | plus: 1 }}{% else %}0{% endif %}px;
            --buttons-border-width: {% if settings.buttons_border_opacity > 0 %}1{% else %}0{% endif %}px;
            --buttons-border-opacity: {{ settings.buttons_border_opacity | divided_by: 100.0 }};
            --buttons-shadow-opacity: {{ settings.buttons_shadow_opacity | divided_by: 100.0 }};
            --buttons-shadow-visible: {% if settings.buttons_shadow_opacity > 0 %}1{% else %}0{% endif %};
            --buttons-shadow-horizontal-offset: {{ settings.buttons_shadow_horizontal_offset }}px;
            --buttons-shadow-vertical-offset: {{ settings.buttons_shadow_vertical_offset }}px;
            --buttons-shadow-blur-radius: {{ settings.buttons_shadow_blur }}px;
            --buttons-border-offset: {% if settings.buttons_radius > 0 or settings.buttons_shadow_opacity > 0 %}0.3{% else %}0{% endif %}px;

            --inputs-radius: 0;
            --inputs-border-width: 1px;
            --inputs-border-opacity: 1;

            --variant-pills-radius: {{ settings.variant_pills_radius }}px;
            --variant-pills-border-width: {{ settings.variant_pills_border_thickness }}px;
            --variant-pills-border-opacity: {{ settings.variant_pills_border_opacity | divided_by: 100.0 }};
          }

          *,
          *::before,
          *::after {
            box-sizing: inherit;
          }

          html {
            box-sizing: border-box;
            font-size: 62.5%;
            height: 100%;
          }

          body {
            display: grid;
            grid-template-rows: auto auto 1fr auto;
            grid-template-columns: 100%;
            min-height: 100%;
            margin: 0;
            font-size: var(--body-font-medium);
            letter-spacing: normal;
            line-height: 1.4;
            font-family: var(--font-body-family);
            font-style: var(--font-body-style);
            font-weight: var(--font-body-weight);
          }
    {% endstyle %}

    {{ 'base.css' | asset_url | stylesheet_tag }}

    {%- unless settings.type_body_font.system? -%}
      {% comment %}theme-check-disable AssetPreload{% endcomment %}
      <link rel="preload" as="font" href="{{ settings.type_body_font | font_url }}" type="font/woff2" crossorigin>
      {% comment %}theme-check-enable AssetPreload{% endcomment %}
    {%- endunless -%}
    {%- unless settings.type_header_font.system? -%}
      {% comment %}theme-check-disable AssetPreload{% endcomment %}
      <link rel="preload" as="font" href="{{ settings.type_header_font | font_url }}" type="font/woff2" crossorigin>
      {% comment %}theme-check-enable AssetPreload{% endcomment %}
    {%- endunless -%}

    {%- if settings.predictive_search_enabled -%}
      <link
        rel="stylesheet"
        href="{{ 'component-predictive-search.css' | asset_url }}"
        media="print"
        onload="this.media='all'"
      >
    {%- endif -%}

    <script>
      document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
      if (Shopify.designMode) {
        document.documentElement.classList.add('shopify-design-mode');
      }
    </script>

    {% comment %}theme-check-disable AssetPreload{% endcomment %}
    <link
      rel="preload"
      href="{{ 'swiper-bundle.min.css' | asset_url }}"
      as="style"
      onload="this.onload=null;this.rel='stylesheet'"
    >
    {% comment %}theme-check-enable AssetPreload{% endcomment %}

    <noscript>
      {{ 'swiper-bundle.min.css' | asset_url | stylesheet_tag }}
    </noscript>

    <link rel="stylesheet" href="{{ 'button-animation.css' | asset_url }}" media="print" onload="this.media='all'">
    {% comment %} {{ 'button-animation.css' | asset_url | stylesheet_tag }} {% endcomment %}

    {% case settings.mood_type %}
      {% when 'kawai' %}
        {{ 'theme-kawai.css' | asset_url | stylesheet_tag }}
      {% when 'mood3' %}
        {{ 'theme-mood3.css' | asset_url | stylesheet_tag }}
      {% when 'mood4' %}
        {{ 'theme-mood4.css' | asset_url | stylesheet_tag }}
      {% when 'mood5' %}
        {{ 'theme-mood5.css' | asset_url | stylesheet_tag }}
      {% when 'mood6' %}
        {{ 'theme-mood6.css' | asset_url | stylesheet_tag }}
    {% endcase %}

    <script src="{{ 'swiper-bundle.min.js' | asset_url }}" defer="defer"></script>
  </head>

  <body class="gradient {{ settings.mood_type }}-mood lang-{{ request.locale.iso_code }}">
    {% section 'change-font' %}

    <a class="skip-to-content-link button visually-hidden" href="#MainContent">
      {{ 'accessibility.skip_to_text' | t }}
    </a>

    {% liquid
      if settings.cart_type == 'drawer' and template != 'cart'
        render 'cart-drawer'
      endif
      if settings.show_swatches == true
        render 'color-swatches'
      endif
    %}

    {% sections 'header-group' %}

    <main id="MainContent" class="content-for-layout focus-none" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    {% sections 'features-group' %}

    <ul hidden>
      <li id="a11y-refresh-page-message">{{ 'accessibility.refresh_page' | t }}</li>
      <li id="a11y-new-window-message">{{ 'accessibility.link_messages.new_window' | t }}</li>
    </ul>

    <script>
      window.shopUrl = '{{ request.origin }}';
      window.routes = {
        cart_add_url: '{{ routes.cart_add_url }}',
        cart_change_url: '{{ routes.cart_change_url }}',
        cart_update_url: '{{ routes.cart_update_url }}',
        cart_url: '{{ routes.cart_url }}',
        predictive_search_url: '{{ routes.predictive_search_url }}',
      };

      window.cartStrings = {
        error: `{{ 'sections.cart.cart_error' | t }}`,
        quantityError: `{{ 'sections.cart.cart_quantity_error_html' | t: quantity: '[quantity]' }}`,
      };

      window.variantStrings = {
        addToCart: `{{ 'products.product.add_to_cart' | t }}`,
        soldOut: `{{ 'products.product.sold_out' | t }}`,
        unavailable: `{{ 'products.product.unavailable' | t }}`,
        unavailable_with_option: `{{ 'products.product.value_unavailable' | t: option_value: '[value]' }}`,
      };

      window.accessibilityStrings = {
        imageAvailable: `{{ 'products.product.media.image_available' | t: index: '[index]' }}`,
        shareSuccess: `{{ 'general.share.success_message' | t }}`,
        pauseSlideshow: `{{ 'sections.slideshow.pause_slideshow' | t }}`,
        playSlideshow: `{{ 'sections.slideshow.play_slideshow' | t }}`,
      };
    </script>

    {%- if settings.predictive_search_enabled -%}
      <script src="{{ 'predictive-search.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}
  </body>
</html>
