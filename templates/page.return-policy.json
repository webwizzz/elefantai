      "blocks": {
        "item_hLKgEE": {
          "type": "item",
          "settings": {
            "item_heading": "13. Order Cancellation",
            "text": "<p>• Orders may be cancelled only <strong>before dispatch</strong>. Go to “Orders” in your account and click “Cancel Order”.</p><p>• Once a toy has been dispatched or delivered, cancellation is not permitted and this Return Policy will apply instead.</p><p>• Full refunds are issued to the original payment method for successful pre-dispatch cancellations, typically within 5–7 business days.</p>"
          }
        },
        "item_6LXekT": {
          "type": "item",
          "settings": {
            "item_heading": "14. Changes to This Policy",
            "text": "<p>We may update this Shipping & Return Policy from time to time to reflect operational changes or legal requirements. The revised policy will be effective from the date posted on our Service. Continued use of the Service after updates constitutes acceptance of the revised policy.</p>"
          }
        },
        "item_Lh8Pmd": {
          "type": "item",
          "settings": {
            "item_heading": "15. Contact Us",
            "text": "<p>For any questions related to shipping, returns, refunds, or sell-back pickups:</p><p>Email: support@theelefant.ai</p><p>Website: toys.theelefant.ai</p><p>Our support team operates Monday to Saturday, 10:00 AM to 7:00 PM IST (excluding public holidays).</p>"
          }
        }
      },
