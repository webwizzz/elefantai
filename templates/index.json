    "fa_qs_GQgVaC": {
      "type": "FAQs",
      "blocks": {
        "faq_4X8X8a": {
          "type": "faq",
          "settings": {
            "question": "What exactly is the Buy & Sell Back model?",
            "answer": "<p>You purchase a toy outright — brand-new or Certified Refurbished — and own it with no time limits or recurring fees. When your child outgrows it, schedule a doorstep pickup. Once the toy passes our quality check, you get a flat 60% of the purchase price back as cash or EleFant membership credit.</p>"
          }
        },
        "faq_YAPywG": {
          "type": "faq",
          "settings": {
            "question": "How is this different from the EleFant rental subscription?",
            "answer": "<p>In the subscription model, you pay a membership fee to borrow and swap toys. In Buy & Sell Back, you fully own the toy — there are no monthly charges, no return deadlines, and no swap limits. Sellback is optional, only when you’re ready.</p>"
          }
        },
        "faq_baQYNB": {
          "type": "faq",
          "settings": {
            "question": "Do I actually own the toy, or am I renting it?",
            "answer": "<p>You own it. There’s no obligation to sell it back. Keep it forever, gift it, or pass it down — the choice is entirely yours.</p>"
          }
        },
        "faq_7Hf7XC": {
          "type": "faq",
          "settings": {
            "question": " Is there a deadline by which I must sell it back?",
            "answer": "<p>No. There are no due dates or pressure to return. Sell back whenever you feel your child has outgrown the toy.</p>"
          }
        },
        "faq_q8xgbr": {
          "type": "faq",
          "settings": {
            "question": "Why choose Buy & Sell Back instead of just buying from a regular store?",
            "answer": "<p>You recover 60% of what you paid once the toy is no longer useful to your child — reducing clutter and effective cost. Regular stores typically don’t offer any buyback.</p>"
          }
        },
        "faq_z73HPE": {
          "type": "faq",
          "settings": {
            "question": "What does “Certified Refurbished” mean?",
            "answer": "<p>These are pre-owned toys that have been inspected, cleaned, sanitised, and restored to high-quality standards before resale. They look and function like new at a lower price.</p>"
          }
        },
        "faq_dwd473": {
          "type": "faq",
          "settings": {
            "question": "Are refurbished toys safe and hygienic for my child?",
            "answer": "<p>Yes. Every refurbished toy goes through a multi-step cleaning and sanitisation process and is checked for missing parts, sharp edges, or safety issues before being listed.</p>"
          }
        },
        "faq_PxtCd3": {
          "type": "faq",
          "settings": {
            "question": "Is there a warranty or quality guarantee on refurbished toys?",
            "answer": "<p>Refurbished toys come with a condition guarantee. If your item arrives not matching its described condition, you can raise a return request within the eligible window.</p>"
          }
        },
        "faq_cGXRJp": {
          "type": "faq",
          "settings": {
            "question": "Will I get the same sellback value on a refurbished toy as on a new one?",
            "answer": "<p>The sellback rate is the same — a flat 60% of the purchase price you paid, subject to quality check. Since refurbished toys are bought at a lower price, the absolute payout will be lower, but the percentage is identical.</p>"
          }
        },
        "faq_wMkKJi": {
          "type": "faq",
          "settings": {
            "question": "How do I place an order?",
            "answer": "<p>Browse the catalogue on the website or app, add toys to your cart, choose any add-ons (like damage waiver), and pay in full at checkout — including applicable taxes and delivery charges.</p>"
          }
        },
        "faq_WLDxgL": {
          "type": "faq",
          "settings": {
            "question": "Do you offer price matching?",
            "answer": "<p>Yes. We match prices across major platforms so you never overpay for a toy on EleFant.</p>"
          }
        },
        "faq_4mqibe": {
          "type": "faq",
          "settings": {
            "question": "What payment methods are accepted?",
            "answer": "<p>Standard digital payment methods — UPI, debit/credit cards, net banking, and supported wallets — are accepted at checkout.</p>"
          }
        },
        "faq_Mf3RJh": {
          "type": "faq",
          "settings": {
            "question": "Can I cancel an order after placing it?",
            "answer": "<p>Yes, but only before dispatch. Once a toy is dispatched or delivered, cancellation isn’t allowed; our refund/return policy applies instead.</p>"
          }
        },
        "faq_6YDKtm": {
          "type": "faq",
          "settings": {
            "question": "What if I change my mind after receiving the toy?",
            "answer": "<p>You may request a return within 5–7 days of delivery (exact window shown at purchase). The toy must be returned unused, in original packaging, and with all parts. Approved refunds go back to the original payment method.</p>"
          }
        },
        "faq_nkTxJA": {
          "type": "faq",
          "settings": {
            "question": "How do I sell a toy back to EleFant?",
            "answer": "<p>Log into your account, select the toy you want to sell back, and schedule a doorstep pickup. Our partner collects the toy, it goes through a quality check, and once it passes, you receive a flat 60% of the purchase price as your sellback payout.</p>"
          }
        },
        "faq_i3LBQz": {
          "type": "faq",
          "settings": {
            "question": " Is there any fee to schedule a pickup?",
            "answer": "<p>Pickup details and any applicable logistics charges are shown upfront when you initiate the sellback request, so there are no surprises.</p>"
          }
        },
        "faq_gJKyni": {
          "type": "faq",
          "settings": {
            "question": "Can I sell back a toy I did not buy from EleFant?",
            "answer": "<p>The sellback programme is designed for toys purchased through EleFant, so their purchase history and condition can be verified. External toys are generally not accepted.</p>"
          }
        },
        "faq_rxF4rq": {
          "type": "faq",
          "settings": {
            "question": "Is there a minimum or maximum number of toys I can sell back?",
            "answer": "<p>There’s no hard cap, but each sellback item is individually inspected and valued. Bulk sellbacks may take slightly longer to process.</p>"
          }
        },
        "faq_xpBTwm": {
          "type": "faq",
          "settings": {
            "question": "Can I sell back a toy I bought just a few days ago?",
            "answer": "<p>If you’re unhappy with a recent purchase, use the return/refund window (5–7 days) instead of sellback — you’ll get a better outcome. Sellback is intended for toys your child has already used and outgrown.</p>"
          }
        },
        "faq_XAnhEC": {
          "type": "faq",
          "settings": {
            "question": "How is the sellback value calculated?",
            "answer": "<p>Once the toy passes our quality check, you receive a flat 60% of the original purchase price — no sliding scale based on how long you’ve owned it. The only condition is that the toy clears QC (complete, clean, functional, and within normal wear).</p>"
          }
        },
        "faq_kGiVHP": {
          "type": "faq",
          "settings": {
            "question": "Can I see the sellback value before I buy a toy?",
            "answer": "<p>Yes. Since the payout is a flat 60% of the purchase price after QC, you know exactly what you’ll get back the moment you buy. There’s no guesswork or variable valuation.</p>"
          }
        },
        "faq_yNGz87": {
          "type": "faq",
          "settings": {
            "question": "Can I choose between a cash refund and EleFant membership credit?",
            "answer": "<p>Yes. You can take the value back to your original payment method or apply it as credit toward an EleFant membership or your next purchase — often at a preferential rate.</p>"
          }
        },
        "faq_HwGgdm": {
          "type": "faq",
          "settings": {
            "question": "Do I get more if I take membership credit instead of cash?",
            "answer": "<p>The 60% payout is the same either way. However, applying it as EleFant credit toward a membership or your next purchase often unlocks additional bonus value or preferential rates — giving you a higher effective return than cash.</p>"
          }
        },
        "faq_QHARtM": {
          "type": "faq",
          "settings": {
            "question": "How long does it take to receive my sellback payout?",
            "answer": "<p>Once the toy is picked up and passes inspection, payouts are usually processed within a few business days to your original payment method or as a wallet credit.</p>"
          }
        },
        "faq_TAHdbd": {
          "type": "faq",
          "settings": {
            "question": "What happens if my toy fails the quality check?",
            "answer": "<p>If the toy doesn’t clear QC (e.g., missing parts, broken, excessive damage), the flat 60% payout doesn’t apply. Our team will share the reason, and you can either have the toy returned to you (return logistics may apply) or discuss alternate options with support.</p>"
          }
        },
        "faq_MrNLDa": {
          "type": "faq",
          "settings": {
            "question": "What counts as “normal wear and tear”?",
            "answer": "<p>Light scratches, faded colours, minor scuffs, or small cosmetic marks from regular play are expected and will still pass QC — you’ll receive the full 60% payout.</p>"
          }
        },
        "faq_W3a8LD": {
          "type": "faq",
          "settings": {
            "question": "What happens if a toy has missing parts or accessories at pickup?",
            "answer": "<p>Missing parts, pieces, or manuals will cause the toy to fail QC, and the 60% payout won’t be released. Keeping the original box and all accessories together is the easiest way to ensure a smooth sellback.</p>"
          }
        },
        "faq_wkxjzz": {
          "type": "faq",
          "settings": {
            "question": "What if the toy is broken or damaged beyond normal use?",
            "answer": "<p>Heavily damaged or non-functional toys will fail QC and won’t be eligible for the 60% payout. If you had opted for the optional damage waiver at purchase, minor damage may still be covered so the toy clears QC — missing parts, however, are never covered under the waiver.</p>"
          }
        },
        "faq_jKPcBx": {
          "type": "faq",
          "settings": {
            "question": "Do I need to clean the toy before pickup?",
            "answer": "<p>You don’t have to, but wiping it down and packing all parts together helps the toy clear QC quickly so your 60% payout gets processed without delay.</p>"
          }
        },
        "faq_iX84GF": {
          "type": "faq",
          "settings": {
            "question": "Which cities do you deliver and offer pickup in?",
            "answer": "<p>EleFant currently operates across Mumbai, Ahmedabad, Hyderabad and Bangalore in India with doorstep delivery and pickup. You can check serviceability by entering your pincode at checkout. If your area isn’t covered yet, our support team can guide you on options.</p>"
          }
        }
      },
