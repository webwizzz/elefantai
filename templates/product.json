    "product-testimonials-grid": {
      "type": "testimonials-grid",
      "blocks": {
        "template--15086792638515__f91e8282-0f30-4a65-8135-93d49e9b7026-testimonial-1": {
          "type": "testimonial",
          "settings": {
            "star_rating": 5,
            "star_color": "#da3c24",
            "testimonail_title": "Amazing Quality!",
            "title_color": "main",
            "image": "",
            "testimonail_description": "<p>\"I absolutely love the baby clothes I purchased from Toyo! The organic fabrics are so soft and gentle on my little one's skin, and the designs are adorable. Plus, knowing they are eco-friendly makes me feel great about my purchase!\"</p>",
            "description_color": "main",
            "testimonail_author": "Becky - Leeds",
            "author_color": "heading",
            "background_color": "color-bg-3"
          }
        },
        "template--15086792638515__f91e8282-0f30-4a65-8135-93d49e9b7026-testimonial-2": {
          "type": "testimonial",
          "settings": {
            "star_rating": 5,
            "star_color": "#da3c24",
            "testimonail_title": "Cool Footwear!",
            "title_color": "main",
            "image": "",
            "testimonail_description": "<p>\"Toyo's footwear collection is a game-changer! Not only are the shoes stylish, but they also provide excellent support for my baby's developing feet. It's evident that safety and comfort are top priorities for this brand.\"</p>",
            "description_color": "main",
            "testimonail_author": "Sarah - London",
            "author_color": "heading",
            "background_color": "color-bg-3"
          }
        },
        "template--15086792638515__f91e8282-0f30-4a65-8135-93d49e9b7026-testimonial-3": {
          "type": "testimonial",
          "settings": {
            "star_rating": 5,
            "star_color": "#da3c24",
            "testimonail_title": "Best Stuffed Toys ever!",
            "title_color": "main",
            "image": "",
            "testimonail_description": "<p>\"Toyo's stuffed toys are a hit in our household! They are not only cuddly and adorable but also made from sustainable materials. My kids have fallen in love with their new companions, and I'm happy knowing I've made an eco-conscious choice.\"</p>",
            "description_color": "main",
            "testimonail_author": "Robert - Manchster",
            "author_color": "heading",
            "background_color": "color-bg-3"
