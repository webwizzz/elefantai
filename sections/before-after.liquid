{{ 'component-before-after.css' | asset_url | stylesheet_tag }}

{%- style -%}
	#shopify-section-{{ section.id }} {
		--padding-top: {{ section.settings.padding_top }}px;
		--padding-bottom: {{ section.settings.padding_bottom }}px;
		--container-width: {{ section.settings.container_width }}px;

		{% if section.settings.enable_border_radius %}
			--container-radius: {{ section.settings.border_radius }}px;
		{% endif %}
	}
	{% if section.settings.icon != blank %}
		#shopify-section-{{ section.id }} .block-image-overlay-1 {
			--mc-icon-width: {{ section.settings.icon_width }}%;
			--mc-icon-width-mb: {{ section.settings.icon_width_mobile }}%;
			--mc-icon-top: {{ section.settings.icon_vertical }}%;
			--mc-icon-top-mb: {{ section.settings.icon_vertical_mobile }}%;
			--mc-icon-left: {{ section.settings.icon_horizontal }}%;
			--mc-icon-left-mb: {{ section.settings.icon_horizontal_mobile }}%;
		}
	{% endif %}
	{% if section.settings.icon_2 != blank %}
		#shopify-section-{{ section.id }} .block-image-overlay-2 {
			--mc-icon-width: {{ section.settings.icon_width_2 }}%;
			--mc-icon-width-mb: {{ section.settings.icon_width_mobile_2 }}%;
			--mc-icon-top: {{ section.settings.icon_vertical_2 }}%;
			--mc-icon-top-mb: {{ section.settings.icon_vertical_mobile_2 }}%;
			--mc-icon-left: {{ section.settings.icon_horizontal_2 }}%;
			--mc-icon-left-mb: {{ section.settings.icon_horizontal_mobile_2 }}%;
		}
	{% endif %}

	#shopify-section-{{ section.id }} .image-comparison__figure:not(.image-comparison__figure--overlay) {
		padding-top: {{ section.settings.image_height }}%;
	}

	{% if section.settings.colors_background_section_gradient != blank %}
    #shopify-section-{{ section.id }} .section-responsive-padding {
      background: {{ section.settings.colors_background_section_gradient }};
    }
  {% endif %}
{%- endstyle -%}

{%- liquid
  if section.settings.image_overlay != blank or section.settings.image_overlay_2 != blank or section.settings.image_overlay_3 != blank or section.settings.shape_type != 'none'
    assign section_overlay = true
  endif
-%}

<div class="before-after section-responsive-padding {{ section.settings.background_color }}{% if section_overlay == true %} section-overlay{% endif %}">

  {%- if section.settings.image_overlay != blank or section.settings.image_overlay_2 != blank or section.settings.image_overlay_3 != blank -%}
    {% render 'section-overlay' %}
  {%- endif -%}

  {%- if section.settings.shape_type != 'none' -%}
    {% render 'shape',
      position: section.settings.shape_position, 
      type: section.settings.shape_type, 
      color: section.settings.shape_color,
      width: section.settings.shape_width
    %}
  {%- endif -%}


	<div class="page-width isolate">

    {%- if section.settings.heading != blank or section.settings.text != blank -%}
      <div class="title-wrapper {{ section.settings.heading_align }} {{ section.settings.text_bottom_space }}">
        {%- if section.settings.heading != blank -%}
          <h2 class="title inline-richtext {{ section.settings.heading_size }} text-color-{{ section.settings.heading_color }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-rotate-in{% endif %}">
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <div class="description rte {{ section.settings.text_body_size }} text-color-{{ section.settings.text_color }} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
            {{ section.settings.text -}}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

		<div class="image-comparison {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" data-id="{{ section.id }}" data-is-init="false" data-component="image-comparison-slider">
			{% if section.settings.icon != blank %}
				{% liquid
					assign classes = 'block-image-overlay block-image-overlay-1'
				%}

				{%- assign widths = '198, 230' -%}

				{%- capture sizes -%}
					(min-width: {{ settings.page_width }}px) 100vw,
					(min-width: 750px) calc(100vw - 130px), calc(100vw - 50px)
				{%- endcapture -%}

				{{
					section.settings.icon
					| image_url: width: 230
					| image_tag: loading: 'lazy', sizes: sizes, widths: widths, class: classes, alt: 'background shape'
				}}
			{% endif %}
			{% if section.settings.icon_2 != blank %}
				{% liquid
					assign classes = 'block-image-overlay block-image-overlay-2'
				%}

				{%- assign widths = '198, 230' -%}

				{%- capture sizes -%}
					(min-width: {{ settings.page_width }}px) 100vw,
					(min-width: 750px) calc(100vw - 130px), calc(100vw - 50px)
				{%- endcapture -%}

				{{
					section.settings.icon_2
					| image_url: width: 230
					| image_tag: loading: 'lazy', sizes: sizes, widths: widths, class: classes, alt: 'background shape'
				}}
			{% endif %}
		<image-comparison class="image-comparison {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" data-id="{{ section.id }}" data-is-init="false" data-layout="horizontal" data-component="image-comparison-slider">

			<div class="image-comparison__slider-wrapper">
				<label for="image-compare-range" class="image-comparison__label">Move image comparison slider</label>
				<input type="range" min="0" max="100" value="50" class="image-comparison__range" id="image-compare-range">
		
				<div class="image-comparison__image-wrapper image--before image-comparison__image-wrapper--overlay" style="clip-path: inset(0px 50% 0px 0px);">
					<figure class="image-comparison__figure image-comparison__figure--overlay">
						<div class="image-comparison__picture">
							{%- if section.settings.before_image != blank -%}
                {%- assign widths = '165, 360, 535, 750, 1070, 1200' -%}
                {%- capture sizes -%}
                  (min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 }}px,
                  (min-width: 750px) calc((100vw - 130px)), calc((100vw - 50px))
                {%- endcapture -%}
								{{
									section.settings.before_image
									| image_url: width: 1200
									| image_tag: loading: 'lazy',
                  sizes: sizes,
                  widths: widths,
                  class: 'image-comparison__image',
                  alt: section.settings.before_image.alt
								}}
							{%- else -%}
								<div class="image-comparison__image image-comparison__default"></div>
							{%- endif -%} 
						</div>
            {%- if section.settings.before_image_heading != blank -%}
						  <figcaption class="image-comparison__caption image-comparison__caption--before">
								<span class="image-comparison__caption-body {{ section.settings.text_before_size }} inline-richtext text-color-{{ section.settings.before_color }}">
                  {{ section.settings.before_image_heading }}
                </span>
              </figcaption>
						{%- endif -%}
					</figure>
				</div>	
		
				<div class="image-comparison__image-wrapper image--after" style="clip-path: inset(0px 0px 0px 50%);">
					<figure class="image-comparison__figure">
						<div class="image-comparison__picture">
							{%- if section.settings.after_image != blank -%}
                {%- assign widths = '165, 360, 535, 750, 1070, 1200' -%}
                {%- capture sizes -%}
                  (min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 }}px,
                  (min-width: 750px) calc((100vw - 130px)), calc((100vw - 50px))
                {%- endcapture -%}
								{{
									section.settings.after_image
									| image_url: width: 1200
									| image_tag: loading: 'lazy',
                  sizes: sizes,
                  widths: widths,
                  class: 'image-comparison__image',
                  alt: section.settings.after_image.alt
								}}
							{%- else -%}
								<div class="image-comparison__image image-comparison__default"></div>
							{%- endif -%} 
						</div>
		
            {%- if section.settings.after_image_heading != blank -%}
						  <figcaption class="image-comparison__caption image-comparison__caption--after">
								<span class="image-comparison__caption-body {{ section.settings.text_after_size }} inline-richtext text-color-{{ section.settings.after_color }} ">
                  {{ section.settings.after_image_heading }}
                </span>
              </figcaption>
						{%- endif -%}
					</figure>
				</div>

				<div class="image-comparison__slider">
					<span class="image-comparison__thumb" data-image-comparison-thumb="">
						<svg xmlns="http://www.w3.org/2000/svg" width="14" height="19" viewBox="0 0 14 19" fill="none">
							<path d="M7 1.97144V17.9714" stroke="white" stroke-width="2" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
							<path d="M13 2V18" stroke="white" stroke-width="2" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
							<path d="M1 1.97144V17.9714" stroke="white" stroke-width="2" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
						</svg>
					</span>
				</div>
			</div>

		</image-comparison>
	</div>
	</div>
</div>

<script src="{{ 'before-after.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "t:sections.before-after.name",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "custom.additions"
    ]
  },
  "settings": [
    {
      "type": "range",
      "id": "image_height",
