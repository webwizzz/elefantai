    },
    {
      "type": "range",
      "id": "card_title_desktop",
      "min": 14,
      "max": 32,
      "step": 1,
      "default": 20,
      "label": "Card Title Size (Desktop)"
    },
    {
      "type": "range",
      "id": "card_desc_desktop",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 14,
      "label": "Card Desc Size (Desktop)"
    },
    {
      "type": "header",
      "content": "Typography - Mobile"
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 16,
      "max": 60,
      "step": 2,
      "default": 32,
      "label": "Heading Size (Mobile)"
    },
    {
      "type": "range",
      "id": "subtitle_size_mobile",
      "min": 10,
      "max": 24,
      "step": 1,
      "default": 15,
      "label": "Subtitle Size (Mobile)"
    },
    {
      "type": "range",
      "id": "card_title_mobile",
      "min": 12,
      "max": 28,
      "step": 1,
      "default": 18,
      "label": "Card Title Size (Mobile)"
    },
    {
      "type": "range",
      "id": "card_desc_mobile",
      "min": 10,
      "max": 22,
      "step": 1,
      "default": 13,
      "label": "Card Desc Size (Mobile)"
    }
  ],
  "blocks": [
    {
      "type": "category_card",
      "name": "Category Card",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card Background Image"
        },
        {
          "type": "image_picker",
          "id": "overlay_image",
          "label": "Overlay Image",
          "info": "Overrides the gradient if selected."
        },
        {
          "type": "color_background",
          "id": "overlay_gradient",
          "label": "Bottom Overlay Gradient",
          "default": "linear-gradient(0deg, rgba(82,143,195,0.9) 0%, rgba(82,143,195,0) 100%)",
          "info": "Create a gradient that goes from solid color to transparent so text is readable."
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Pill Badge Text",
          "default": "0-12 Months"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Newborn & Infant"
        },
        {
          "type": "textarea",
          "id": "desc",
