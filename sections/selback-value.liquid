{%- style -%}
  #US-{{ section.id }} {
    position: relative;
    padding: 80px 20px 80px 20px;
    background: {{ section.settings.bg_color }};
    {% if section.settings.bg_image != blank %}
      background-image: url('{{ section.settings.bg_image | image_url: width: 2400 }}');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    {% endif %}
    font-family: inherit;
    text-align: center;
    overflow: hidden; /* Contains floating elements */
  }

  /* Background Decorative Elements */
  .us-floating-icon {
    position: absolute;
    z-index: 1;
    pointer-events: none;
    transform: translate(-50%, -50%); /* Centered properly around coordinates */
  }
  .us-floating-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  @media (max-width: 768px) {
    .us-floating-icon {
      opacity: 0.3; /* Less opaque on tiny screens to avoid text clash */
    }
  }

  /* Corner Images */
  .us-corner-img {
    position: absolute;
    bottom: 0;
    z-index: 1;
    pointer-events: none;
    object-fit: contain;
  }
  .us-corner-bl {
    left: 0;
    width: {{ section.settings.bottom_left_width }}px;
  }
  .us-corner-br {
    right: 0;
    width: {{ section.settings.bottom_right_width }}px;
  }
  @media (max-width: 768px) {
    .us-corner-bl {
      width: calc({{ section.settings.bottom_left_width }}px * 0.6);
    }
    .us-corner-br {
      width: calc({{ section.settings.bottom_right_width }}px * 0.6);
    }
  }

  /* Core UI Wrappers */
  .us-content {
    position: relative;
    z-index: 2;
    max-width: 1000px;
    margin: 0 auto;
  }

  .us-header {
    margin-bottom: 55px;
  }

  .us-title {
    font-size: {{ section.settings.heading_size }}px;
    font-weight: {{ section.settings.heading_weight }};
    color: {{ section.settings.title_color }};
    margin: 0 0 16px 0;
    letter-spacing: 0.5px;
  }
  .us-title .highlight {
    color: {{ section.settings.title_highlight_color }};
  }

  .us-subtitle {
    font-size: {{ section.settings.subtitle_size }}px;
    font-weight: {{ section.settings.subtitle_weight }};
    color: {{ section.settings.subtitle_color }};
    margin: 0;
  }

  /* Top Cards Row */
  .us-cards-row {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 30px;
    margin-bottom: 30px;
  }
  @media (max-width: 768px) {
    .us-cards-row {
      flex-direction: row;
      gap: 10px;
    }
  }

  .us-feature-card {
    flex: 1;
    width: 100%;
    max-width: {{ section.settings.top_cards_width }}px;
    min-height: {{ section.settings.top_cards_height }}px;
    border-radius: 20px;
    box-shadow: 0 12px 35px rgba(0,0,0,0.08); /* elevated drop shadow like image */
    padding: 20px 15px;
    display: flex;
    flex-direction: column;
    align-items: center;
    border: 3px solid #fff;
    transition: transform 0.3s ease;
  }
  .us-feature-card:hover {
    transform: translateY(-5px);
  }

  .us-card-icon {
    width: 90px;
    height: 90px;
    border-radius: 26px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 25px;
  }
  .us-card-icon img {
    width: 50px;
    height: 50px;
    object-fit: contain;
  }
  .us-card-icon svg {
    width: 50px;
    height: 50px;
    stroke: #333;
    fill: none;
    stroke-width: 1.5;
  }

  /* Specific typography for grid cards */
  .us-card-label {
    font-size: {{ section.settings.tc_title_size }}px;
    font-weight: {{ section.settings.tc_title_weight }};
    color: {{ section.settings.tc_title_color }};
    margin: 0 0 12px 0;
  }
  .us-card-price {
    font-size: {{ section.settings.tc_price_size }}px;
    font-weight: {{ section.settings.tc_price_weight }};
    color: {{ section.settings.tc_price_color }};
    margin: 0 0 10px 0;
    line-height: 1;
  }
  .us-card-subtext {
    font-size: {{ section.settings.tc_subtext_size }}px;
    font-weight: {{ section.settings.tc_subtext_weight }};
    color: {{ section.settings.tc_subtext_color }};
    margin: 0;
  }

  /* Center Directional Arrow */
  .us-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ section.settings.arrow_color }};
  }
  .us-arrow svg {
    width: 50px;
    height: 50px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  @media (max-width: 768px) {
    .us-arrow {
      transform: none;
    }
    .us-arrow svg {
      width: 30px;
      height: 30px;
    }
  }

  /* Bottom Effective Cost Card */
  .us-bottom-card {
    background: {{ section.settings.card_3_bg }};
    border-radius: 24px;
    border: 4px solid #fff;
    box-shadow: 0 15px 35px rgba(0,0,0,0.1);
    max-width: {{ section.settings.bottom_card_width }}px;
    min-height: {{ section.settings.bottom_card_height }}px;
    width: 100%;
    margin: 0 auto;
    padding: 30px 40px 30px 40px;
    position: relative;
    color: {{ section.settings.card_3_text_color }};
    text-align: center;
    transition: transform 0.3s ease;
  }
  .us-bottom-card:hover {
    transform: scale(1.02);
  }

  .us-bc-label {
    font-size: {{ section.settings.bc_title_size }}px;
    font-weight: {{ section.settings.bc_title_weight }};
    margin: 0 0 16px 0;
    color: inherit;
  }
  /* Bolding the text connects to the highlight color setting dynamically! */
  .us-bc-label strong,
  .us-bc-label b {
    color: {{ section.settings.card_3_highlight_color }};
    font-weight: bold;
  }

  .us-bc-prices {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 16px;
    white-space:nowrap;
  }
  .us-bc-strikethrough {
    font-size: calc({{ section.settings.bc_price_size }}px * 0.45);
    text-decoration: line-through;
    opacity: 0.8;
    font-weight: 500;
    color: inherit;
  }
  .us-bc-mainprice {
    font-size: {{ section.settings.bc_price_size }}px;
    font-weight: {{ section.settings.bc_price_weight }};
    line-height: 1;
    color: inherit;
  }

  /* The intersecting bottom pill */
  .us-bc-pill {
    display: inline-block;
    margin-top: 20px;
    background: {{ section.settings.pill_bg }};
    color: {{ section.settings.pill_text_color }};
    border-radius: 50px;
    padding: 10px;
    font-size: {{ section.settings.bc_pill_size }}px;
    font-weight: {{ section.settings.bc_pill_weight }};
    white-space: nowrap;
    box-shadow: 0 8px 20px rgba(0,0,0,0.15);
  }

  /* Explicit mapping for mobile fonts from settings */
  @media (max-width: 768px) {
    .us-feature-card { padding: 25px 10px; border-radius: 12px; min-height: auto; border-width: 2px; }
    .us-card-icon { width: 60px; height: 60px; border-radius: 16px; margin-bottom: 15px; }
    .us-card-icon img, .us-card-icon svg { width: 35px; height: 35px; }
    .us-title { font-size: {{ section.settings.heading_size_m }}px; }
    .us-subtitle { font-size: {{ section.settings.subtitle_size_m }}px; }
    .us-card-label { font-size: {{ section.settings.tc_title_size_m }}px; }
    .us-card-price { font-size: {{ section.settings.tc_price_size_m }}px; }
    .us-card-subtext { font-size: {{ section.settings.tc_subtext_size_m }}px; }
    .us-bc-label { font-size: {{ section.settings.bc_title_size_m }}px; margin: 0 0 5px 0;}
    .us-bc-mainprice { font-size: {{ section.settings.bc_price_size_m }}px; }
    .us-bc-strikethrough { font-size: calc({{ section.settings.bc_price_size_m }}px * 0.45); }
    .us-bc-pill { font-size: {{ section.settings.bc_pill_size_m }}px; }
  }

  @media (max-width: 480px) {
    .us-bc-prices { flex-direction: row; align-items: center; gap: 10px; white-space:nowrap; margin-bottom: 0px; }
    .us-bc-pill { padding: 10px 20px; }
    .us-bottom-card{
      min-height: auto;
      padding: 15px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign base_price = blank

  if product != blank
    if product.selected_or_first_available_variant != blank
      assign base_price = product.selected_or_first_available_variant.price
    elsif product.price != blank
      assign base_price = product.price
    endif
  endif

  if base_price != blank
    assign buyback_price = base_price | times: 60 | divided_by: 100
    assign effective_price = base_price | minus: buyback_price
  endif
-%}

<div id="US-{{ section.id }}">
  {%- comment -%} Dynamically scattered background icons from Customize blocks {%- endcomment -%}
  {% for block in section.blocks %}
    {% if block.type == 'icon' and block.settings.image != blank %}
      <div
        class="us-floating-icon"
        style="top: {{ block.settings.top_pos }}%; left: {{ block.settings.left_pos }}%; width: {{ block.settings.size }}px; height: {{ block.settings.size }}px;"
        {{ block.shopify_attributes }}
      >
        <img
          src="{{ block.settings.image | image_url: width: 400 }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
          alt="Decorative Icon"
        >
      </div>
    {% endif %}
  {% endfor %}

  {%- comment -%} Fixed Corner Images {%- endcomment -%}
  {% if section.settings.bottom_left_image != blank %}
    <img
      src="{{ section.settings.bottom_left_image | image_url: width: 600 }}"
      class="us-corner-img us-corner-bl"
      alt=""
      loading="lazy"
      width="{{ section.settings.bottom_left_image.width }}"
      height="{{ section.settings.bottom_left_image.height }}"
    >
  {% endif %}

  {% if section.settings.bottom_right_image != blank %}
    <img
      src="{{ section.settings.bottom_right_image | image_url: width: 600 }}"
      class="us-corner-img us-corner-br"
      alt=""
      loading="lazy"
      width="{{ section.settings.bottom_right_image.width }}"
      height="{{ section.settings.bottom_right_image.height }}"
    >
  {% endif %}

  <div class="us-content">
    <div class="us-header">
      <h2 class="us-title">
        {{ section.settings.heading_1 }}
        <span class="highlight">{{ section.settings.highlight_text }}</span>
        {{ section.settings.heading_2 }}
      </h2>
      <p class="us-subtitle">{{ section.settings.subtitle }}</p>
    </div>

    <div class="us-cards-row">
      <!-- Card 1 -->
      <div class="us-feature-card" style="background: {{ section.settings.card_1_bg }};">
        <div class="us-card-icon" style="background: {{ section.settings.card_1_icon_bg }};">
          {% if section.settings.card_1_icon != blank %}
            <img
              src="{{ section.settings.card_1_icon | image_url: width: 200 }}"
              alt=""
              width="{{ section.settings.card_1_icon.width }}"
              height="{{ section.settings.card_1_icon.height }}"
              loading="lazy"
            >
          {% else %}
            <svg viewBox="0 0 24 24">
              <path d="M12 1v22M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
            </svg>
          {% endif %}
        </div>
        <h3 class="us-card-label">{{ section.settings.card_1_title }}</h3>
        <p class="us-card-price" data-us-buy-price>
          {% if base_price != blank %}
            {{ base_price | money | replace: 'Rs.', '₹' | replace: 'Rs', '₹' }}
          {% else %}
            {{ section.settings.card_1_price | replace: 'Rs.', '₹' | replace: 'Rs', '₹' }}
          {% endif %}
        </p>
        <p class="us-card-subtext">{{ section.settings.card_1_subtext }}</p>
      </div>

      <!-- Arrow -->
      <div class="us-arrow">
        <svg viewBox="0 0 24 24">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </div>

      <!-- Card 2 -->
      <div class="us-feature-card" style="background: {{ section.settings.card_2_bg }};">
        <div class="us-card-icon" style="background: {{ section.settings.card_2_icon_bg }};">
          {% if section.settings.card_2_icon != blank %}
            <img
              src="{{ section.settings.card_2_icon | image_url: width: 200 }}"
              alt=""
              width="{{ section.settings.card_2_icon.width }}"
              height="{{ section.settings.card_2_icon.height }}"
              loading="lazy"
            >
          {% else %}
            <svg viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10"></circle><path d="M8 14s1.5 2 4 2 4-2 4-2"></path><line x1="9" y1="9" x2="9.01" y2="9"></line><line x1="15" y1="9" x2="15.01" y2="9"></line>
            </svg>
          {% endif %}
        </div>
        <h3 class="us-card-label">{{ section.settings.card_2_title }}</h3>
        <p class="us-card-price" data-us-buyback-price>
          {% if buyback_price != blank %}
            {{ buyback_price | money | replace: 'Rs.', '₹' | replace: 'Rs', '₹' }}
          {% else %}
            {{ section.settings.card_2_price | replace: 'Rs.', '₹' | replace: 'Rs', '₹' }}
          {% endif %}
        </p>
        <p class="us-card-subtext">{{ section.settings.card_2_subtext }}</p>
      </div>
    </div>

    <!-- Bottom Wide Card -->
    <div class="us-bottom-card">
      <p class="us-bc-label">{{ section.settings.card_3_title }}</p>

      <div class="us-bc-prices">
        {% if base_price != blank %}
          <div class="us-bc-strikethrough" data-us-effective-strikethrough>
            {{ base_price | money | replace: 'Rs.', '₹' | replace: 'Rs', '₹' }}
          </div>
        {% elsif section.settings.card_3_strikethrough != blank %}
          <div class="us-bc-strikethrough" data-us-effective-strikethrough>
            {{ section.settings.card_3_strikethrough | replace: 'Rs.', '₹' | replace: 'Rs', '₹' }}
          </div>
        {% endif %}
        <div class="us-bc-mainprice" data-us-effective-price>
          {% if effective_price != blank %}
            {{ effective_price | money | replace: 'Rs.', '₹' | replace: 'Rs', '₹' }}
          {% else %}
            {{ section.settings.card_3_price | replace: 'Rs.', '₹' | replace: 'Rs', '₹' }}
          {% endif %}
        </div>
      </div>

      {% if section.settings.pill_text != blank %}
        <div class="us-bc-pill">
          {{ section.settings.pill_text }}
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% if product != blank %}
  <script>
    (() => {
      const root = document.getElementById('US-{{ section.id }}');
      if (!root) return;

      const buyPriceEl = root.querySelector('[data-us-buy-price]');
      const buybackPriceEl = root.querySelector('[data-us-buyback-price]');
      const effectiveStrikeEl = root.querySelector('[data-us-effective-strikethrough]');
      const effectivePriceEl = root.querySelector('[data-us-effective-price]');

      const variantIds = {{ product.variants | map: 'id' | json }};
      const variantIdSet = new Set(variantIds.map((id) => Number(id)));
      const moneyFormat = String({{ shop.money_format | json }} || '')
        .replace(/Rs\.?/gi, '₹')
        .replace(/INR/gi, '₹')
        .replace(/&#8377;/gi, '₹');
      const buybackPercent = 60;

      const formatWithDelimiters = (number, precision = 2, thousands = ',', decimal = '.') => {
        const centsNumber = Number(number);
        if (Number.isNaN(centsNumber) || centsNumber === null) return '0';

        const rounded = (centsNumber / 100).toFixed(precision);
        const [wholePart, decimalPart] = rounded.split('.');
        const withThousands = wholePart.replace(/\B(?=(\d{3})+(?!\d))/g, thousands);

        if (!decimalPart) return withThousands;
        return `${withThousands}${decimal}${decimalPart}`;
      };

      const ensureRupeeSymbol = (formattedValue) => {
        const sanitizedValue = String(formattedValue || '')
          .replace(/Rs\.?\s*/gi, '₹')
          .replace(/INR\s*/gi, '₹')
          .replace(/&#8377;/gi, '₹')
          .trim();

        if (!sanitizedValue) return '₹0';
        if (sanitizedValue.includes('₹')) return sanitizedValue;
        return `₹${sanitizedValue}`;
      };

      const formatMoney = (cents, format) => {
        const placeholderRegex = /\{\{\s*(\w+)\s*\}\}/;
        const formatString = String(format || '');
        const match = formatString.match(placeholderRegex);

        if (!match) return ensureRupeeSymbol(formatWithDelimiters(cents, 2, ',', '.'));

        let value = '';
        switch (match[1]) {
          case 'amount':
            value = formatWithDelimiters(cents, 2, ',', '.');
            break;
          case 'amount_no_decimals':
            value = formatWithDelimiters(cents, 0, ',', '.');
            break;
          case 'amount_with_comma_separator':
            value = formatWithDelimiters(cents, 2, '.', ',');
            break;
          case 'amount_no_decimals_with_comma_separator':
            value = formatWithDelimiters(cents, 0, '.', ',');
            break;
          case 'amount_with_apostrophe_separator':
            value = formatWithDelimiters(cents, 2, "'", '.');
            break;
          default:
            value = formatWithDelimiters(cents, 2, ',', '.');
        }

        return ensureRupeeSymbol(formatString.replace(placeholderRegex, value));
      };

      const updatePrices = (basePriceInCents) => {
        const basePrice = Number(basePriceInCents);
        if (Number.isNaN(basePrice)) return;

        const buybackPrice = Math.floor((basePrice * buybackPercent) / 100);
        const effectivePrice = basePrice - buybackPrice;

        if (buyPriceEl) buyPriceEl.textContent = formatMoney(basePrice, moneyFormat);
        if (buybackPriceEl) buybackPriceEl.textContent = formatMoney(buybackPrice, moneyFormat);
        if (effectiveStrikeEl) effectiveStrikeEl.textContent = formatMoney(basePrice, moneyFormat);
        if (effectivePriceEl) effectivePriceEl.textContent = formatMoney(effectivePrice, moneyFormat);
      };

      const onVariantChange = (event) => {
        const variant = event && event.data ? event.data.variant : null;
        if (!variant || typeof variant.id === 'undefined' || typeof variant.price === 'undefined') return;

        const variantId = Number(variant.id);
        if (variantIdSet.size && !variantIdSet.has(variantId)) return;

        updatePrices(variant.price);
      };

      const bindVariantChange = () => {
        if (typeof subscribe !== 'function' || typeof PUB_SUB_EVENTS === 'undefined' || !PUB_SUB_EVENTS.variantChange) {
          return false;
        }

        if (typeof root.__usVariantPriceUnsubscribe === 'function') {
          root.__usVariantPriceUnsubscribe();
        }

        root.__usVariantPriceUnsubscribe = subscribe(PUB_SUB_EVENTS.variantChange, onVariantChange);
        return true;
      };

      if (!bindVariantChange()) {
        document.addEventListener(
          'DOMContentLoaded',
          () => {
            bindVariantChange();
          },
          { once: true }
        );
      }

      document.addEventListener(
        'shopify:section:unload',
        (event) => {
          if (!event || !event.detail || event.detail.sectionId !== '{{ section.id }}') return;
          if (typeof root.__usVariantPriceUnsubscribe === 'function') {
            root.__usVariantPriceUnsubscribe();
          }
        },
        { once: true }
      );
    })();
  </script>
{% endif %}

{% schema %}
{
  "name": "Understand Sellback Value",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Overall Section Theme"
    },
    {
      "type": "color_background",
      "id": "bg_color",
      "label": "Overall Background Gradient/Color",
      "default": "linear-gradient(180deg, #f2f7ff 0%, #a6cbf3 100%)"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Overall Background Image (Optional override)"
    },
    {
      "type": "header",
      "content": "Corner Images (Bottom)"
    },
    {
      "type": "image_picker",
      "id": "bottom_left_image",
      "label": "Bottom Left Image"
    },
    {
      "type": "range",
      "id": "bottom_left_width",
      "min": 50,
      "max": 400,
      "step": 10,
      "unit": "px",
      "label": "Bottom Left Image Width",
      "default": 200
    },
    {
      "type": "image_picker",
      "id": "bottom_right_image",
      "label": "Bottom Right Image"
    },
    {
      "type": "range",
      "id": "bottom_right_width",
      "min": 50,
      "max": 400,
      "step": 10,
      "unit": "px",
      "label": "Bottom Right Image Width",
      "default": 200
    },
    {
      "type": "header",
      "content": "Headings"
    },
    {
      "type": "text",
      "id": "heading_1",
      "label": "Heading Part 1",
      "default": "Understanding "
    },
    {
      "type": "text",
      "id": "highlight_text",
      "label": "Highlighted Phrase",
      "default": "Sellback"
    },
    {
      "type": "text",
      "id": "heading_2",
      "label": "Heading Part 2",
      "default": " Value"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Heading Text Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "title_highlight_color",
      "label": "Highlight Text Color",
      "default": "#8A67A8"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "See how much you actually save with EleFant's buyback guarantee"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle Color",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "arrow_color",
      "label": "Center Arrow Color",
      "default": "#4C9FEF"
    },
    {
      "type": "header",
      "content": "Card Sizing"
    },
    {
      "type": "range",
      "id": "top_cards_width",
      "min": 250,
      "max": 600,
      "step": 10,
      "unit": "px",
      "label": "Top Cards Max Width",
      "default": 330
    },
    {
      "type": "range",
      "id": "top_cards_height",
      "min": 200,
      "max": 600,
      "step": 10,
      "unit": "px",
      "label": "Top Cards Min Height",
      "default": 300
    },
    {
      "type": "range",
      "id": "bottom_card_width",
      "min": 300,
      "max": 800,
      "step": 10,
      "unit": "px",
      "label": "Bottom Card Max Width",
      "default": 480
    },
    {
      "type": "range",
      "id": "bottom_card_height",
      "min": 150,
      "max": 500,
      "step": 10,
      "unit": "px",
      "label": "Bottom Card Min Height",
      "default": 220
    },
    {
      "type": "header",
      "content": "Typography: Headings"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 20,
      "max": 80,
      "step": 1,
      "unit": "px",
      "label": "Heading Font Size (Desktop)",
      "default": 40
