{{ 'component-image-with-text.css' | asset_url | stylesheet_tag }}

{%- style -%}
  @media screen and (max-width: 749px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.53 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.53 | round: 0 }}px;
    }
  }

	@media screen and (min-width: 750px) and (max-width: 1024px) {
    .section-{{ section.id }}-padding {
			padding-top: {{ section.settings.padding_top | times: 0.67 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.67 | round: 0 }}px;
    }
  }

  @media screen and (min-width: 1025px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

	{% if section.settings.colors_background_section_gradient != blank %}
    .section-{{ section.id }}-padding {
      background: {{ section.settings.colors_background_section_gradient }};
    }
  {% endif %}

  {% if section.settings.remove_left_padding %}
    @media screen and (min-width: 990px) {
      .section-{{ section.id }}-padding.multirow .add-padding .image-with-text__grid--reverse .image-with-text__content {
        padding-left: 0;
      }
    }
  {% endif %}

  {% if section.settings.add_paddings_mobile %}
    @media screen and (max-width: 749px) {
      .section-{{ section.id }}-padding .image-with-text .image-with-text__content {
        padding: 3rem 2rem 2rem;
      }
    }
  {% endif %}

{%- endstyle -%}

{%- liquid
  if section.settings.image_layout contains 'right'
    assign odd_class = ' image-with-text__grid--reverse'
  else
    assign even_class = ' image-with-text__grid--reverse'
  endif

  if section.settings.colors_background_section_gradient != blank or section.settings.background_color != 'color-main-bg' or section.settings.row_color_scheme != 'color-main-bg'
    assign padding_class = ' add-padding'
  endif

  if section.settings.image_overlay != blank or section.settings.image_overlay_2 != blank or section.settings.image_overlay_3 != blank or section.settings.shape_type != 'none'
    assign section_overlay = true
  endif
-%}

<div class="multirow section-{{ section.id }}-padding{% if section.settings.colors_background_section_gradient != blank %} gradient{% else %} {{ section.settings.background_color }}{% endif %}{% if section_overlay == true %} section-overlay{% endif %}">

  {%- if section.settings.image_overlay != blank or section.settings.image_overlay_2 != blank or section.settings.image_overlay_3 != blank -%}
    {% render 'section-overlay' %}
  {%- endif -%}

  {%- if section.settings.shape_type != 'none' -%}
    {% render 'shape',
      position: section.settings.shape_position, 
      type: section.settings.shape_type, 
      color: section.settings.shape_color,
      width: section.settings.shape_width
    %}
  {%- endif -%}

  {%- if section.settings.title_heading != blank or section.settings.title_text != blank -%}
    <div class="page-width">
      <div class="title-wrapper {{ section.settings.text_bottom_space }} {{ section.settings.title_heading_align }}">
        {%- if section.settings.title_heading != blank -%}
          <h2 class="title inline-richtext {{ section.settings.title_heading_size }} text-color-{{ section.settings.title_heading_color }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-rotate-in{% endif %}">
            {{ section.settings.title_heading }}
          </h2>
        {%- endif -%}
  
        {%- if section.settings.title_text != blank -%}
          <div class="description rte {{ section.settings.title_text_body_size }} text-color-{{ section.settings.title_text_color }} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
            {{ section.settings.title_text -}}
          </div>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  <div class="multirow__inner page-width">
    {%- for block in section.blocks -%}
      <div class="image-with-text isolate{{ padding_class }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" {{ block.shopify_attributes }} >
        <div class="image-with-text__grid grid grid--gapless grid--1-col {{ section.settings.row_color_scheme }} grid--{% if section.settings.desktop_image_width == 'medium' %}2-col-tablet{% else %}3-col-tablet{% endif %}{% if section.settings.image_layout contains 'alternate' %}{% cycle odd_class, even_class %}{% else %}{{ odd_class }}{% endif %}">
          <div class="image-with-text__media-item image-with-text__media-item--{{ section.settings.desktop_image_width }} image-with-text__media-item--{{ section.settings.desktop_content_position }} grid__item">
            <div class="image-with-text__media image-with-text__media--{{ section.settings.image_height }} gradient global-media-settings{% if block.settings.image != blank %} media{% else %} image-with-text__media--placeholder placeholder{% endif %}"
              {% if section.settings.image_height == 'adapt' and block.settings.image != blank %}
                style="padding-bottom: {{ 1 | divided_by: block.settings.image.aspect_ratio | times: 100 }}%;"
              {% endif %}>
              {%- if block.settings.image != blank -%}
                {%- capture sizes -%}
                  (min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 2 }}px,
                  (min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)
                {%- endcapture -%}
                {{
                  block.settings.image
                  | image_url: width: 1500, format: 'webp' 
                  | image_tag: loading: 'lazy', sizes: sizes, widths: '165, 360, 535, 750, 1070, 1500', alt: block.settings.image.alt
                }}
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>
          </div>

          <div class="image-with-text__text-item grid__item">
            <div class="image-with-text__content image-with-text__content--{{ section.settings.desktop_content_position }} image-with-text__content--desktop-{{ section.settings.desktop_content_alignment }} image-with-text__content--mobile-{{ section.settings.mobile_content_alignment }} image-with-text__content--{{ section.settings.image_height }} content-container">

              {%- if block.settings.caption -%}
                <p class="image-with-text__text image-with-text__text--caption caption-with-letter-spacing caption-with-letter-spacing--medium">
                  {{ block.settings.caption | escape }}
                </p>
              {%- endif -%}

              {%- if block.settings.heading -%}
                <h2 class="image-with-text__heading text-color-{{ section.settings.text_color }} {{ section.settings.heading_size }} inline-richtext">
                  {{ block.settings.heading }}
                </h2>
              {%- endif -%}

              {%- if block.settings.text -%}
                <div class="image-with-text__text inline-richtext rte {{ section.settings.text_style }}">{{ block.settings.text }}</div>
              {%- endif -%}

              {%- if block.settings.button_label != blank -%}
                <a {% if block.settings.button_link == blank %} role="link" aria-disabled="true" {% else %} href="{{ block.settings.button_link }}" {% endif %} class="button {{ block.settings.top_space }}">
                  {{ block.settings.button_label | escape }}
                </a>
              {%- endif -%}

            </div>
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>
</div>

