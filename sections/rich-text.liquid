{{ 'section-rich-text.css' | asset_url | stylesheet_tag }}

{%- style -%}
  @media screen and (max-width: 749px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.53 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.53 | round: 0 }}px;
    }
  }

	@media screen and (min-width: 750px) and (max-width: 1024px) {
    .section-{{ section.id }}-padding {
			padding-top: {{ section.settings.padding_top | times: 0.67 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.67 | round: 0 }}px;
    }
  }

  @media screen and (min-width: 1025px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

	{% if section.settings.colors_background_section_gradient != blank %}
    .section-{{ section.id }}-padding {
      background: {{ section.settings.colors_background_section_gradient }};
    }
  {% endif %}
{%- endstyle -%}

{%- liquid
  if section.settings.image_overlay != blank or section.settings.image_overlay_2 != blank or section.settings.image_overlay_3 != blank or section.settings.shape_type != 'none'
    assign section_overlay = true
  endif
-%}

<div class="isolate{% unless section.settings.full_width %} page-width{% endunless %}">

  <div class="rich-text content-container gradient{% if section.settings.full_width %} rich-text--full-width content-container--full-width{% endif %} section-{{ section.id }}-padding {% if section.settings.colors_background_section_gradient != blank %} gradient{% else %} {{ section.settings.background_color }}{% endif %}{% if section_overlay == true %} section-overlay{% endif %}">

    {%- if section.settings.image_overlay != blank or section.settings.image_overlay_2 != blank or section.settings.image_overlay_3 != blank -%}
      {% render 'section-overlay' %}
    {%- endif -%}
  
    {%- if section.settings.shape_type != 'none' -%}
      {% render 'shape',
        position: section.settings.shape_position, 
        type: section.settings.shape_type, 
        color: section.settings.shape_color,
        width: section.settings.shape_width
      %}
    {%- endif -%}

    <div class="rich-text__wrapper rich-text__wrapper--{{ section.settings.desktop_content_position }}{% if section.settings.full_width %} page-width{% endif %}">
      <div class="rich-text__blocks {{ section.settings.content_alignment }}">
        {%- for block in section.blocks -%}
          {%- case block.type -%}

            {%- when 'heading' -%}
              <h2 class="rich-text__heading inline-richtext text-color-{{ block.settings.text_color }} {{ block.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-rotate-in{% endif %}" {% if settings.animations_reveal_on_scroll %} data-cascade style="--animation-order: {{ forloop.index }};"{% endif %} {{ block.shopify_attributes }} >
                {{- block.settings.heading -}}
              </h2>

            {%- when 'text' -%}
              <div class="rich-text__text rte {{ block.settings.text_style }} text-color-{{ block.settings.text_color }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" {% if settings.animations_reveal_on_scroll %} data-cascade style="--animation-order: {{ forloop.index }};"{% endif %} {{ block.shopify_attributes }}>
                {{- block.settings.text -}}
              </div>

            {%- when 'coundownBar' -%}
              {%- render 'countdown-bar',
                block: block,
                forloop: forloop,
                section_id: section.id
              -%}

            {%- when 'image' -%}
              {%- render 'block-image',
                block: block,
                forloop: forloop,
                section_id: section.id 
              -%}

            {%- when 'video' -%}
              {%- render 'block-video',
                block: block,
                forloop: forloop,
                section_id: section.id 
              -%}

            {%- when 'progress_bar' -%}
              {%- render 'progress-bar',
                block: block,
                forloop: forloop,
                section_id: section.id 
              -%}

            {%- when 'featured_icon' -%}
              {%- render 'featured-icon',
                block: block,
                forloop: forloop,
                section_id: section.id 
              -%}

            {%- when 'social' -%}
              {%- render 'social-icons',
                block: block,
                forloop: forloop,
                section_id: section.id,
                color_hover: block.settings.social_color_hover
              -%}

            {%- when 'button' -%}
              <div class="rich-text__buttons {{ block.settings.top_space }} {% if block.settings.button_label != blank and block.settings.button_label_2 != blank %} rich-text__buttons--multiple{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" {% if settings.animations_reveal_on_scroll %} data-cascade style="--animation-order: {{ forloop.index }};"{% endif %} {{ block.shopify_attributes }}>

                {%- if block.settings.button_label != blank -%}
                  <a {% if block.settings.button_link == blank %} role="link" aria-disabled="true" {% else %} href="{{ block.settings.button_link }}"{% endif %} class="button">
                    {{- block.settings.button_label | escape -}}
                  </a>
                {%- endif -%}

                {%- if block.settings.button_label_2 != blank -%}
                  <a {% if block.settings.button_link_2 == blank %} role="link" aria-disabled="true" {% else %} href="{{ block.settings.button_link_2 }}" {% endif %} class="button">
                    {{- block.settings.button_label_2 | escape -}}
                  </a>
                {%- endif -%}
              </div>

          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

