{{ 'section-image-gallery.css' | asset_url | stylesheet_tag }}
{{ 'section-main-product.css' | asset_url | stylesheet_tag }}

{%- style -%}
	.section-{{ section.id }}-padding {
		padding-top: {{ section.settings.padding_top | times: 0.53 | round: 0 }}px;
		padding-bottom: {{ section.settings.padding_bottom | times: 0.53 | round: 0 }}px;
	}

	@media screen and (min-width: 750px) and (max-width: 1024px) {
    .section-{{ section.id }}-padding {
			padding-top: {{ section.settings.padding_top | times: 0.67 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.67 | round: 0 }}px;
    }
  }

  @media screen and (min-width: 1025px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

	{% if section.settings.colors_background_section_gradient != blank %}
    .section-{{ section.id }}-padding {
      background: {{ section.settings.colors_background_section_gradient }};
    }
  {% endif %}

{%- endstyle -%}

{%- liquid
  if section.settings.image_overlay != blank or section.settings.image_overlay_2 != blank or section.settings.image_overlay_3 != blank or section.settings.shape_type != 'none'
    assign section_overlay = true
  endif
-%}

<div class="gradient section-{{ section.id }}-padding{% if section.settings.colors_background_section_gradient != blank %} gradient{% else %} {{ section.settings.background_color }}{% endif %}{% if section_overlay == true %} section-overlay{% endif %}">

  {%- if section.settings.image_overlay != blank or section.settings.image_overlay_2 != blank or section.settings.image_overlay_3 != blank -%}
    {% render 'section-overlay' %}
  {%- endif -%}

  {%- if section.settings.shape_type != 'none' -%}
    {% render 'shape',
      position: section.settings.shape_position, 
      type: section.settings.shape_type, 
      color: section.settings.shape_color,
      width: section.settings.shape_width
    %}
  {%- endif -%}

  <div class="page-width isolate">

    {%- if section.settings.heading != blank or section.settings.text != blank -%}
      <div class="title-wrapper {{ section.settings.heading_align }} {{ section.settings.text_bottom_space }}">
        {%- if section.settings.heading != blank -%}
          <h2 class="title inline-richtext {{ section.settings.heading_size }} text-color-{{ section.settings.heading_color }} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-rotate-in{% endif %}">
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}
    
        {%- if section.settings.text != blank -%}
          <div class="description rte {{ section.settings.text_body_size }} text-color-{{ section.settings.text_color }} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
            {{ section.settings.text }}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="gallery-grid desktop-grid-{{ section.settings.columns_desktop }} mobile-grid-{{ section.settings.columns_mobile }} image-{{ section.settings.image_ratio }}">
      {% for block in section.blocks %}
        <div class="gallery-item">
          <noscript>
            {% if block.settings.image != blank %}
            {{ block.settings.image
              | image_url: width: 700
              | image_tag: 
              loading: 'lazy', 
              alt: 'Gallery image',
              widths: '300, 400, 500, 600, 700',
              width: block.settings.image.width,
              height: block.settings.image.height
            }}
          {% else %}
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
          {% endif %}
          </noscript>
          
          <modal-opener class="product__modal-opener product__modal-opener--image no-js-hidden" data-modal="#ProductModal-{{ section.id }}">
            <div class="loading-overlay__spinner hidden">
              <svg aria-hidden="true" focusable="false" class="spinner" viewBox="0 0 66 66" xmlns="http://www.w3.org/2000/svg">
                <circle class="path" fill="none" stroke-width="4" cx="33" cy="33" r="30"></circle>
              </svg>
            </div>

            <div class="product__media media media--transparent">
              {% if block.settings.image != blank %}
                {{ block.settings.image
                  | image_url: width: 700
                  | image_tag: 
                  loading: 'lazy', 
                  alt: 'Gallery image',
                  widths: '300, 400, 500, 600, 700',
                  width: block.settings.image.width,
                  height: block.settings.image.height
                }}
              {% else %}
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
              {% endif %}
            </div>

            <button class="product__media-toggle quick-add-hidden product__media-zoom-lightbox" type="button" aria-haspopup="dialog" data-media-id="{% if block.settings.image.id != blank %}{{ block.settings.image.id }}{% else %}{{ forloop.index }}{% endif %}">
              <span class="visually-hidden">
                {{ 'products.product.media.open_media' | t: index: forloop.index }}
              </span>
            </button>
          </modal-opener>
        </div>
      {% endfor %}
    </div>

    <product-modal id="ProductModal-{{ section.id }}" class="product-media-modal media-modal gallery-modal">
      <div class="product-media-modal__dialog" role="dialog"
        aria-label="{{ 'products.modal.label' | t }}" aria-modal="true" tabindex="-1">
        <button id="ModalClose-{{ section.id }}" type="button" class="product-media-modal__toggle" aria-label="{{ 'accessibility.close' | t }}">
          {% render 'icon-close' %}
        </button>
    
        <div class="product-media-modal__content color-background-1 gradient" role="document"
          aria-label="{{ 'products.modal.label' | t }}" tabindex="0">

          {% for block in section.blocks %}
        
            {% liquid 
              if block.settings.image.id != blank
                assign media_id = block.settings.image.id
              else
                assign media_id = forloop.index
              endif 
            %}

            {% if block.settings.image != blank %}
              {{ block.settings.image
                | image_url: width: 1700
                | image_tag: 
                loading: 'lazy', 
                data-media-id: media_id,
                alt: 'Gallery image',
                widths: '300, 400, 500, 600, 700, 900, 1100, 1300, 1700',
                width: block.settings.image.width,
                height: block.settings.image.height
              }}
            {% else %}
              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </product-modal>
  </div>
</div>

<script src="{{ 'product-modal.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'media-gallery.js' | asset_url }}" defer="defer"></script>

