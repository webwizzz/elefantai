<link rel="stylesheet" href="{{ 'component-card.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'section-trending-collections.css' | asset_url }}" media="print" onload="this.media='all'">
  
<noscript>{{ 'component-card.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'section-trending-collections.css' | asset_url | stylesheet_tag }}</noscript>

{%- style -%}
  #shopify-section-{{ section.id }} {
    --padding-top: {{ section.settings.padding_top }}px;
		--padding-bottom: {{ section.settings.padding_bottom }}px;

    --arrows-clr: {{ section.settings.arrows_btn_color.red }}, {{ section.settings.arrows_btn_color.green }}, {{ section.settings.arrows_btn_color.blue }};
		--arrows-clr-hover: {{ section.settings.arrows_btn_color_hover.red }}, {{ section.settings.arrows_btn_color_hover.green }}, {{ section.settings.arrows_btn_color_hover.blue }};
		--arrows-bg: {{ section.settings.arrows_btn_bg_color.red }}, {{ section.settings.arrows_btn_bg_color.green }}, {{ section.settings.arrows_btn_bg_color.blue }};
		--arrows-bg-hover: {{ section.settings.arrows_btn_bg_color_hover.red }}, {{ section.settings.arrows_btn_bg_color_hover.green }}, {{ section.settings.arrows_btn_bg_color_hover.blue }};
  }

  {% if section.settings.colors_background_section_gradient != blank %}
    #shopify-section-{{ section.id }} .trending-collections.gradient {
      background: {{ section.settings.colors_background_section_gradient }};
    }
  {% endif %}

{%- endstyle -%}

<trending-collections class="trending-collections {{ section.settings.background_color }} gradient section-responsive-padding">
  <div class="page-width trending-collections__wrapper">
    
    <div class="trending-collections__info {{ section.settings.align_heading_mobile }}">
      {% if section.settings.title %}
        <h2 class="trending-collections__title inline-richtext {{ section.settings.title_size }} text-color-{{ section.settings.heading_color }} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
					{{ section.settings.title }}
				</h2>
      {% endif %}
      
      {% if section.settings.description %}
        <div class="trending-collections__description rte text-color-{{ section.settings.text_color }} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">{{ section.settings.description }}</div>
      {% endif %}

      {% if section.blocks.size >= 3 %}
        <div class="navigation small-hide">
          <div class="nav prev slider-arrow {% if settings.mood_type == 'mood5' %}button{% endif %}" aria-label="Previous slide">
            {% if  settings.mood_type == 'kawai' %}
              {% render 'icon-arrow-red' %}
            {% else %}
              {% render 'icon-arrow-slider' %}
            {% endif %}
          </div>
          <div class="nav next slider-arrow {% if settings.mood_type == 'mood5' %}button{% endif %}" aria-label="Next slide">
            {% if  settings.mood_type == 'kawai' %}
              {% render 'icon-arrow-red' %}
            {% else %}
              {% render 'icon-arrow-slider' %}
            {% endif %}
          </div>
        </div>
      {% endif %}

    </div>

    <div class="swiper trending-collections__slider {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      <div class="swiper-wrapper trending-collections__slider-wrp" id="collection-{{ section.id }}" role="list">
        {%- for block in section.blocks -%}
          <div class="list-unstyled swiper-slide trending-collections__item" {{ block.shopify_attributes }}>

            {% render 'card-collection',
              card_collection: block.settings.collection,
              layout: "default",
              media_aspect_ratio: section.settings.image_ratio,
              collection_heading_size: section.settings.collection_heading_size,
              collection_heading_weight: section.settings.collection_heading_weight,
              collection_text_color: section.settings.collection_text_color,
              collection_info_align: section.settings.collection_info_align,
              bg_color: block.settings.background,
            %}

          </div>
        {%- endfor -%}
      </div>
    </div>

    {% if section.settings.show_navigation_mobile == true and section.blocks.size > 1 %}
      <div class="navigation {{ section.settings.align_navigation_mobile }} medium-hide large-up-hide">
        <div class="nav prev slider-arrow {% if settings.mood_type == 'mood5' %}button{% endif %}" aria-label="Previous slide">
          {% if  settings.mood_type == 'kawai' %}
            {% render 'icon-arrow-red' %}
          {% else %}
            {% render 'icon-arrow-slider' %}
          {% endif %}
        </div>
        <div class="nav next slider-arrow {% if settings.mood_type == 'mood5' %}button{% endif %}" aria-label="Next slide">
          {% if  settings.mood_type == 'kawai' %}
            {% render 'icon-arrow-red' %}
          {% else %}
            {% render 'icon-arrow-slider' %}
          {% endif %}
        </div>
      </div>
    {% endif %}

  </div>
</trending-collections>

<script src="{{ 'trending-collections.js' | asset_url }}" defer></script>

