{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'template-collection.css' | asset_url | stylesheet_tag }}

{% if settings.enable_product_variants %}
  {{ 'product-card-variants.css' | asset_url | stylesheet_tag }}
{% endif %}

{%- if settings.enable_quick_add -%}
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- style -%}
  #shopify-section-{{ section.id }} {
		--padding-top: {{ section.settings.padding_top }}px;
		--padding-bottom: {{ section.settings.padding_bottom }}px;


		{% if section.settings.active_state == true %}
			{% if section.settings.active_state_text_color != blank %}
				--active-text-clr: {{ section.settings.active_state_text_color.red }}, {{ section.settings.active_state_text_color.green }}, {{ section.settings.active_state_text_color.blue }};
			{% endif %}
			{% if section.settings.active_state_bg_color != blank %}
				--active-bg: {{ section.settings.active_state_bg_color.red }}, {{ section.settings.active_state_bg_color.green }}, {{ section.settings.active_state_bg_color.blue }};
			{% endif %}
		{% endif %}
  }

		{% if section.settings.colors_background_section_gradient != blank %}
		#shopify-section-{{ section.id }} .section-responsive-padding {
			background: {{ section.settings.colors_background_section_gradient }};
		}
  {% endif %}

  {% if section.settings.text != blank %}
		#shopify-section-{{ section.id }} a:has(.replace-color) {
			color: {{ section.settings.text_color_2 }};
		}
	{% endif %}

{%- endstyle -%}

{%- liquid
  if section.settings.image_overlay != blank or section.settings.image_overlay_2 != blank or section.settings.image_overlay_3 != blank or section.settings.shape_type != 'none'
    assign section_overlay = true
  endif

  assign button_type = 'button button--outline'
  assign button_icon = false
  if section.settings.button_type == 'inline'
	  assign button_type = 'link link-with-icon'
	  assign button_icon = true
  endif

if section.settings.button_type == 'regular_button'
	  assign button_type = 'button'
	  assign button_icon = false
  endif	

-%}

<div class="isolate gradient collections-with-tabs{% if section_overlay == true %} section-overlay{% endif %}">
  {%- if section.settings.image_overlay != blank
    or section.settings.image_overlay_2 != blank
    or section.settings.image_overlay_3 != blank
  -%}
    {% render 'section-overlay' %}
  {%- endif -%}

  {%- if section.settings.shape_type != 'none' -%}
    {% render 'shape',
      position: section.settings.shape_position,
      type: section.settings.shape_type,
      color: section.settings.shape_color,
      width: section.settings.shape_width
    %}
  {%- endif -%}

  <div class="collection section-responsive-padding {% if section.settings.colors_background_section_gradient != blank %} gradient{% else %} {{ section.settings.background_color }}{% endif %}">
    <div class="page-width">
      <div class="title-box">

        {%- if section.settings.title != blank or section.settings.text != blank -%}
          <div class="title-wrapper {{ section.settings.heading_align }}">
            {%- if section.settings.title != blank -%}
              <h2 class="title inline-richtext {{ section.settings.heading_size }} text-color-{{ section.settings.heading_color }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-rotate-in{% endif %}">
                {% if section.settings.text_heading != blank %}
                  {% assign word_list = section.settings.text_heading | split: ', ' %}
                  {% assign text_to_replace = section.settings.title | split: '' %}
                  {% assign content = '' %}
                  {% assign result = '' %}
                  {% assign inside_tag = false %}
            
                  {% for char in text_to_replace %}
                    {% if inside_tag %}
                      {% if char == '>' %}
                        {% assign inside_tag = false %}
                      {% endif %}
                      {% assign result = result | append: char %}
                    {% else %}
                      {% if char == '<' or forloop.last %}
                        {% assign inside_tag = true %}
                        {% if forloop.last %}
                          {% assign content = content | append: char %}
                        {% endif %}
                        {% for word in word_list %}
                          {% assign replace_text = '<<<' | append: section.settings.text_color_2 | append: '">' | append: word | append: '>>>' %}
                          {% assign content = content | replace: word, replace_text %}
                        {% endfor %}
            
                        {% assign content = content | replace: '<<<', '<span class="replace-color" style="color:' %}
                        {% assign content = content | replace: '>>>', '</span>' %}
                        {% assign result = result | append: content %}
                        {% assign content = '' %}
                        {% if forloop.last != true %}
                          {% assign result = result | append: char %}
                        {% endif %}
                      {% else %}
                        {% assign content = content | append: char %}
                      {% endif %}
                    {% endif %}
            
                  {% endfor %}
    
                  {{ result }}
                {% else %}
                  {{ section.settings.title }}
                {% endif %}  
              </h2>
            {%- endif -%}

            {%- if section.settings.text != blank -%}
              <div class="description rte {{ section.settings.text_body_size }} text-color-{{ section.settings.text_color }} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
                {{ section.settings.text -}}
              </div>
            {%- endif -%}

          </div>
        {%- endif -%}

        {% if section.settings.show_header_button %}
          <a href="{{ section.settings.header_button_url }}" class="{{ button_type }} small-hide medium-hide{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %} medium-hide" {% if section.settings.header_button_url == blank %} role="link" aria-disabled="true" {% else %} href="{{ section.settings.header_button_url }}"{% endif %}>
            {{ section.settings.header_button_label }}

            {%- if button_icon -%}
              {% if settings.mood_type != 'mood5' and settings.mood_type != 'mood6' %}  
                {% render 'icon-arrow-link' %}
              {% endif %}

              {% if settings.mood_type == 'mood5' %}
                {% render 'icon-arrow-short' %}
              {% endif %}

              {% if settings.mood_type == 'mood6' %}
                {% render 'icon-arrow-mood6' %}
              {% endif %}
            {%- endif -%}
          </a>    
        {% endif %}
      </div>

      <ul class="tabs-navigation-list medium-hide small-hide {{ section.settings.navigation_style }}-style {{ section.settings.navigation_background_color }} {{ section.settings.navigation_align }} mobile-{{ section.settings.navigation_align_mb }}">
        {%- for block in section.blocks -%}
          <li class="tabs-navigation-item scroll{% if forloop.index == 1 %} active{% endif %} text-color-{{ section.settings.navigation_text_color }} text-color-{{ section.settings.navigation_text_color_hover }}-hover" tabindex="0" data-tab="tab-{{ forloop.index }}">
            <h3 class="{{ section.settings.navigation_heading_size }}">
              {% if block.settings.collection.title != blank %}
                {{- block.settings.collection.title | escape -}}
              {% else %}
                {{ 'onboarding.collection_title_short' | t }}
              {% endif %}
            </h3>

            {% if section.settings.navigation_style == 'with-icon' and section.settings.active_menu_icon != blank %}
              <img srcset="{{ section.settings.active_menu_icon | image_url: format: 'webp' }}" src="{{ section.settings.active_menu_icon | image_url: width: 1920, format: 'webp' }}" loading="lazy"  class="navigation-icon" width="auto" height="auto" alt="{{ section.settings.active_menu_icon.alt }}">

            {% endif %}
          </li>
        {%- endfor -%}
      </ul>

      <div class="tabs-navigation-list {{ section.settings.heading_align }} {{ section.settings.navigation_style }}-style large-up-hide {{ section.settings.navigation_align }} mobile-{{ section.settings.navigation_align_mb }}">
        <div class="tabs-navigation-select__wrapper">
          <select class="tabs-navigation-select" name="tabs-navigation" aria-label="Select collection">
            {%- for block in section.blocks -%}
              <option value="tab-{{ forloop.index }}">
                {% if block.settings.collection.title != blank %}
                  {{- block.settings.collection.title | escape -}}
                {% else %}
                  {{- 'onboarding.collection_title' | t -}}
                {% endif %}
              </option>
            {%- endfor -%}
          </select>
          <svg xmlns="http://www.w3.org/2000/svg" width="12" height="7" viewBox="0 0 12 7" fill="none">
            <path d="M11 1L6 6L1 1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      </div>

      <div class="tabs-products-wrapp">
        {%- for block in section.blocks -%}
          <ul class="grid product-grid contains-card contains-card--product{% if settings.card_style == 'standard' %} contains-card--standard{% endif %} grid--{{ section.settings.columns_desktop }}-col-desktop{% if block.settings.collection == blank %} grid--2-col-tablet-down{% else %} grid--{{ section.settings.columns_mobile }}-col-tablet-down{% endif %}{% if forloop.index == 1 %} active{% endif %}" role="list" aria-label="{{ 'general.slider.name' | t }}" data-tab-id="tab-{{ forloop.index }}">
            {%- for product in block.settings.collection.products limit: section.settings.products_to_show -%}
              <li class="grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" {% if settings.animations_reveal_on_scroll %} data-cascade style="--animation-order: {{ forloop.index }};" {% endif %}>
								{%- assign placeholder_image = 'product-1' -%}
                {% render 'card-product',
                  card_product: product,
                  media_aspect_ratio: section.settings.image_ratio,
                  show_secondary_image: section.settings.show_secondary_image,
                  show_vendor: section.settings.show_vendor,
                  show_rating: section.settings.show_rating,
                  show_quick_add: settings.enable_quick_add,
                  section_id: section.id
									placeholder_image: placeholder_image
                %}
              </li>
            {%- else -%}
              {%- for i in (1..8) -%}
                <li class="grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" {% if settings.animations_reveal_on_scroll %} data-cascade style="--animation-order: {{ forloop.index }};" {% endif %}>
                  {% liquid
                    if i < 7
                      assign placeholder_image = 'product-' | append: forloop.index
                    elsif i == 7
                      assign placeholder_image = 'product-1'
                    elsif i == 8
                      assign placeholder_image = 'product-2'
                    endif
                  %}

                  {% render 'card-product',
                    show_vendor: section.settings.show_vendor,
                    placeholder_image: placeholder_image
                  %}
                </li>
              {%- endfor -%}
            {%- endfor -%}

            {%- if block.settings.button_label != blank and block.settings.show_view_all == true -%}
              <li class="collection-list__item-button grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" {% if settings.animations_reveal_on_scroll %} data-cascade style="--animation-order: {{ forloop.index }};"{% endif %}>
                <a {% if block.settings.collection == blank %} role="link" aria-disabled="true" {% else %} href="{{ block.settings.collection.url }}" {% endif %} class="button">
                  <span>
                    {{ block.settings.button_label | escape }}
                  </span>
                </a>
              </li>
            {%- endif -%}
          </ul>
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

<script src="{{ 'collection-with-tabs.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
