  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer", "custom.additions"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "<strong>Favorite collections</strong>",
      "label": "t:sections.all.heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
		    {
          "value": "h4",
          "label": "Extra small"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__3.label"
