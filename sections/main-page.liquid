{{ 'section-main-page.css' | asset_url | stylesheet_tag }}

{%- style -%}
	#shopify-section-{{ section.id }} .main-page-banner {
		--padding-top: {{ section.settings.padding_top }}px;
		--padding-bottom: {{ section.settings.padding_bottom }}px;
	}
	
	#shopify-section-{{ section.id }} .main-page-content {
		--padding-top: {{ section.settings.content_padding_top }}px;
		--padding-bottom: {{ section.settings.content_padding_bottom }}px;
	}

  {% if section.settings.colors_background_section_gradient != blank %}
    #shopify-section-{{ section.id }} .main-page-banner {
      background: {{ section.settings.colors_background_section_gradient }};
    }
  {% endif %}
	{% if section.settings.content_colors_background_section_gradient != blank %}
    #shopify-section-{{ section.id }} .content {
      background: {{ section.settings.content_colors_background_section_gradient }};
    }
  {% endif %}
{%- endstyle -%}

{% if section.settings.show_breadcrumbs %} 
  <div class="breadcrumb-section page-width text-color-{{ section.settings.breadcrumb_color }} text-color-{{ section.settings.breadcrumb_color_hover }}-hover">
    {% render 'breadcrumb', active_color: section.settings.breadcrumb_color_hover %}
  </div>
{% endif %}
{% if section.settings.hide_banner != true%}
<div class="main-page-banner {% if section.settings.full_width %}full-width{% endif %} section-responsive-padding {{ section.settings.background_color }}">

  {%- if section.settings.shape_type != 'none' -%}
    {% render 'shape',
      position: section.settings.shape_position, 
      type: section.settings.shape_type, 
      color: section.settings.shape_color,
      width: section.settings.shape_width
    %}
  {%- endif -%}

  {%- if section.settings.overlay_image != blank -%}
    <div class="collection-hero--overlay">
      {%- capture sizes -%}
        (min-width: {{ settings.page_width }}px) 1700px, (min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)
      {%- endcapture -%}
        {{
          section.settings.overlay_image
          | image_url: width: 1700
          | image_tag: 
            loading: 'lazy', 
            width: section.settings.overlay_image.width,
            height: section.settings.overlay_image.height,
            sizes: sizes,
            widths: '375, 450, 550, 650, 750, 850, 950, 1100, 1300, 1440, 1650, 1800, 1980'
        }}
    </div>
  {%- endif -%}

  {%- if section.settings.overlay_image_right != blank -%}
    <div class="collection-hero--overlay-right">
      {%- capture sizes -%}
        (min-width: {{ settings.page_width }}px) 1700px, (min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)
      {%- endcapture -%}
        {{
          section.settings.overlay_image_right
          | image_url: width: 1700
          | image_tag: 
            loading: 'lazy', 
            width: section.settings.overlay_image_right.width,
            height: section.settings.overlay_image_right.height,
            sizes: sizes,
            widths: '375, 450, 550, 650, 750, 850, 950, 1100, 1300, 1440, 1650, 1800, 1980'
        }}
    </div>
  {%- endif -%}

  {%- if section.settings.banner_backgroung_image != blank -%}
    <div class="collection-hero--background">
			<img srcset=" {%- if section.settings.banner_backgroung_image.width >= 165 -%}{{ section.settings.banner_backgroung_image | image_url: width: 165 }} 165w,{%- endif -%}
				{%- if section.settings.banner_backgroung_image.width >= 360 -%}{{ section.settings.banner_backgroung_image | image_url: width: 360 }} 360w,{%- endif -%}
				{%- if section.settings.banner_backgroung_image.width >= 535 -%}{{ section.settings.banner_backgroung_image | image_url: width: 535 }} 535w,{%- endif -%}
				{%- if section.settings.banner_backgroung_image.width >= 750 -%}{{ section.settings.banner_backgroung_image | image_url: width: 750 }} 750w,{%- endif -%}
				{%- if section.settings.banner_backgroung_image.width >= 1070 -%}{{ section.settings.banner_backgroung_image | image_url: width: 1070 }} 1070w,{%- endif -%}
				{%- if section.settings.banner_backgroung_image.width >= 1500 -%}{{ section.settings.banner_backgroung_image | image_url: width: 1500 }} 1500w,{%- endif -%}
				{%- if section.settings.banner_backgroung_image.width >= 1600 -%}{{ section.settings.banner_backgroung_image | image_url: width: 1600 }} 1600w,{%- endif -%}
				{%- if section.settings.banner_backgroung_image.width >= 1700 -%}{{ section.settings.banner_backgroung_image | image_url: width: 1700 }} 1700w,{%- endif -%}
				{%- if section.settings.banner_backgroung_image.width >= 1800 -%}{{ section.settings.banner_backgroung_image | image_url: width: 1800 }} 1800w,{%- endif -%}
				{%- if section.settings.banner_backgroung_image.width >= 1920 -%}{{ section.settings.banner_backgroung_image | image_url: width: 1920 }} 1920w,{%- endif -%}
				{{ section.settings.banner_backgroung_image | image_url }} {{ section.settings.banner_backgroung_image.width }}w"
				src="{{ section.settings.banner_backgroung_image | image_url: width: 1920 }}"
				sizes="100vw"
				alt="{{- page.title | escape -}}"
				loading="lazy"
				width="{{ section.settings.banner_backgroung_image.width }}"
				height="{{ section.settings.banner_backgroung_image.height }}">
    </div>
  {%- endif -%}

  {%- if section.settings.banner_backgroung_image_mob != blank -%}
    <div class="collection-hero--background-mobile">
			<img srcset=" {%- if section.settings.banner_backgroung_image_mob.width >= 165 -%}{{ section.settings.banner_backgroung_image_mob | image_url: width: 165 }} 165w,{%- endif -%}
				{%- if section.settings.banner_backgroung_image_mob.width >= 360 -%}{{ section.settings.banner_backgroung_image_mob | image_url: width: 360 }} 360w,{%- endif -%}
				{%- if section.settings.banner_backgroung_image_mob.width >= 535 -%}{{ section.settings.banner_backgroung_image_mob | image_url: width: 535 }} 535w,{%- endif -%}
				{%- if section.settings.banner_backgroung_image_mob.width >= 750 -%}{{ section.settings.banner_backgroung_image_mob | image_url: width: 750 }} 750w,{%- endif -%}
				{%- if section.settings.banner_backgroung_image_mob.width >= 1070 -%}{{ section.settings.banner_backgroung_image_mob | image_url: width: 1070 }} 1070w,{%- endif -%}
				{%- if section.settings.banner_backgroung_image_mob.width >= 1500 -%}{{ section.settings.banner_backgroung_image_mob | image_url: width: 1500 }} 1500w,{%- endif -%}
				{%- if section.settings.banner_backgroung_image_mob.width >= 1600 -%}{{ section.settings.banner_backgroung_image_mob | image_url: width: 1600 }} 1600w,{%- endif -%}
				{%- if section.settings.banner_backgroung_image_mob.width >= 1700 -%}{{ section.settings.banner_backgroung_image_mob | image_url: width: 1700 }} 1700w,{%- endif -%}
				{%- if section.settings.banner_backgroung_image_mob.width >= 1800 -%}{{ section.settings.banner_backgroung_image_mob | image_url: width: 1800 }} 1800w,{%- endif -%}
				{%- if section.settings.banner_backgroung_image_mob.width >= 1920 -%}{{ section.settings.banner_backgroung_image_mob | image_url: width: 1920 }} 1920w,{%- endif -%}
				{{ section.settings.banner_backgroung_image_mob | image_url }} {{ section.settings.banner_backgroung_image_mob.width }}w"
				src="{{ section.settings.banner_backgroung_image_mob | image_url: width: 1920 }}"
				sizes="100vw"
				alt="{{- page.title | escape -}}"
				loading="lazy"
				width="{{ section.settings.banner_backgroung_image_mob.width }}"
				height="{{ section.settings.banner_backgroung_image_mob.height }}">
    </div>
  {%- endif -%}

  <h1 class="main-page-title center page-title text-color-{{ section.settings.text_color }} {{ section.settings.heading_size }} text-weight-{{ section.settings.heading_weight }} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-rotate-in{% endif %}">
    {{ page.title | escape }}
  </h1>
</div>
{% endif %}
{% if page.content != blank %}
  <div class="main-page-content content {{ section.settings.content_background_color }}">

    {%- if section.settings.shape_content_type != 'none' -%}
      {% render 'shape',
        position: section.settings.shape_content_position, 
        type: section.settings.shape_content_type, 
        color: section.settings.shape_content_color,
        width: section.settings.shape_content_width
      %}
    {%- endif -%}

    <div class="page-width page-width--narrow section-responsive-padding">
      <div class="rte">
        {{ page.content }}
      </div>
    </div>
  </div>
{% endif %}


