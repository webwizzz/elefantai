<style>
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.section_bg }};
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    position: relative;
    overflow: hidden;
  }
  @media screen and (min-width: 769px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .eco-container {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 20px;
    position: relative;
    z-index: 2;
  }

  .eco-header {
    text-align: center;
    margin-bottom: 50px;
    position: relative;
  }

  .eco-heading {
    font-size: {{ section.settings.heading_fs_m }}px;
    color: {{ section.settings.heading_color }};
    margin: 0 0 10px 0;
    font-weight: 700;
    line-height: 1.2;
    /* You can override font-family here or let it inherit */
  }

  .eco-description {
    font-size: {{ section.settings.description_fs_m }}px;
    color: {{ section.settings.description_color }};
    margin: 0;
  }

  @media screen and (min-width: 769px) {
    .eco-heading {
      font-size: {{ section.settings.heading_fs_d }}px;
    }

    .eco-heading span {  
      font-family: 'sag' !important;
    }
    .eco-description {
      font-size: {{ section.settings.description_fs_d }}px;
    }
  }

  .eco-decoration {
    position: absolute;
    top: -37px;
    right: -19px;
    width: 50px;
    z-index: 1;
    opacity: 0.5;
    pointer-events: none;
  }

  {% if section.settings.decoration_image == blank %}
  .eco-decoration svg {
    width: 100%;
    height: auto;
  }
  {% endif %}

  .eco-cards-wrapper {
    position: relative;
    width: 100%;
  }

  .eco-cards-grid {
    display: flex;
    flex-wrap: nowrap;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    gap: {{ section.settings.card_gap_m }}px;
    padding-bottom: 20px; /* space for shadow */
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
    align-items: stretch;
  }

  .eco-cards-grid::-webkit-scrollbar {
    display: none;
  }

  .eco-card-container {
    flex: 0 0 85%;
    scroll-snap-align: center;
    display: flex;
  }

  .eco-card-container > * {
    width: 100%;
  }

  @media screen and (min-width: 769px) {
    .eco-cards-grid {
      overflow-x: visible;
      gap: {{ section.settings.card_gap }}px;
      padding-bottom: 0;
    }
    .eco-card-container {
      flex: 1;
    }
    .eco-decoration {
        top: -60px;
        right: 10%;
        width: 120px;
        opacity: 1;
    }
  }

  .eco-carousel-dots {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
    margin-top: 10px;
  }
  .eco-dot {
    width: 8px;
    height: 8px;
    background-color: #d1ced5;
    border-radius: 4px;
    transition: all 0.3s ease;
    cursor: pointer;
  }
  .eco-dot.active {
    width: 24px;
    background-color: #B19BC6;
  }
  @media screen and (min-width: 769px) {
    .eco-carousel-dots {
      display: none;
    }
  }

  {% for block in section.blocks %}
  .eco-card--{{ block.id }} {
    background: {{ block.settings.card_bg }};
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    border-radius: {{ section.settings.card_border_radius_m }}px;
    padding: {{ section.settings.card_padding_m }}px;
    display: flex;
    flex-direction: column;
    box-shadow: 0 15px 30px rgba(0,0,0,0.05);
  }
  @media screen and (min-width: 769px) {
    .eco-card--{{ block.id }} {
      padding: {{ section.settings.card_padding_d }}px;
      border-radius: {{ section.settings.card_border_radius }}px;
    }
  }

  .eco-card--{{ block.id }} .eco-card-title {
    font-size: {{ block.settings.title_fs_m }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 10px 0;
  }

  .eco-card--{{ block.id }} .eco-card-subtitle {
    font-size: {{ block.settings.subtitle_fs_m }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0 0 25px 0;
    font-weight: 600;
  }

  .eco-card--{{ block.id }} .eco-card-desc {
    font-size: {{ block.settings.desc_fs_m }}px;
    color: {{ block.settings.desc_color }};
    margin: 0 0 35px 0;
    line-height: 1.5;
  }

  .eco-card--{{ block.id }} .eco-card-list {
    list-style: none;
    padding: 0;
    margin: 0 0 40px 0;
    flex-grow: 1;
  }

  .eco-card--{{ block.id }} .eco-card-item {
    display: flex;
    align-items: center;
    margin-bottom: 20px;
    font-size: {{ block.settings.list_fs_m }}px;
    color: {{ block.settings.list_color }};
  }

  .eco-card--{{ block.id }} .eco-card-icon {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background-color: {{ block.settings.icon_bg_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 15px;
    flex-shrink: 0;
  }

  .eco-card--{{ block.id }} .eco-card-icon svg {
    width: 14px;
    height: 14px;
    fill: none;
    stroke: {{ block.settings.icon_color }};
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .eco-card--{{ block.id }} .eco-card-btn {
    display: block;
    width: 100%;
    text-align: center;
    background-color: {{ block.settings.button_bg }};
    color: {{ block.settings.button_color }};
    font-size: {{ block.settings.button_fs_m }}px;
    padding: 10px;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 600;
    transition: background-color 0.2s ease, transform 0.2s ease;
  }

  .eco-card--{{ block.id }} .eco-card-btn:hover {
    transform: translateY(-2px);
    opacity: 0.95;
  }

  @media screen and (min-width: 769px) {
    .eco-card--{{ block.id }} .eco-card-title {
      font-size: {{ block.settings.title_fs_d }}px;
    }
    .eco-card--{{ block.id }} .eco-card-subtitle {
      font-size: {{ block.settings.subtitle_fs_d }}px;
    }
    .eco-card--{{ block.id }} .eco-card-desc {
      font-size: {{ block.settings.desc_fs_d }}px;
    }
    .eco-card--{{ block.id }} .eco-card-item {
      font-size: {{ block.settings.list_fs_d }}px;
    }
    .eco-card--{{ block.id }} .eco-card-btn {
      font-size: {{ block.settings.button_fs_d }}px;
    }
    .eco-card--{{ block.id }} .eco-card-icon {
      width: 55px;
      height: 55px;
      margin-right: 20px;
    }
    .eco-card--{{ block.id }} .eco-card-icon svg {
      width: 28px;
      height: 28px;
    }
  }
  {% endfor %}
</style>

<div class="eco-container">
  <div class="eco-header">
    <h2 class="eco-heading">
      {% if section.settings.heading_highlight != blank %}
        {% assign highlight_style = '<span style="color:'
          | append: section.settings.heading_highlight_color
          | append: ';">'
          | append: section.settings.heading_highlight
          | append: '</span>'
        %}
        {{ section.settings.heading | replace: section.settings.heading_highlight, highlight_style }}
      {% else %}
        {{ section.settings.heading }}
      {% endif %}
    </h2>
    <p class="eco-description">{{ section.settings.description }}</p>

    <div class="eco-decoration">
      {% if section.settings.decoration_image != blank %}
        <img
          src="{{ section.settings.decoration_image | image_url: width: 300 }}"
          alt=""
          loading="lazy"
          style="width: 100%; height: auto;"
        >
      {% else %}
        <!-- Default kite SVG -->
        <svg viewBox="0 0 100 150" xmlns="http://www.w3.org/2000/svg">
          <path d="M50 10 L80 40 L50 90 L20 40 Z" fill="#6B4C9A" opacity="0.8"/>
          <path d="M50 10 L80 40 L50 50 L20 40 Z" fill="#F8B133"/>
          <path d="M50 90 L30 140" stroke="#F8B133" stroke-width="2" fill="none"/>
          <path d="M45 100 L25 105 L40 110" stroke="#F8B133" stroke-width="2" fill="none"/>
          <path d="M40 115 L20 120 L35 125" stroke="#F8B133" stroke-width="2" fill="none"/>
        </svg>
      {% endif %}
    </div>
  </div>

  <div class="eco-cards-wrapper">
    <div class="eco-cards-grid" id="ecoCardsGrid-{{ section.id }}">
      {% for block in section.blocks %}
        <div class="eco-card-container" data-index="{{ forloop.index0 }}">
          <div class="eco-card--{{ block.id }}" {{ block.shopify_attributes }}>
            <h3 class="eco-card-title">
              {% if block.settings.title_highlight != blank %}
                {% assign card_highlight_style = '<span style="color: '
                  | append: block.settings.title_highlight_color
                  | append: ';">'
                  | append: block.settings.title_highlight
                  | append: '</span>'
                %}
                {{ block.settings.title | replace: block.settings.title_highlight, card_highlight_style }}
              {% else %}
                {{ block.settings.title }}
              {% endif %}
            </h3>

            {% if block.settings.subtitle != blank %}
              <div class="eco-card-subtitle">{{ block.settings.subtitle }}</div>
            {% endif %}

            {% if block.settings.description != blank %}
              <p class="eco-card-desc">{{ block.settings.description }}</p>
            {% endif %}

            <ul class="eco-card-list">
              {% for i in (1..3) %}
                {% assign list_item_key = 'list_item_' | append: i %}
                {% assign list_item_value = block.settings[list_item_key] %}

                {% if list_item_value != blank %}
                  <li class="eco-card-item">
                    <div class="eco-card-icon">
                      <svg viewBox="0 0 24 24">
                        <path d="M5 13l4 4L19 7" />
                      </svg>
                    </div>
                    <span>{{ list_item_value }}</span>
                  </li>
                {% endif %}
              {% endfor %}
            </ul>

            {% if block.settings.button_label != blank %}
              <a href="{{ block.settings.button_link | default: '#' }}" class="eco-card-btn">
                {{ block.settings.button_label }}
              </a>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>

    <div class="eco-carousel-dots" id="ecoDots-{{ section.id }}">
      {% for block in section.blocks %}
        <div class="eco-dot {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}"></div>
      {% endfor %}
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const sectionId = '{{ section.id }}';
    const grid = document.getElementById('ecoCardsGrid-' + sectionId);
    const dotsContainer = document.getElementById('ecoDots-' + sectionId);
    if (!grid || !dotsContainer) return;

    const dots = dotsContainer.querySelectorAll('.eco-dot');
    const cards = grid.querySelectorAll('.eco-card-container');

    if (dots.length <= 1 || cards.length <= 1) {
      dotsContainer.style.display = 'none';
      grid.style.justifyContent = 'center'; // optional: center if only 1
    }

    if (dots.length === 0 || cards.length === 0) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const index = entry.target.dataset.index;
            dots.forEach((dot, i) => {
              if (i == index) {
                dot.classList.add('active');
              } else {
                dot.classList.remove('active');
              }
            });
          }
        });
      },
      {
        root: grid,
        threshold: 0.6,
      }
    );

    cards.forEach((card) => observer.observe(card));

    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        const card = cards[index];
        if (card) {
          const scrollPos = card.offsetLeft - grid.offsetLeft - (grid.clientWidth - card.clientWidth) / 2;
          grid.scrollTo({
            left: scrollPos,
            behavior: 'smooth',
          });
        }
      });
    });
  });
</script>

