<footer class="site-footer" style="background-color: #101828">
  <div class="wrap">
    <div class="footer__menus">
      <div class="footer__intro">
        {% if section.settings.intro_logo != blank %}
          <div class="footer__intro-logo" style="--intro-logo-width: {{ section.settings.intro_logo_width | default: 180 }}px;">
            {{ section.settings.intro_logo | image_url: width: 800 | image_tag: alt: section.settings.intro_logo_alt, class: 'footer__intro-logo-image' }}
          </div>
        {% endif %}

        {% if section.settings.intro_content != blank %}
          <div class="footer__intro-content rte">
            {{ section.settings.intro_content }}
          </div>
        {% endif %}

        {% assign has_social_links = false %}
        {% for block in section.blocks %}
          {% if block.type == 'social_link' and block.settings.link != blank and block.settings.icon != blank %}
            {% assign has_social_links = true %}
            {% break %}
          {% endif %}
        {% endfor %}

        {% if has_social_links %}
          <ul class="footer__social" role="list" style="--footer-social-bg: {{ section.settings.social_icon_bg | default: '#1E2938' }};">
            {% for block in section.blocks %}
              {% if block.type == 'social_link' and block.settings.link != blank and block.settings.icon != blank %}
                <li class="footer__social-item" {{ block.shopify_attributes }}>
                  <a href="{{ block.settings.link }}" class="footer__social-link" target="_blank" rel="noopener" aria-label="{{ block.settings.label | escape | default: 'Social link' }}">
                    {{ block.settings.icon | image_url: width: 100 | image_tag: alt: block.settings.label, class: 'footer__social-icon' }}
                  </a>
                </li>
              {% endif %}
            {% endfor %}
          </ul>
        {% endif %}
      </div>

      {% assign menu_setting = section.settings.menu %}
      {% if menu_setting != blank and linklists[menu_setting] %}
        {% assign footer_menu = linklists[menu_setting] %}
        {% assign groups = footer_menu.links %}
        {% assign total = groups.size %}

        {% if total <= 4 %}
          {% for group in groups %}
            <nav class="footer__menu" aria-label="{{ group.title }}">
              <h4 class="footer__menu-title">{{ group.title }}</h4>
              <ul class="footer__menu-list">
                {% if group.links and group.links.size > 0 %}
                  {% for item in group.links %}
                    <li class="footer__menu-item"><a href="{{ item.url }}" class="footer__menu-link">{{ item.title }}</a></li>
                  {% endfor %}
                {% else %}
                  <li class="footer__menu-item"><a href="{{ group.url }}" class="footer__menu-link">{{ group.title }}</a></li>
                {% endif %}
              </ul>
            </nav>
          {% endfor %}
        {% else %}
          {% for i in (0..2) %}
            {% assign group = groups[i] %}
            <nav class="footer__menu" aria-label="{{ group.title }}">
              <h4 class="footer__menu-title">{{ group.title }}</h4>
              <ul class="footer__menu-list">
                {% if group.links and group.links.size > 0 %}
                  {% for item in group.links %}
                    <li class="footer__menu-item"><a href="{{ item.url }}" class="footer__menu-link">{{ item.title }}</a></li>
                  {% endfor %}
                {% else %}
                  <li class="footer__menu-item"><a href="{{ group.url }}" class="footer__menu-link">{{ group.title }}</a></li>
                {% endif %}
              </ul>
            </nav>
          {% endfor %}

          <div class="footer__menu footer__menu--stacked" aria-label="More links">
            {% assign last_index = total | minus: 1 %}
            {% for j in (3..last_index) %}
              {% assign group = groups[j] %}
              <div class="footer__menu-block">
                <h4 class="footer__menu-title">{{ group.title }}</h4>
                <ul class="footer__menu-list">
                  {% if group.links and group.links.size > 0 %}
                    {% for item in group.links %}
                      <li class="footer__menu-item"><a href="{{ item.url }}" class="footer__menu-link">{{ item.title }}</a></li>
                    {% endfor %}
                  {% else %}
                    <li class="footer__menu-item"><a href="{{ group.url }}" class="footer__menu-link">{{ group.title }}</a></li>
                  {% endif %}
                </ul>
              </div>
            {% endfor %}
          </div>
        {% endif %}
      {% endif %}
    </div>

    {% assign has_contact_items = false %}
    {% for block in section.blocks %}
      {% if block.type == 'contact_item' and block.settings.value != blank %}
        {% assign has_contact_items = true %}
        {% break %}
      {% endif %}
    {% endfor %}

    {% if has_contact_items %}
      <div class="footer__contact">
        {% if section.settings.get_in_touch_heading != blank %}
          <h4 class="footer__section-heading">{{ section.settings.get_in_touch_heading }}</h4>
        {% endif %}

        <div class="footer__contact-grid">
          {% for block in section.blocks %}
            {% if block.type == 'contact_item' and block.settings.value != blank %}
              <div class="footer__contact-item" {{ block.shopify_attributes }}>
                {% if block.settings.contact_logo != blank or block.settings.label != blank %}
                  <div class="footer__contact-head">
                    {% if block.settings.contact_logo != blank %}
                      {{ block.settings.contact_logo | image_url: width: 80 | image_tag: alt: block.settings.label, class: 'footer__contact-logo' }}
                    {% endif %}
                    {% if block.settings.label != blank %}
                      <p class="footer__contact-label">{{ block.settings.label }}</p>
                    {% endif %}
                  </div>
                {% endif %}
                <div class="footer__contact-value rte">{{ block.settings.value }}</div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    {% endif %}

    {% if section.settings.show_newsletter %}
      <div class="footer__newsletter">
        {% if section.settings.newsletter_heading != blank %}
          <h4 class="footer__section-heading">{{ section.settings.newsletter_heading }}</h4>
        {% endif %}

        {% if section.settings.newsletter_subheading != blank %}
          <p class="footer__newsletter-subheading">{{ section.settings.newsletter_subheading }}</p>
        {% endif %}

        {% form 'customer', class: 'footer__newsletter-form' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <label for="FooterEmail-{{ section.id }}" class="visually-hidden">Email</label>
          <input
            id="FooterEmail-{{ section.id }}"
            type="email"
            name="contact[email]"
            class="footer__newsletter-input"
            value="{% if customer %}{{ customer.email }}{% endif %}"
            placeholder="{{ section.settings.newsletter_placeholder | escape }}"
            required
          >
          <button type="submit" class="footer__newsletter-button">{{ section.settings.newsletter_button_text }}</button>

          {% if form.posted_successfully? %}
            <p class="footer__newsletter-message footer__newsletter-message--success">Thanks for subscribing.</p>
          {% endif %}

          {% if form.errors %}
            <p class="footer__newsletter-message footer__newsletter-message--error">{{ form.errors | default_errors }}</p>
          {% endif %}
        {% endform %}
      </div>
    {% endif %}

    <div class="footer__logo-wrap">
      {% if section.settings.logo != blank %}
        <div class="footer__logo" style="--logo-width: {{ section.settings.logo_width | default: 171 }}px;">
          {{ section.settings.logo | image_url: width: 1400 | image_tag: alt: section.settings.logo_alt, class: 'footer__logo-image' }}
        </div>
      {% endif %}
    </div>

    <div class="footer__bottom">
      <div class="footer__copyright">
        {{ section.settings.copyright_text }}
      </div>

      <div class="footer__right-links">
        {% if section.settings.right_links_menu != blank and linklists[section.settings.right_links_menu] %}
          {% assign rightmenu = linklists[section.settings.right_links_menu] %}
          <ul class="footer__right-list">
            {% for item in rightmenu.links %}
              <li class="footer__right-item"><a href="{{ item.url }}" class="footer__right-link">{{ item.title }}</a></li>
            {% endfor %}
          </ul>
        {% endif %}
      </div>
    </div>
  </div>
</footer>

{% stylesheet %}
.site-footer {
  background: #101828;
  color: #111;
  padding: var(--spacing-lg) 0 40px;
}

.site-footer .wrap {
  margin: 0 32px;
  padding-bottom: 10px;
  padding-top: 15rem;
  display: flex;
  flex-direction: column;
  height: 100%;
  justify-content: space-between;
}

.footer__menus {
  display: grid;
  grid-template-columns: minmax(220px, 1.4fr) repeat(4, minmax(120px, 1fr));
  gap: 48px;
  margin-bottom: 40px;
}

.footer__intro {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.footer__intro-logo-image {
  width: min(100%, var(--intro-logo-width));
  height: auto;
  display: block;
}

.footer__intro-content,
.footer__intro-content p {
  margin: 0;
  color: white;
  font-size: 16px;
  line-height: 1.6;
}

.footer__social {
  list-style: none;
  margin: 4px 0 0;
  padding: 0;
  display: flex;
  gap: 12px;
  align-items: center;
}

.footer__social-link {
  width: 44px;
  height: 44px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: var(--footer-social-bg, #1E2938);
  border-radius: 999px;
  position: relative;
  opacity: 0.95;
  transition: opacity 0.3s ease;
}

.footer__social-link:hover {
  opacity: 1;
}

.footer__social-icon {
  width: 60%;
  height: 60%;
  object-fit: contain;
  display: block;
  position: relative;
  z-index: 1;
}

.footer__menu-title {
  font-size: 20px;
  color: #fff;
  margin-bottom: 12px;
  font-weight: 600;
  white-space: nowrap;
}

.footer__menu-list {
  list-style: none;
  margin: 0;
  padding: 0;
}

.footer__menu-item {
  margin-bottom: 12px;
}

.footer__menu-link {
  color: #fff;
  text-decoration: none;
  font-size: 18px;
}

.footer__menu-link:hover {
  text-decoration: underline;
  text-underline-offset: 0.3rem;
  color: #f1bd56;
  transition: underline-offset 0.3s ease, color 0.3s ease;
  
}

.footer__menu--stacked .footer__menu-block {
  margin-bottom: 60px;
}

.footer__menu--stacked .footer__menu-block:last-child {
  margin-bottom: 0;
}

.footer__contact,
.footer__newsletter {
  border-top: 1px solid rgba(17, 17, 17, 0.12);
  padding-top: 24px;
  margin-bottom: 24px;
}

.footer__contact{
    border-bottom: 1px solid #3C3C3C;
    border-top: 1px solid #3C3C3C;
    padding: 5rem 0;
}

.footer__section-heading {
  margin: 0 0 20px;
  font-size: 22px;
  line-height: 1.2;
  color: #fff;
}

.footer__contact-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 20px;
}

.footer__contact-head {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 6px;
}

.footer__contact-logo {
  width: 26px;
  height: 26px;
  object-fit: contain;
  display: block;
}

.footer__contact-label {
  margin: 0;
  font-size: 16px;
  color: #888888;
}

.footer__contact-value,
.footer__contact-value p,
.footer__contact-value a {
  margin: 0;
  color: #fff;
  text-decoration: none;
  font-size: 18px;
  line-height: 1.35;
}

.footer__newsletter-subheading {
  margin: 0 0 14px;
  color: #888888;
  font-size: 16px;
}

.footer__newsletter-form {
  display: flex;
  gap: 12px;
  max-width: 30%;
}

.footer__newsletter-input {
  min-width: 260px;
  flex: 1;
  border: 1px solid #444444;
  background: #1E2938;
  color: #fff;
  border-radius: 999px;
  padding: 12px 16px;
  font-size: 16px;
}

.footer__newsletter-input::placeholder {
  color: #444444;
}

.footer__newsletter-button {
  border: 0;
  border-radius: 999px;
  padding: 12px 20px;
  background: linear-gradient(90deg, hsla(338, 77%, 67%, 1) 0%, hsla(281, 25%, 39%, 1) 100%, hsla(7, 89%, 69%, 1) 100%);
  color: #fff;
  cursor: pointer;
  white-space: nowrap;
  font-size: 16px;
}

.footer__newsletter-message {
  width: 100%;
  margin: 0;
  font-size: 13px;
}

.footer__newsletter-message--success {
  color: #8ee4a1;
}

.footer__newsletter-message--error {
  color: #ff8d8d;
}

.footer__logo-wrap {
  text-align: center;
  margin-bottom: 10px;
  margin-top: 5rem;
}

.footer__logo-image {
  width: 90vw;
  height: auto;
  display: block;
  margin: 0 auto;
  filter: brightness(1);
}

.footer__bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
}

.footer__copyright {
  font-size: 14px;
  color: #fff;
}

.footer__right-list {
  list-style: none;
  display: flex;
  gap: 16px;
  margin: 0;
  padding: 0;
}

.footer__right-link {
  color: #fff;
  text-decoration: none;
  font-size: 14px;
}

@media (max-width: 1100px) {
  .footer__menus {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 30px;
  }

  .footer__intro {
    grid-column: 1 / -1;
  }

  .footer__menu-title {
    font-size: 20px;
  }

  .footer__menu-link {
    font-size: 18px;
  }

  .footer__social-link{
    width: 35px;
    height: 35px;
  }

  .footer__section-heading {
    font-size: 24px;
  }

  .footer__contact-value,
  .footer__contact-value p,
  .footer__contact-value a {
    font-size: 18px;
  }
  .footer__newsletter-form{
    max-width: none;
  }
}

@media (max-width: 900px) {
  .site-footer .wrap {
    margin: 0 16px;
    padding-bottom: 10px;
    padding-top: 8rem;
  }

  .footer__menus {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
  }

  .footer__contact-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .footer__logo-wrap {
    margin: 24px 0;
  }
  .footer__contact-value,
.footer__contact-value p,
.footer__contact-value a {
    font-size: 14px;
}

.footer__contact{
    padding: 3rem 0;
}

  .footer__bottom {
    flex-direction: row;
    align-items: center;
    text-align: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .footer__right-list {
    flex-wrap: wrap;
    justify-content: center;
  }

  .footer__menu--stacked .footer__menu-block {
    margin-bottom: 25px;
  }
}

@media (max-width: 600px) {
  .footer__menus {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  .footer__intro {
    grid-column: 1 / -1;
  }

  .footer__contact-grid {
    grid-template-columns: repeat(2, 1fr);
  }


  .footer__newsletter-input {
    font-size: 14px;
    min-width: 0;
  }

  .footer__newsletter-button {
    font-size: 14px;
  }

  .footer__menu-title{
  font-size: 18px;
  }

  .footer__menu-link {
    font-size: 16px;
  }

  .footer__section-heading {
    font-size: 20px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "header", "content": "First column" },
    { "type": "image_picker", "id": "intro_logo", "label": "First column logo" },
    { "type": "text", "id": "intro_logo_alt", "label": "First column logo alt text", "default": "Footer logo" },
    { "type": "range", "id": "intro_logo_width", "label": "First column logo width (px)", "min": 80, "max": 500, "step": 10, "default": 180 },
    { "type": "richtext", "id": "intro_content", "label": "First column content", "default": "<p>Add your brand summary for the footer.</p>" },

    { "type": "header", "content": "Social icons" },
    { "type": "color", "id": "social_icon_bg", "label": "Social icon circle color", "default": "#1E2938" },

    { "type": "header", "content": "Menus" },
    { "type": "link_list", "id": "menu", "label": "Footer menu" },
    { "type": "link_list", "id": "right_links_menu", "label": "Bottom small links" },

    { "type": "header", "content": "Get in touch" },
    { "type": "text", "id": "get_in_touch_heading", "label": "Heading", "default": "Get in touch" },

    { "type": "header", "content": "Email signup" },
    { "type": "checkbox", "id": "show_newsletter", "label": "Show email signup", "default": true },
    { "type": "text", "id": "newsletter_heading", "label": "Signup heading", "default": "Stay updated" },
    { "type": "text", "id": "newsletter_subheading", "label": "Signup subheading", "default": "Get exclusive deals, new arrivals, and parenting tips delivered to your inbox." },
    { "type": "text", "id": "newsletter_placeholder", "label": "Email input placeholder", "default": "Enter your email" },
    { "type": "text", "id": "newsletter_button_text", "label": "Button label", "default": "Subscribe" },

    { "type": "header", "content": "Bottom logo" },
    { "type": "image_picker", "id": "logo", "label": "Bottom logo" },
    { "type": "text", "id": "logo_alt", "label": "Bottom logo alt text", "default": "Site logo" },
    { "type": "range", "id": "logo_width", "label": "Bottom logo max width (px)", "min": 160, "max": 1200, "step": 13, "default": 420 },

    { "type": "header", "content": "Footer bottom" },
    { "type": "text", "id": "copyright_text", "label": "Copyright text", "default": "© {{ 'now' | date: '%Y' }} Burosys." }
  ],
  "blocks": [
    {
      "type": "social_link",
      "name": "Social icon",
      "limit": 5,
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "Icon image" },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "text", "id": "label", "label": "Accessible label", "default": "Social" }
      ]
    },
    {
      "type": "contact_item",
      "name": "Get in touch item",
      "limit": 4,
      "settings": [
        { "type": "image_picker", "id": "contact_logo", "label": "Logo" },
        { "type": "text", "id": "label", "label": "Label", "default": "Email" },
        { "type": "richtext", "id": "value", "label": "Content", "default": "<p>hello@example.com</p>" }
      ]
    }
  ],
  "max_blocks": 9,
  "presets": [
    {
      "name": "Footer",
      "category": "Footer",
      "blocks": [
        { "type": "social_link" },
        { "type": "social_link" },
        { "type": "contact_item" },
        { "type": "contact_item" },
        { "type": "contact_item" }
      ]
    }
  ]
}
{% endschema %}
