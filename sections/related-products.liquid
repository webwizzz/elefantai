{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'section-related-products.css' | asset_url | stylesheet_tag }}

{% if settings.enable_product_variants %}
  {{ 'product-card-variants.css' | asset_url | stylesheet_tag }}
{% endif %}

{%- if settings.enable_quick_add -%}
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- liquid
  if section.settings.image_overlay != blank or section.settings.image_overlay_2 != blank or section.settings.image_overlay_3 != blank or section.settings.shape_type != 'none'
    assign section_overlay = true
  endif
-%}

<div class="section-responsive-padding {{ section.settings.background_color }} gradient no-js-hidden{% if section_overlay == true %} section-overlay{% endif %}">

  {%- if section.settings.image_overlay != blank or section.settings.image_overlay_2 != blank or section.settings.image_overlay_3 != blank -%}
    {% render 'section-overlay' %}
  {%- endif -%}

  {%- if section.settings.shape_type != 'none' -%}
    {% render 'shape',
      position: section.settings.shape_position, 
      type: section.settings.shape_type, 
      color: section.settings.shape_color,
      width: section.settings.shape_width
    %}
  {%- endif -%}

  <product-recommendations class="related-products page-width isolate"
    data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ section.settings.products_to_show }}">
    {% if recommendations.performed and recommendations.products_count > 0 %}
			{%- style -%}
				#shopify-section-{{ section.id }} {
					--padding-top: {{ section.settings.padding_top }}px;
					--padding-bottom: {{ section.settings.padding_bottom }}px;
				}
		
				{% if section.settings.colors_background_section_gradient != blank %}
					#shopify-section-{{ section.id }} .section-responsive-padding {
						background: {{ section.settings.colors_background_section_gradient }};
					}
				{% endif %}
			{%- endstyle -%}
			
      {%- if section.settings.heading != blank or section.settings.text != blank -%}
        <div class="related-products-heading">
          <div class="title-wrapper {{ section.settings.heading_align }} {{ section.settings.text_bottom_space }}">
            {%- if section.settings.heading != blank -%}
              <h2 class="title inline-richtext {{ section.settings.heading_size }} text-color-{{ section.settings.heading_color }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-rotate-in{% endif %}">
                {{ section.settings.heading }}
              </h2>
            {%- endif -%}
    
            {%- if section.settings.text != blank -%}
              <div class="description rte {{ section.settings.text_body_size }} text-color-{{ section.settings.description_color }} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-rotate-in{% endif %}">
                {{ section.settings.text -}}
              </div>
            {%- endif -%}
          </div>

          {% if section.settings.show_header_button %}
            <a href="{{ section.settings.header_button_url }}" class="featured-collection-header-link link small-hide medium-hide">
              {{ section.settings.header_button_label }}
              {% if settings.mood_type == 'mood5' %}
                {% render 'icon-arrow-short' %}
              {% endif %}
              {% if settings.mood_type == 'mood6' %}
                {% render 'icon-arrow-mood6' %}
              {% endif %}
            </a>    
          {% endif %}
        </div>
      {%- endif -%}
      
      <ul class="grid product-grid grid--{{ section.settings.columns_desktop }}-col-desktop grid--{{ section.settings.columns_mobile }}-col-tablet-down {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
        role="list">
        {% for recommendation in recommendations.products %}
          <li class="grid__item" >
						{%- assign placeholder_image = 'product-1' -%}
            {% render 'card-product',
              card_product: recommendation,
              media_aspect_ratio: section.settings.image_ratio,
              show_secondary_image: section.settings.show_secondary_image,
              show_vendor: section.settings.show_vendor,
              show_rating: section.settings.show_rating,
              show_quick_add: settings.enable_quick_add,
              section_id: section.id
			  			placeholder_image: placeholder_image
            %}
          </li>
        {% endfor %}
      </ul>
    {% endif %}
  </product-recommendations>
</div>

