		{
			"type": "textarea",
			"id": "subtitle",
			"label": "Description",
			"default": "Join our community for updates and inspiration and a closer look at our creations"
		},
		{
			"type": "range",
			"id": "heading_size",
			"label": "Heading Size",
			"min": 28,
			"max": 80,
			"step": 2,
			"default": 52,
			"unit": "px"
		},
		{
			"type": "range",
			"id": "subtitle_size",
