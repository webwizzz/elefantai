{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}
{{ 'newsletter-section.css' | asset_url | stylesheet_tag }}

{%- style -%}
	#shopify-section-{{ section.id }} {
		--padding-top: {{ section.settings.padding_top }}px;
		--padding-bottom: {{ section.settings.padding_bottom }}px;
	}

  {% if section.settings.color_background_main != blank %}
		#shopify-section-{{ section.id }} {
			--background-color: {{ section.settings.color_background_main }};
    }
  {% endif %}

  {% if section.settings.colors_background_section_gradient != blank %}
    #shopify-section-{{ section.id }} {
			--background-color: {{ section.settings.colors_background_section_gradient }};
    }
  {% endif %}

  {% if section.settings.show_image %}

    @media screen and (min-width: 750px) {
      #shopify-section-{{ section.id }} .grid__item.newsletter-media {
        width: calc({{ section.settings.column_width }}% - 0.5rem);
      }
      #shopify-section-{{ section.id }} .grid__item.newsletter-content {
        width: calc(100% - {{ section.settings.column_width }}% - 0.5rem);
      }
    }

  {% endif %}

  {% if section.settings.colors_background_section_gradient != blank %}
    #shopify-section-{{ section.id }} .newsletter__wrapper {
      background: {{ section.settings.colors_background_section_gradient }};
    }
  {% endif %}



{%- endstyle -%}

{%- liquid
  if section.settings.image_overlay != blank or section.settings.image_overlay_2 != blank or section.settings.image_overlay_3 != blank or section.settings.shape_type != 'none'
    assign section_overlay = true
  endif
-%}

<div class="section-responsive-padding newssub {{ section.settings.background_color_main }}{% if section.settings.show_image == false %} no-image{% endif %}{% if section_overlay == true %} section-overlay{% endif %}">

  {%- if section.settings.image_overlay != blank or section.settings.image_overlay_2 != blank or section.settings.image_overlay_3 != blank -%}
    {% render 'section-overlay' %}
  {%- endif -%}

	{%- if section.settings.shape_type != 'none' -%}
    {% render 'shape',
      position: section.settings.shape_position, 
      type: section.settings.shape_type, 
      color: section.settings.shape_color,
      width: section.settings.shape_width
    %}
  {%- endif -%}


	<div class="newsletter {% if section.settings.full_width == false %}page-width newsletter--narrow {% else %} full-width{% endif %}">

		<div class="newsletter__wrapper{% if section.settings.colors_background_section_gradient != blank %} gradient{% else %} {{ section.settings.background_color }}{% endif %} content-container isolate{% if section.settings.full_width == true %} content-container--full-width{% endif %} grid grid--gapless grid--1-col grid--2-col-tablet {% if section.settings.bg_image != blank %} image-bg {% endif %}" {% if section.settings.bg_image != blank %} style="background-image: url('{{ section.settings.bg_image | image_url: width: 480, height: 480 }}');" {% endif %}>

      {% if section.settings.show_image and section.settings.image_position == 'left' %}
        <div class="grid__item newsletter-media {% if section.settings.hide_image_mb %} small-hide {% endif %}">
          <div class="{% if section.settings.image != blank %} media media--transparent{% else %} image-with-text__media--placeholder placeholder{% endif %}" style="{% if section.settings.image != blank %}padding-bottom: {{ 1 | divided_by: section.settings.image.aspect_ratio | times: 100 }}%;{% endif %}">
            {%- if section.settings.image != blank -%}
              {%- assign widths = '165, 360, 535, 750, 1070, 1500' -%}
              {%- capture sizes -%}
                (min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 2 }}px,
                (min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)
              {%- endcapture -%}
              {{
                section.settings.image
                | image_url: width: 1500
                | image_tag: loading: 'lazy', sizes: sizes, widths: widths, alt: section.settings.image.alt
              }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
        </div>
      {% endif %}

			<div class="grid__item newsletter-content  {{ section.settings.content_alignment }}">
				<div class="newsletter-content--wrapp">
					{%- for block in section.blocks -%}
						{%- case block.type -%}
            
							{%- when '@app' -%}
								{% render block %}
		
							{%- when 'heading' -%}
								<h2 class="inline-richtext {{ block.settings.heading_size }} text-color-{{ block.settings.heading_color }} text-weight-{{ block.settings.heading_weight }} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-rotate-in{% endif %}" {{ block.shopify_attributes }} {% if settings.animations_reveal_on_scroll %} data-cascade style="--animation-order: {{ forloop.index }};"{% endif %}>
									{{ block.settings.heading }}
								</h2>
		
							{%- when 'paragraph' -%}
								<div class="newsletter__subheading rte {{ block.settings.text_style }} text-body--{{  block.settings.text_size }} text-color-{{ block.settings.text_color }} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" {{ block.shopify_attributes }} {% if settings.animations_reveal_on_scroll %} data-cascade style="--animation-order: {{ forloop.index }};"{% endif %}>
									{{ block.settings.text }}
								</div>

              {%- when 'coundownBar' -%}
                {%- render 'countdown-bar',
                  block: block,
                  forloop: forloop,
									style: block.settings.coundown_style,								
                  section_id: section.id
                -%}

              {%- when 'image' -%}
                {%- render 'block-image',
                  block: block,
                  forloop: forloop,
                  section_id: section.id 
                -%}

              {%- when 'social' -%}
                {%- render 'social-icons',
                  block: block,
                  forloop: forloop,
                  color_hover: block.settings.social_color_hover,
                  section_id: section.id 
                -%}

              {%- when 'video' -%}
                {%- render 'block-video',
                  block: block,
                  forloop: forloop,
                  section_id: section.id 
                -%}

              {%- when 'progress_bar' -%}
                {%- render 'progress-bar',
                  block: block,
                  forloop: forloop,
                  section_id: section.id 
                -%}
                
              {%- when 'featured_icon' -%}
                {%- render 'featured-icon',
                  block: block,
                  forloop: forloop,
                  section_id: section.id 
                -%}
								
							{%- when 'email_form' -%}
								<div class="newsletter-content--form" {{ block.shopify_attributes }}>
									{% form 'customer', class: 'newsletter-form' %}
										<input type="hidden" name="contact[tags]" value="newsletter">
										<div class="newsletter-form__field-wrapper{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" {% if settings.animations_reveal_on_scroll %} data-cascade style="--animation-order: {{ forloop.index }};" {% endif %}>
		
											<div class="field">
												<input type="email" id="NewsletterForm--{{ section.id }}" class="field__input" 
													name="contact[email]" value="{{ form.email }}"
													aria-required="true" autocorrect="off" autocapitalize="off" autocomplete="email"
													{% if form.errors %}
														autofocus aria-invalid="true" aria-describedby="Newsletter-error--{{ section.id }}"
													{% elsif form.posted_successfully? %}
														aria-describedby="Newsletter-success--{{ section.id }}"
													{% endif %}
													placeholder="{{ 'newsletter.label' | t }}" required >
												<label class="field__label" for="NewsletterForm--{{ section.id }}">
													{{ 'newsletter.label' | t }}
												</label>
												<button type="submit" class="newsletter-form__button field__button" name="commit" id="Subscribe" aria-label="{{ 'newsletter.button_label' | t }}" >
													{{ 'newsletter.button_label' | t }}
												</button>
											</div>
		
											{%- if form.errors -%}
												<small class="newsletter-form__message form__message" id="Newsletter-error--{{ section.id }}">
													{%- render 'icon-error' -%}
													{{- form.errors.translated_fields.email | capitalize }}
													{{ form.errors.messages.email -}}
												</small>
											{%- endif -%}
		
										</div>
										{%- if form.posted_successfully? -%}
											<h3 class="newsletter-form__message newsletter-form__message--success form__message" id="Newsletter-success--{{ section.id }}" tabindex="-1" autofocus>
												{% render 'icon-success' -%}
												{{- 'newsletter.success' | t }}
											</h3>
										{%- endif -%}
									{% endform %}
								</div>

						{%- endcase -%}
					{%- endfor -%}
				</div>
			</div>

			
      {% if section.settings.show_image and section.settings.image_position == 'right' %}
        <div class="grid__item newsletter-media {% if section.settings.hide_image_mb %} small-hide {% endif %}mobile-bottom">
          <div class="{% if section.settings.image != blank %} media media--transparent{% else %} image-with-text__media--placeholder placeholder{% endif %}" style="{% if section.settings.image != blank %}padding-bottom: {{ 1 | divided_by: section.settings.image.aspect_ratio | times: 100 }}%;{% endif %}">
            {%- if section.settings.image != blank -%}
              {%- assign widths = '165, 360, 535, 750, 1070, 1500' -%}
              {%- capture sizes -%}
                (min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 2 }}px,
                (min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)
              {%- endcapture -%}
              {{
                section.settings.image
                | image_url: width: 1500
                | image_tag: loading: 'lazy', sizes: sizes, widths: widths, alt: section.settings.image.alt
              }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
        </div>
      {% endif %}
      
		</div>
	</div>
</div>

{% schema %}
{
  "name": "t:sections.newsletter.name",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": [
      "header",
      "custom.additions"
    ]
  },
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.newsletter.settings.paragraph.content"
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "default": true,
      "label": "Show image"
    },
    {
      "type": "checkbox",
      "id": "hide_image_mb",
      "default": false,
      "label": "Hide image on mobile"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.image-with-text.settings.image.label"
    },
    {
      "type": "range",
      "id": "column_width",
      "min": 30,
      "max": 60,
      "step": 1,
      "unit": "%",
      "label": "Image width",
      "default": 50
    },
		{
			"type": "select",
			"id": "image_position",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left",
      "label": "Image position"
		},
    {
      "type": "select",
      "id": "content_alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center",
      "label": "Content alignment"
    },
    {
      "type": "select",
      "id": "background_color",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "color-main-bg",
          "label": "t:settings_schema.colors.settings.colors_background_main.label"
        },
        {
          "value": "color-bg-1",
          "label": "t:settings_schema.colors.settings.colors_background_section_1.label"
        },
        {
          "value": "color-bg-2",
          "label": "t:settings_schema.colors.settings.colors_background_section_2.label"
        },
        {
          "value": "color-bg-3",
          "label": "t:settings_schema.colors.settings.colors_background_section_3.label"
        },
        {
          "value": "color-bg-4",
          "label": "t:settings_schema.colors.settings.colors_background_section_4.label"
        },
        {
          "value": "color-bg-5",
          "label": "t:settings_schema.colors.settings.colors_background_section_5.label"
        }
      ],
      "default": "color-bg-3",
      "label": "Container background color",
      "info": "t:sections.all.colors.has_cards_info"
    },
    {
      "id": "colors_background_section_gradient",
      "type": "color_background",
      "label": "Container background gradient"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Container background image"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "default": false,
      "label": "t:sections.newsletter.settings.full_width.label"
    },
    {
      "type": "header",
      "content": "Section overlay"
    },
    {
      "type": "image_picker",
      "id": "image_overlay",
      "label": "Image overlay"
    },
    {
      "type": "range",
      "id": "image_overlay_width",
      "min": 1,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Image width",
      "default": 10
    },
    {
      "type": "range",
      "id": "image_overlay_vertical",
      "min": 1,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Image vertical position",
      "default": 20
    },
    {
      "type": "range",
      "id": "image_overlay_horizontal",
      "min": 1,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Image horizontal position",
      "default": 20
    },
    {
      "type": "range",
      "id": "image_overlay_width_mobile",
      "min": 1,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Image width mobile",
      "default": 10
    },
    {
      "type": "range",
      "id": "image_overlay_vertical_mobile",
      "min": 1,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Image vertical position mobile",
      "default": 20
    },
    {
      "type": "range",
      "id": "image_overlay_horizontal_mobile",
      "min": 1,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Image horizontal position mobile",
      "default": 20
    },
    {
      "type": "select",
      "id": "image_overlay_animation",
