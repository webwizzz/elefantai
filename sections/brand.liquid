{%- style -%}
  #Brands-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: 70px 0; /* Vertical padding */
    position: relative;
    overflow: hidden;
    font-family: inherit;
  }
  
  .brands-header-wrapper {
    position: relative;
    text-align: center;
    margin-bottom: 50px;
    padding: 0 20px;
  }
  
  .brands-left-img {
    position: absolute;
    top: 50%;
    left: 8%;
    transform: translateY(-50%);
    max-width: 120px;
    z-index: 1;
  }
  
  @media (max-width: 1100px) {
    .brands-left-img { left: 4%; max-width: 100px; }
  }
  
  @media (max-width: 800px) {
    .brands-left-img {
      position: static;
      display: block;
      margin: 0 auto 20px auto;
      transform: none;
      max-width: 90px;
    }
  }

  .brands-title {
    font-size: 3.6rem;
    font-weight: 700;
    color: #111;
    margin: 0 0 10px 0;
    letter-spacing: 0.5px;
  }
  
  .brands-title .highlight {
    color: {{ section.settings.highlight_color }};
  }
  
  .brands-subtitle {
    font-size: 1.5rem;
    color: #777;
    margin: 0;
    font-weight: 500;
  }

  .brands-marquee {
    width: 100vw;
    overflow: hidden;
    position: relative;
    display: flex;
    white-space: nowrap;
    /* This creates a soft fade effect on the far left and right edges for a premium look */
    -webkit-mask-image: linear-gradient(to right, transparent, black 3%, black 97%, transparent);
    mask-image: linear-gradient(to right, transparent, black 3%, black 97%, transparent);
  }

  .brands-track {
    display: flex;
    width: max-content;
    animation: scrollBrands {{ section.settings.scroll_speed }}s linear infinite;
    padding: 20px 0; 
    gap: 24px; /* Space between each card */
    padding-right: 24px; /* Ensure exact looping math aligns with gap logic */
  }

  /* Optional: pause slider when user hovers */
  .brands-track:hover {
    animation-play-state: paused;
  }

  @keyframes scrollBrands {
    0% { transform: translateX(0); }
    100% { transform: translateX(-25%); } /* 4 seamless copies mathematically offset */
  }

  .brand-card {
    background: #fff;
    border-radius: {{ section.settings.card_radius }}px;
    box-shadow: 0 4px 18px rgba(0,0,0,0.06);
    width: {{ section.settings.card_width }}px;
    height: {{ section.settings.card_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    flex-shrink: 0;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  
  .brand-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.1);
  }

  .brand-card img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    mix-blend-mode: multiply; /* Helps logos with non-transparent white backgrounds blend properly */
  }
  
  /* Placeholder SVG styling */
  .brand-placeholder {
    width: 100%;
    height: 100%;
    background: #f8f8f8;
    border-radius: 10px;
  }
{%- endstyle -%}

<div id="Brands-{{ section.id }}">
  <div class="brands-header-wrapper">
    {% if section.settings.left_image != blank %}
      <img src="{{ section.settings.left_image | image_url: width: 300 }}" class="brands-left-img" alt="Decorative Illustration" loading="lazy" width="{{ section.settings.left_image.width }}" height="{{ section.settings.left_image.height }}">
    {% endif %}
    
    <h2 class="brands-title">
      <span class="highlight">{{ section.settings.highlight_text }}</span> 
      {{ section.settings.heading }}
    </h2>
    <p class="brands-subtitle">{{ section.settings.subtitle }}</p>
  </div>

  <div class="brands-marquee">
    <div class="brands-track">
      {%- comment -%} Emulate 4 identical copies for an endless infinite 25% transformation loop {%- endcomment -%}
      {% for i in (1..4) %}
        
        {% for block in section.blocks %}
          <div class="brand-card" {{ block.shopify_attributes }}>
            {% if block.settings.logo != blank %}
              <img src="{{ block.settings.logo | image_url: width: 400 }}" alt="{{ block.settings.logo.alt | default: 'Brand Logo' | escape }}" width="{{ block.settings.logo.width }}" height="{{ block.settings.logo.height }}" loading="lazy">
            {% else %}
               <!-- Placeholder or Brand Name -->
               <svg class="brand-placeholder" viewBox="0 0 200 100" preserveAspectRatio="xMidYMid meet">
                 <text x="50%" y="50%" dominant-baseline="middle" text-anchor="middle" font-size="16" fill="#aaa">Brand</text>
               </svg>
            {% endif %}
          </div>
        {% endfor %}
        
        {%- comment -%} Display defaults if no blocks exist yet so preview works immediately {%- endcomment -%}
        {% if section.blocks.size == 0 %}
           {% for j in (1..6) %}
             <div class="brand-card">
               <svg class="brand-placeholder" viewBox="0 0 200 100" preserveAspectRatio="xMidYMid meet">
                 <text x="50%" y="50%" dominant-baseline="middle" text-anchor="middle" font-size="20" fill="#999">Logo {{ j }}</text>
               </svg>
             </div>
           {% endfor %}
        {% endif %}
        
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Trusted Brands Scroller",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background Color",
      "default": "#f6f5fb"
    },
    {
      "type": "header",
      "content": "Heading Setup"
    },
    {
      "type": "image_picker",
      "id": "left_image",
      "label": "Left Side Decorative Image",
      "info": "Upload the toy ring or other graphic."
    },
    {
      "type": "text",
      "id": "highlight_text",
      "label": "Highlighted Phrase",
      "default": "Trusted"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Highlight Text Color",
      "default": "#8A67A8"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Remaining Heading",
      "default": "Toy Brands"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Making toys accessible and sustainable"
    },
    {
      "type": "header",
      "content": "Scroller Configuration"
    },
    {
      "type": "range",
      "id": "scroll_speed",
      "min": 10,
      "max": 80,
      "step": 1,
      "unit": "s",
      "label": "Animation Speed (Lower is faster)",
      "default": 35
    },
    {
      "type": "range",
      "id": "card_width",
      "min": 150,
      "max": 350,
      "step": 10,
      "unit": "px",
      "label": "Logo Card Width",
      "default": 200
    },
    {
      "type": "range",
      "id": "card_height",
      "min": 100,
      "max": 250,
      "step": 10,
      "unit": "px",
      "label": "Logo Card Height",
      "default": 170
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Card Border Radius",
      "default": 24
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Brand Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Brand Logo Image (PNG/JPG)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trusted Brands Scroller",
      "category": "Image",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}
