{{ 'testimonials-grid.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
  	padding-top: {{ section.settings.padding_top | times: 0.53 | round: 0 }}px;
  	padding-bottom: {{ section.settings.padding_bottom | times: 0.53 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) and (max-width: 1024px) {
     .section-{{ section.id }}-padding {
  		padding-top: {{ section.settings.padding_top | times: 0.67 | round: 0 }}px;
       padding-bottom: {{ section.settings.padding_bottom | times: 0.67 | round: 0 }}px;
     }
   }

   @media screen and (min-width: 1025px) {
     .section-{{ section.id }}-padding {
       padding-top: {{ section.settings.padding_top }}px;
       padding-bottom: {{ section.settings.padding_bottom }}px;
     }
   }

  {% if section.settings.colors_background_section_gradient != blank %}
    .section-{{ section.id }}-padding{
      background: {{ section.settings.colors_background_section_gradient }};
    }
    #shopify-section-{{ section.id }} .gradient {
      background: transparent;
    }
  {% endif %}
{%- endstyle -%}

{%- liquid
  if section.settings.image_overlay != blank or section.settings.image_overlay_2 != blank or section.settings.image_overlay_3 != blank or section.settings.shape_type != 'none'
    assign section_overlay = true
  endif
-%}

<div class="{{ section.settings.background_color }} section-{{ section.id }}-padding{% if section_overlay == true %} section-overlay{% endif %}">
  {%- if section.settings.image_overlay != blank
    or section.settings.image_overlay_2 != blank
    or section.settings.image_overlay_3 != blank
  -%}
    {% render 'section-overlay' %}
  {%- endif -%}

  {%- if section.settings.shape_type != 'none' -%}
    {% render 'shape',
      position: section.settings.shape_position,
      type: section.settings.shape_type,
      color: section.settings.shape_color,
      width: section.settings.shape_width
    %}
  {%- endif -%}

  <div class="testominilas-grid page-width">
    {%- if section.settings.heading != blank or section.settings.text != blank -%}
      <div class="title-wrapper {{ section.settings.heading_align }} {{ section.settings.text_bottom_space }}">
        {%- if section.settings.heading != blank -%}
          <h2 class="title inline-richtext {{ section.settings.heading_size }} text-color-{{ section.settings.heading_color }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-rotate-in{% endif %}">
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <div class="description rte {{ section.settings.text_body_size }} text-color-{{ section.settings.text_color }} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
            {{ section.settings.text -}}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="testominilas-grid__wrapp media-width-{{ section.settings.desktop_image_width }}{% if section.settings.layout == 'text_first' %} testominilas__grid--reverse{% endif %}">
      <div class="testominilas-grid__media image-{{ section.settings.desktop_image_position }}">
        <div
          class="testominilas-grid__media-wrapp media testominilas-media--{{ section.settings.height }}"
          {% if section.settings.height == 'adapt' and section.settings.image != blank %}
            style="padding-bottom: {{ 1 | divided_by: section.settings.image.aspect_ratio | times: 100 }}%;"
          {% elsif section.settings.image == blank %}
            style="padding-bottom:100%;"
          {% endif %}
        >
          {%- if section.settings.image != blank -%}
            {%- assign widths = '165, 360, 535, 750, 1070, 1500' -%}
            {%- capture sizes -%}
              (min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 2 }}px,
              (min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)
            {%- endcapture -%}
            {{
              section.settings.image
              | image_url: width: 1500, format: 'webp' 
              | image_tag: loading: 'lazy', sizes: sizes, widths: widths
            }}
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
          {%- endif -%}
        </div>
      </div>

      <div class="testominilas-grid__list">
        {%- for block in section.blocks -%}
          <div
            class="testimonial-item item-{{ forloop.index }}{% if block.settings.image != blank %} testimonail-with-image{% endif %} {{ block.settings.background_color }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {% if settings.animations_reveal_on_scroll %}
              data-cascade style="--animation-order: {{ forloop.index }};"
            {% endif %}
            {{ block.shopify_attributes }}
          >
            <div
              class="star-rating"
              style="--star-rating: {{ block.settings.star_rating }}; --color-star: {{ block.settings.star_color }};"
            ></div>

            <h3 class="testimonial-title text-color-{{ block.settings.title_color }}">
              {{ block.settings.testimonail_title }}
            </h3>

            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 200, format: 'webp' 
                | image_tag: loading: 'lazy', alt: block.settings.image.alt
              }}
            {%- endif -%}

            <div class="testimonial-description rte text-color-{{ block.settings.description_color }}">
              {{ block.settings.testimonail_description }}
            </div>

            <p class="testimonial-author text-color-{{ block.settings.author_color }}">
              {{ block.settings.testimonail_author }}
            </p>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

