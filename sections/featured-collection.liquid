{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'swiper.css' | asset_url | stylesheet_tag }}

{% if settings.enable_product_variants %}
  {{ 'product-card-variants.css' | asset_url | stylesheet_tag }}
{% endif %}

{%- if settings.enable_quick_add -%}
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- style -%}
  #shopify-section-{{ section.id }} {
		--padding-top: {{ section.settings.padding_top }}px;
		--padding-bottom: {{ section.settings.padding_bottom }}px;

		{% if section.settings.enable_border_radius %}
			--custom-radius: {{ section.settings.border_radius }}px;
		{% endif %}

		--arrows-clr: {{ section.settings.arrows_btn_color.red }}, {{ section.settings.arrows_btn_color.green }}, {{ section.settings.arrows_btn_color.blue }};
		--arrows-clr-hover: {{ section.settings.arrows_btn_color_hover.red }}, {{ section.settings.arrows_btn_color_hover.green }}, {{ section.settings.arrows_btn_color_hover.blue }};
		--arrows-bg: {{ section.settings.arrows_btn_bg_color.red }}, {{ section.settings.arrows_btn_bg_color.green }}, {{ section.settings.arrows_btn_bg_color.blue }};
		--arrows-bg-hover: {{ section.settings.arrows_btn_bg_color_hover.red }}, {{ section.settings.arrows_btn_bg_color_hover.green }}, {{ section.settings.arrows_btn_bg_color_hover.blue }};
  }

	{% if section.settings.colors_background_section_gradient != blank %}
		#shopify-section-{{ section.id }} .section-responsive-padding {
			background: {{ section.settings.colors_background_section_gradient }};
		}
	{% endif %}
	{% if section.settings.image_overlay_opacity > 0 %}
	#shopify-section-{{ section.id }} .featured-collection--image .media::after {
			opacity: {{ section.settings.image_overlay_opacity | divided_by: 100.0 }};
		}
	{% endif %}
	{% if section.settings.padding_top > 0 and section.settings.padding_bottom > 0 and settings.mood_type == "kawai" %}
		#shopify-section-{{ section.id }} .featured-collection {
			border-top: 1px solid rgb(var(--border-color));
			border-bottom: 1px solid rgb(var(--border-color));
		}
	{% endif %}

	{% if section.settings.coundown_number_size > 70 %}
		#shopify-section-{{ section.id }} .featured-collection--image .media {
			height: 100%;
			padding: 0;
			position: absolute;
		}

		#shopify-section-{{ section.id }} .banner-content {
			position: static;
			padding-top: 4rem;
			padding-bottom: 4rem;
		}
	{% endif %}
{%- endstyle -%}

{%- liquid
  if section.settings.collection.all_products_count > section.settings.products_to_show
    assign more_in_collection = true
  endif

  if section.settings.image_overlay != blank or section.settings.image_overlay_2 != blank or section.settings.image_overlay_3 != blank or section.settings.shape_type != 'none'
    assign section_overlay = true
  endif

  assign button_type = 'button button--outline'
	assign button_icon = false
	if section.settings.button_type == 'inline'
		assign button_type = 'link link-with-icon'
		assign button_icon = true
	endif

  if section.settings.button_type == 'regular_button'
		assign button_type = 'button'
		assign button_icon = false
	endif
-%}

<div class="featured-collection isolate gradient">
  <div class="collection section-responsive-padding {% if section.settings.colors_background_section_gradient != blank %} gradient{% else %} {{ section.settings.background_color }}{% endif %}{% if section_overlay == true %} section-overlay{% endif %}">
    {%- if section.settings.image_overlay != blank
      or section.settings.image_overlay_2 != blank
      or section.settings.image_overlay_3 != blank
    -%}
      {% render 'section-overlay' %}
    {%- endif -%}

    {%- if section.settings.shape_type != 'none' -%}
      {% render 'shape',
        position: section.settings.shape_position,
        type: section.settings.shape_type,
        color: section.settings.shape_color,
        width: section.settings.shape_width
      %}
    {%- endif -%}
    
    <div class="featured-collection--wrapp{% if section.settings.show_collection_image == true %} image-{{ section.settings.image_position }}{% endif %}{% if section.settings.full_width != true %} page-width{% else %} full-width{% endif %}">
      {%- if section.settings.title != blank or section.settings.description != blank -%}
        <div class="{% if section.settings.full_width == true %}page-width{% endif %}{% if section.settings.image_position != "top" and section.settings.show_collection_image == true %} medium-hide large-up-hide{% endif %}">
          <div class="featured-collection-header">
            <div class="title-wrapper {{ section.settings.text_bottom_space }} {{ section.settings.heading_align }} mobile-{{ section.settings.heading_alignment_mb }}">
              {%- if section.settings.title != blank -%}
                <h2 class="title inline-richtext {{ section.settings.heading_size }} text-color-{{ section.settings.heading_color }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-rotate-in{% endif %}">
                  {{ section.settings.title }}
                </h2>
              {%- endif -%}

              {%- if section.settings.description != blank -%}
                <div class="description rte {{ section.settings.text_body_size }} text-color-{{ section.settings.text_color }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
                  {{ section.settings.description -}}
                </div>
              {%- endif -%}
            </div>

            {% if section.settings.show_header_button and section.settings.arrows_on_top != true %}
              
              <a href="{{ section.settings.header_button_url }}" class="{{ button_type }} small-hide medium-hide{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
                <span>
                  {{ section.settings.header_button_label }}
                </span>
                {%- if button_icon -%}
                  {% if settings.mood_type != 'mood5' and settings.mood_type != 'mood6' %}  
                    {% render 'icon-arrow-link' %}
                  {% endif %}
                  {% if settings.mood_type == 'mood5' %}
                    {% render 'icon-arrow-short' %}
                  {% endif %}
                  {% if settings.mood_type == 'mood6' %}
                    {% render 'icon-arrow-mood6' %}
                  {% endif %}
                {%- endif -%}
              </a>
            {% endif %}
          
          {% if section.settings.arrows_on_top == true and section.settings.enable_slider == true%}
            <div class="slider-navigation">
              <div class="slider-arrow slider-arrow-prev {% if section.settings.arrows_outline %} slider-arrow--transparent {% endif %}" aria-label="Previous slide">
                {% if settings.mood_type == 'kawai' %}
                  {% render 'icon-arrow-red' %}
                {% else %}
                  {% render 'icon-arrow-slider' %}
                {% endif %}
              </div>
              <div class="slider-arrow slider-arrow-next {% if section.settings.arrows_outline %} slider-arrow--transparent {% endif %}" aria-label="Next slide">
                {% if settings.mood_type == 'kawai' %}
                  {% render 'icon-arrow-red' %}
                {% else %}
                  {% render 'icon-arrow-slider' %}
                {% endif %}
              </div>
            </div>
          {% endif %}
          </div>
        </div>
      {%- endif -%}

      {% if section.settings.show_collection_image == true %}
        {% if section.settings.image_position == 'top' and section.settings.full_width == true %}
          <div class="page-width featured-collection-banner">
        {% endif %}

        {%- liquid
          assign collection_image = section.settings.collection.featured_image
          if section.settings.custom_image != blank
            assign collection_image = section.settings.custom_image
          endif
          assign ratio = 70
          if collection_image and section.settings.image_position == 'top'
            assign ratio = collection_image.aspect_ratio
          endif
          if ratio == 0 or ratio == null
            assign ratio = 1
          endif
        -%}

        <div
          class="featured-collection--image"
          style="{% if section.settings.image_position == 'top' %}--ratio-percent: {{ 1 | divided_by: ratio | times: 100 }}%;{% else %}--ratio-percent: {{ ratio }}%;{% endif %}"
        >

          <div class="media{% if collection_image == blank %} empty-image{% endif %}">
            {%- if collection_image -%}
              {{
                collection_image
                | image_url: width: 3840
                | image_tag:
                  loading: 'lazy',
                  width: collection_image.width,
                  height: collection_image.height,
                  sizes: '70vw',
                  class: 'motion-reduce',
                  widths: '330, 535, 650, 750, 850, 950, 1050, 1200, 1300, 1400, 1500',
                  alt: collection_image.alt
              }}
            {% else %}
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
            {%- endif -%}
          </div>

          <div class="banner-content">
            <div class="banner-text inline-richtext text-color-{{ section.settings.banner_text_color }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
              {{- section.settings.banner_text -}}
            </div>

            {%- render 'countdown-bar',
              block: section,
              forloop: 2,
              style: section.settings.coundown_style,
              section_id: section.id
            -%}
          </div>

          {%- if section.settings.icon != blank -%}
            {{
              section.settings.icon
              | image_url: width: 115
              | image_tag: loading: 'lazy', class: 'featured-collection--icon', alt: section.settings.icon.alt
            }}
          {%- endif -%}
        </div>

        {% if section.settings.image_position == 'top' and section.settings.full_width == true %}
          </div>
        {% endif %}
      {% endif %}

      <div class="{% if section.settings.enable_slider == true %}featured-collection--slider{% else %}featured-collection--grid{% endif %}">
        {%- if section.settings.title != blank
          and section.settings.image_position != 'top'
          and section.settings.show_collection_image == true
        -%}
          <div class="title-wrapper {{ section.settings.text_bottom_space }} {{ section.settings.heading_align }} {% if section.settings.show_collection_image == true %} small-hide{% endif %}{% if section.settings.full_width and section.settings.show_collection_image != true %} page-width{% endif %}">
            <h2 class="title rte inline-richtext {{ section.settings.heading_size }} text-color-{{ section.settings.heading_color }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
              {{ section.settings.title }}
            </h2>

            {%- if section.settings.description != blank -%}
              <div class="collection__description rte text-color-{{ section.settings.text_color }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
                {{ section.settings.description -}}
              </div>
            {%- endif -%}
						{% if section.settings.arrows_on_top == true and section.settings.enable_slider == true%}
							<div class="slider-navigation small-hide medium-hide">
								<div class="slider-arrow slider-arrow-prev {% if section.settings.arrows_outline %} slider-arrow--transparent {% endif %}" aria-label="Previous slide">
									{% if settings.mood_type == 'kawai' %}
										{% render 'icon-arrow-red' %}
									{% else %}
										{% render 'icon-arrow-slider' %}
									{% endif %}
								</div>
								<div class="slider-arrow slider-arrow-next {% if section.settings.arrows_outline %} slider-arrow--transparent {% endif %}" aria-label="Next slide">
									{% if settings.mood_type == 'kawai' %}
										{% render 'icon-arrow-red' %}
									{% else %}
										{% render 'icon-arrow-slider' %}
									{% endif %}
								</div>
							</div>
						{% endif %}
						</div>
        {%- endif -%}

        {% if section.settings.enable_slider == true %}
          <div
            class="swiper collection-slider-{{ section.id }} collection-slider"
            data-section-id="{{ section.id }}"
            data-columns-mobile="{{ section.settings.columns_mobile }}"
            data-columns-desktop="{{ section.settings.columns_desktop }}"
            data-centered-slide="{% if section.settings.image_position == "top" %}true{% else %}false{% endif %}"
            data-centered-slides="{{ section.settings.center_slide }}"
          >
            <div class="swiper-wrapper c-{{ section.settings.columns_desktop | round }}{% if section.settings.show_collection_image == true and section.settings.columns_desktop > 3 and section.settings.image_position != "top" %} button-small{% endif %}">
              {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
                <div class="swiper-slide">
								{%- assign placeholder_image = 'product-1' -%}
                  {% render 'card-product',
                    card_product: product,
                    media_aspect_ratio: section.settings.image_ratio,
                    show_secondary_image: section.settings.show_secondary_image,
                    show_vendor: section.settings.show_vendor,
                    show_rating: section.settings.show_rating,
                    show_quick_add: settings.enable_quick_add,
                    section_id: section.id
										placeholder_image: placeholder_image
                  %}
                </div>
              {%- else -%}
                {%- for i in (1..4) -%}
                  <div class="swiper-slide">
                    {%- assign placeholder_image = 'product-' | append: forloop.rindex -%}
                    {% render 'card-product',
                      show_vendor: section.settings.show_vendor,
                      placeholder_image: placeholder_image
                    %}
                  </div>
                {%- endfor -%}
              {%- endfor -%}
            </div>
              <div class="slider-navigation {% if section.settings.full_width and section.settings.show_collection_image != true %} page-width{% endif %} {% if section.settings.arrows_on_top == true %}hide-desktop{% endif %}">
                <div class="slider-arrow slider-arrow-prev {% if section.settings.arrows_outline %} slider-arrow--transparent {% endif %}" aria-label="Previous slide">
                  {% if settings.mood_type == 'kawai' %}
                    {% render 'icon-arrow-red' %}
                  {% else %}
                    {% render 'icon-arrow-slider' %}
                  {% endif %}
                </div>
                <div class="slider-arrow slider-arrow-next {% if section.settings.arrows_outline %} slider-arrow--transparent {% endif %}" aria-label="Next slide">
                  {% if settings.mood_type == 'kawai' %}
                    {% render 'icon-arrow-red' %}
                  {% else %}
                    {% render 'icon-arrow-slider' %}
                  {% endif %}
                </div>
              </div>
          </div>
        {% else %}
          <ul class="grid product-grid contains-card contains-card--product grid--{{ section.settings.columns_desktop_grid }}-col-desktop grid--{{ section.settings.columns_mobile_grid }}-col-tablet-down{% if section.settings.show_collection_image == true and section.settings.columns_desktop_grid > 3 %} button-small{% endif %}">
            {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
              <li id="Slide-{{ section.id }}-{{ forloop.index }}"
                class="grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                {% if settings.animations_reveal_on_scroll %}
                  data-cascade style="--animation-order: {{ forloop.index }};"
                {% endif %}>
								{%- assign placeholder_image = 'product-' | append: forloop.rindex -%}
                {% render 'card-product',
                  card_product: product,
                  media_aspect_ratio: section.settings.image_ratio,
                  show_secondary_image: section.settings.show_secondary_image,
                  show_vendor: section.settings.show_vendor,
                  show_rating: section.settings.show_rating,
                  show_quick_add: settings.enable_quick_add,
                  section_id: section.id
									placeholder_image: placeholder_image,
                %}
              </li>
            {%- else -%}
              {%- for i in (1..4) -%}
                <li class="grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" {% if settings.animations_reveal_on_scroll %} data-cascade style="--animation-order: {{ forloop.index }};" {% endif %} >

                  {%- assign placeholder_image = 'product-' | append: forloop.rindex -%}

                  {% render 'card-product',
                    show_vendor: section.settings.show_vendor,
                    placeholder_image: placeholder_image,
                  %}
                </li>
              {%- endfor -%}
            {%- endfor -%}
          </ul>
        {% endif %}
    
        {%- if section.settings.show_view_all and more_in_collection -%}
          <div class="center collection__view-all{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
            <a href="{{ section.settings.collection.url }}" class="button" aria-label="{{ 'sections.featured_collection.view_all_label' | t: collection_name: section.settings.collection.title }}">
              {{ 'sections.featured_collection.view_all' | t }}
            </a>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% if section.settings.enable_slider == true %}
	<script src="{{ 'slider-featured-collection.js' | asset_url }}" defer="defer"></script>
{% endif %}

{% schema %}
{
  "name": "t:sections.featured-collection.name",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "custom.additions"
    ]
  },
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "t:sections.featured-collection.settings.collection.label"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "<strong>Featured collection</strong>",
      "label": "t:sections.all.heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
		{
          "value": "h4",
          "label": "Extra small"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__3.label"
        }
      ],
      "default": "h2",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "select",
      "id": "heading_color",
      "options": [
        {
          "value": "main",
          "label": "t:settings_schema.colors.settings.colors_text.label"
        },
        {
          "value": "secondary",
          "label": "t:settings_schema.colors.settings.colors_secondary_text.label"
        },
        {
          "value": "heading",
          "label": "t:settings_schema.colors.settings.colors_heading.label"
        },
        {
          "value": "heading-secondary",
          "label": "t:settings_schema.colors.settings.colors_secondary_heading.label"
        }
      ],
      "default": "heading",
      "label": "t:sections.all.colors.label_heading",
      "info": "t:sections.all.colors.has_cards_info"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:sections.featured-collection.settings.description.label"
    },
    {
      "type": "select",
      "id": "text_body_size",
      "options": [
        {
          "value": "text-body--small",
          "label": "Small"
        },
        {
          "value": "text-body--medium",
          "label": "Medium"
        },
        {
          "value": "text-body--large",
          "label": "Large"
        }
      ],
      "default": "text-body--large",
      "label": "Text size"
    },
    {
      "type": "select",
      "id": "text_color",
      "options": [
        {
          "value": "main",
          "label": "t:settings_schema.colors.settings.colors_text.label"
        },
        {
          "value": "secondary",
          "label": "t:settings_schema.colors.settings.colors_secondary_text.label"
        },
        {
          "value": "heading",
          "label": "t:settings_schema.colors.settings.colors_heading.label"
        },
        {
          "value": "heading-secondary",
          "label": "t:settings_schema.colors.settings.colors_secondary_heading.label"
        }
      ],
      "default": "main",
      "label": "t:sections.all.colors.label_description",
      "info": "t:sections.all.colors.has_cards_info"
    },
    {
      "type": "select",
      "id": "heading_align",
      "options": [
        {
          "value": "left",
          "label": "t:sections.all.heading_align.options__1.label"
        },
        {
          "value": "center",
          "label": "t:sections.all.heading_align.options__2.label"
        },
        {
          "value": "right",
          "label": "t:sections.all.heading_align.options__3.label"
        }
      ],
      "default": "center",
      "label": "t:sections.all.heading_align.label__2"
    },
    {
      "type": "text_alignment",
      "id": "heading_alignment_mb",
      "label": "Content alignment mobile",
      "default": "center"
    },
    {
      "type": "select",
      "id": "text_bottom_space",
      "options": [
        {
          "value": "",
          "label": "Small"
        },
        {
          "value": "mb-lg-6",
          "label": "Large"
        }
      ],
      "default": "",
      "label": "Text bottom space desktop"
    },
    {
      "type": "header",
      "content": "Header button"
    },
    {
      "type": "checkbox",
      "id": "show_header_button",
      "default": false,
      "label": "Show button",
      "info": "Displayed only when slider arrows are not at the top"
    },
    {
      "type": "select",
      "id": "button_type",
      "options": [
        {
          "value": "regular_button",
          "label": "Regular button"
        },
        {
          "value": "outline",
          "label": "Outline button"
        },
        {
          "value": "inline",
          "label": "Inline button with icon"
        }
      ],
      "default": "inline",
			"label": "Button type"
    },
    {
      "type": "text",
      "id": "header_button_label",
      "default": "SHOP ALL PRODUCTS",
      "label": "Label"
    },
    {
      "type": "url",
      "id": "header_button_url",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Collection banner"
    },
    {
      "type": "checkbox",
      "id": "show_collection_image",
      "default": true,
      "label": "Show collection banner"
    },
		{
      "type": "select",
      "id": "image_position",
      "label": "Desktop banner position",
      "options": [
        {
          "value": "top",
          "label": "Top"
        },
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "top"
    },
    {
      "type": "image_picker",
      "id": "custom_image",
      "label": "Custom image"
    },
    {
      "type": "range",
      "id": "image_overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "%",
      "label": "t:sections.image-banner.settings.image_overlay_opacity.label",
      "default": 0
    },
    {
        "type": "checkbox",
        "id": "enable_border_radius",
        "label": "Enable custom border radius"
    },
    {
        "type": "range",
        "id": "border_radius",
        "min": 0,
        "max": 300,
        "step": 5,
        "unit": "px",
        "label": "Border radius",
        "default": 100
    },
    {
      "type": "image_picker",
      "id": "icon",
      "label": "Icon"
    },
    {
      "type": "richtext",
      "id": "banner_text",
      "label": "Banner text"
    },
    {
      "type": "select",
      "id": "banner_text_color",
      "options": [
        {
          "value": "main",
          "label": "t:settings_schema.colors.settings.colors_text.label"
        },
        {
          "value": "secondary",
          "label": "t:settings_schema.colors.settings.colors_secondary_text.label"
        },
        {
          "value": "heading",
          "label": "t:settings_schema.colors.settings.colors_heading.label"
        },
        {
          "value": "heading-secondary",
          "label": "t:settings_schema.colors.settings.colors_secondary_heading.label"
        }
      ],
      "default": "secondary",
      "label": "Text color",
      "info": "t:sections.all.colors.has_cards_info"
    },
    {
      "type": "text",
      "id": "coundown_date",
      "default": "Apr 31, 2024",
      "label": "End date",
      "info": "Example: Dec 31, 2024 or Dec 31, 2024 20:00"
    },
