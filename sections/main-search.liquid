{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-article-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-search.css' | asset_url | stylesheet_tag }}

{%- if section.settings.enable_filtering or section.settings.enable_sorting -%}
  {{ 'component-facets.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'facets.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{% if settings.enable_product_variants %}
  {{ 'product-card-variants.css' | asset_url | stylesheet_tag }}
   
{% endif %}

{%- if settings.enable_quick_add -%}
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

<script src="{{ 'main-search.js' | asset_url }}" defer="defer"></script>

<style>
  .template-search__search {
    margin: 0 auto;
    max-width: 74.1rem;
  }
  .template-search__search .search {
    margin-top: 3rem;
  }
  .search__button .icon {
    height: 1.8rem;
  }
</style>

{%- liquid
  assign sort_by = search.sort_by | default: search.default_sort_by
  assign terms = search.terms | escape
  assign search_url = '?q=' | append: terms | append: '&options%5Bprefix%5D=last&sort_by=' | append: sort_by
  assign article_image_ratio = 1
  if section.settings.image_ratio == 'portrait'
      assign article_image_ratio = 0.85
    elsif section.settings.image_ratio == 'tallview'
      assign article_image_ratio = 0.72
  endif
-%}

{%- style -%}
  @media screen and (max-width: 749px) {
    .banner-{{ section.id }}-padding {
      padding-top: {{ section.settings.banner_padding_top | times: 0.53 | round: 0 }}px;
      padding-bottom: {{ section.settings.banner_padding_bottom | times: 0.53 | round: 0 }}px;
    }
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.53 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.53 | round: 0 }}px;
    }
  }
  @media screen and (min-width: 750px) and (max-width: 1024px) {
    .banner-{{ section.id }}-padding {
      padding-top: {{ section.settings.banner_padding_top | times: 0.67 | round: 0 }}px;
      padding-bottom: {{ section.settings.banner_padding_bottom | times: 0.67 | round: 0 }}px;
    }
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.67 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.67 | round: 0 }}px;
    }
  }
  @media screen and (min-width: 1025px) {
    .banner-{{ section.id }}-padding {
      padding-top: {{ section.settings.banner_padding_top }}px;
      padding-bottom: {{ section.settings.banner_padding_bottom }}px;
    }
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  {% if section.settings.colors_background_section_gradient != blank %}
    .template-search__header {
      background: {{ section.settings.colors_background_section_gradient }};
    }
  {% endif %}

	{% if section.settings.main_colors_background_section_gradient != blank %}
		.section-{{ section.id }}-padding {
			background: {{ section.settings.main_colors_background_section_gradient }};
		}
		.section-{{ section.id }}-padding .gradient {
			background:transparent;
		}
	{% endif %}
{%- endstyle -%}

{% paginate search.results by 24 %}
  <div class="template-search{% unless search.performed and search.results_count > 0 %} template-search--empty{% endunless %}{% if section.settings.filter_type == 'horizontal' %} facets-type-horisontal{% endif %} {{ section.settings.background_color }}">

    <div class="template-search__header {{ section.settings.background_color }} banner-{{ section.id }}-padding{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}{% if section.settings.full_width %} full-width{% endif %}">

      {%- if section.settings.overlay_image != blank or section.settings.overlay_image_right != blank -%}

        {%- capture sizes -%}
          (min-width: {{ settings.page_width }}px) 1700px, (min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)
        {%- endcapture -%}

        {%- if section.settings.overlay_image != blank -%}
          <div class="search-hero--overlay">
            {{
              section.settings.overlay_image
              | image_url: width: 1700
              | image_tag: 
                loading: 'lazy', 
                width: section.settings.overlay_image.width,
                height: section.settings.overlay_image.height,
                sizes: sizes,
                widths: '375, 450, 550, 650, 750, 850, 950, 1100, 1300, 1440, 1650, 1800, 1980', 
                alt: section.settings.overlay_image.alt
            }}
          </div>
        {%- endif -%}
      {%- endif -%}

      {%- if section.settings.overlay_image_right != blank -%}
        <div class="search-hero--overlay-right">
          {{
            section.settings.overlay_image_right
            | image_url: width: 1700
            | image_tag: 
              loading: 'lazy', 
              width: section.settings.overlay_image_right.width,
              height: section.settings.overlay_image_right.height,
              sizes: sizes,
              widths: '375, 450, 550, 650, 750, 850, 950, 1100, 1300, 1440, 1650, 1800, 1980',
              alt: section.settings.overlay_image_right.alt
          }}
        </div>
      {%- endif -%}

      <h1 class="center text-color-{{ section.settings.text_color }} {{ section.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-rotate-in{% endif %}">
        {%- if search.performed -%}
          {{- 'templates.search.title' | t -}}
        {%- else -%}
          {{- 'general.search.search' | t -}}
        {%- endif -%}
      </h1>

      <div class="template-search__search">
        {%- if settings.predictive_search_enabled -%}
          <predictive-search data-loading-text="{{ 'accessibility.loading' | t }}">
        {%- endif -%}
            <main-search>
              <form action="{{ routes.search_url }}" method="get" role="search" class="search">
                <div class="field">
                  <input class="search__input field__input" id="Search-In-Template"
                    type="search" name="q" value="{{ search.terms | escape }}" placeholder="{{ 'general.search.search' | t }}"
                    {%- if settings.predictive_search_enabled -%}
                      role="combobox" aria-expanded="false" aria-owns="predictive-search-results" aria-controls="predictive-search-results"
                      aria-haspopup="listbox" aria-autocomplete="list" autocorrect="off" autocomplete="off" autocapitalize="off" spellcheck="false"
                    {%- endif -%}>

                  <label class="field__label" for="Search-In-Template">
                    {{ 'general.search.search' | t }}
                  </label>

                  <input name="options[prefix]" type="hidden" value="last">

                  {%- if settings.predictive_search_enabled -%}
                    <div class="predictive-search predictive-search--search-template" tabindex="-1" data-predictive-search>
                      <div class="predictive-search__loading-state">
                        <svg aria-hidden="true" focusable="false" class="spinner" viewBox="0 0 66 66" xmlns="http://www.w3.org/2000/svg">
                          <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
                        </svg>
                      </div>
                    </div>

                    <span class="predictive-search-status visually-hidden" role="status" aria-hidden="true"></span>
                  {%- endif -%}

                  <button type="reset" class="reset__button field__button{% if search.terms == blank %} hidden{% endif %}" aria-label="{{ 'general.search.reset' | t }}">
                    <svg class="icon icon-close" aria-hidden="true" focusable="false">
                      <use xlink:href="#icon-reset">
                    </svg>
                  </button>
                  <button type="submit" class="search__button field__button" aria-label="{{ 'general.search.search' | t }}">
                    <svg class="icon icon-search" aria-hidden="true" focusable="false">
                      <use xlink:href="#icon-search">
                    </svg>
                  </button>
                </div>
              </form>
            </main-search>
        {%- if settings.predictive_search_enabled -%}
          </predictive-search>
        {%- endif -%}
      </div>

      {%- if search.performed -%}
        {%- unless section.settings.enable_filtering or section.settings.enable_sorting -%}
          {%- if search.results_count > 0 -%}
            <p class="h5 status center page-width text-color-{{ section.settings.text_color }}" role="status">
              {{ 'templates.search.results_with_count_and_term' | t: terms: search.terms, count: search.results_count }}
            </p>
          {%- endif -%}
        {%- endunless -%}

        {%- if search.results_count == 0 and search.filters == empty -%}
          <p class="h5 status center page-width text-color-{{ section.settings.text_color }}" role="status">
            {{ 'templates.search.no_results' | t: terms: search.terms }}
          </p>
        {%- endif -%}
      {%- endif -%}
    </div>

    {%- if search.performed -%}
      <div class="section-{{ section.id }}-padding {{ section.settings.main_background_color }} {% if section.settings.filter_type == 'vertical' %}facets-vertical page-width{% endif %}">

        {%- if search.filters != empty -%}
          {%- if section.settings.enable_filtering or section.settings.enable_sorting -%}
            <aside aria-labelledby="verticalTitle" class="facets-wrapper{% unless section.settings.enable_filtering %} facets-wrapper--no-filters{% endunless %}{% if section.settings.filter_type != 'vertical' %} page-width{% endif %} text-color-{{ section.settings.filter_color_hover }}-hover{% if section.settings.show_filter_checkbox == false %} hide-checkbox{% endif %}" id="main-search-filters" data-id="{{ section.id }}">
              {% render 'facets', 
                 results: search, 
                 enable_filtering: section.settings.enable_filtering,
                 grid_navigation: section.settings.grid_navigation,
								 grid_style: section.settings.grid_style,
                 filter_type: section.settings.filter_type,
								 filter_size: section.settings.filter_size,
                 enable_sorting: section.settings.enable_sorting, 
                 show_sorting_label: section.settings.show_sorting_label,
                 paginate: paginate,
                 filter_bg: section.settings.filtering_background_color,
                 custom_color: section.settings.enable_custom_color,
                 facets_dropdown_background_color: section.settings.facets_dropdown_background_color 
              %}
            </aside>
          {%- endif -%}
        {%- endif -%}

        <div class="product-grid-container{% if search.results.size == 0 %} grid-empty{% endif %}" id="ProductGridContainer">
          {%- if search.results.size == 0 -%}

            <div class="template-search__results collection collection--empty{% if section.settings.filter_type != 'vertical' %} page-width{% endif %}" id="product-grid" data-id="{{ section.id }}">
              <div class="loading-overlay gradient {{ section.settings.main_background_color }}"></div>
              <div class="title-wrapper center">
                <h2 class="title title--primary {% if settings.mood_type == 'mood4' %} h3 {% endif %}">
                  {{ 'sections.collection_template.empty_search' | t }}<br>
                  {%- if search.filters != empty -%}
                    {{ 'sections.collection_template.use_fewer_filters_html' | t: link: search_url, class: "underlined-link link" }}
                  {%- endif -%}
                </h2>
              </div>
            </div>
          {%- else -%}

            {%- if section.settings.filter_type == 'vertical' -%}
              <facet-filters-form class="facets facets-vertical-sort page-width small-hide no-js-hidden">
                <form class="facets-vertical-form" id="FacetSortForm">
                  <div class="product-count-vertical" role="status">
                    <h2 class="product-count__text text-body">
                      <span id="ProductCountDesktop">
                        {%- if search.results_count -%}
                          {{ 'templates.search.results_with_count' | t: terms: search.terms, count: search.results_count }}
                        {%- elsif search.products_count == search.all_products_count -%}
                          {{ 'products.facets.product_count_simple' | t: count: search.products_count }}
                        {%- else -%}
                          {{ 'products.facets.product_count' | t: product_count: search.products_count, count: search.all_products_count }}
                        {%- endif -%}
                      </span>
                    </h2>
                    <div class="loading-overlay__spinner">
                      <svg aria-hidden="true" focusable="false" class="spinner" viewBox="0 0 66 66" xmlns="http://www.w3.org/2000/svg">
                        <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
                      </svg>
                    </div>
                  </div>
                  {%- if section.settings.enable_sorting and search.filters != empty -%}
                    <div class="facet-filters sorting caption">
                      <div class="facet-filters__field">
                        {% if section.settings.show_sorting_label %}
                          <h2 class="facet-filters__label caption-large text-body">
                            <label for="SortBy">{{ 'products.facets.sort_by_label' | t }}</label>
                          </h2>
                        {% endif %}
                        <div class="select">
                          {%- assign sort_by = search.sort_by | default: search.default_sort_by -%}
                          <select name="sort_by" class="facet-filters__sort select__select caption-large" id="SortBy" aria-describedby="a11y-refresh-page-message">
                            {%- for option in search.sort_options -%}
                              <option value="{{ option.value | escape }}"{% if option.value == sort_by %} selected="selected"{% endif %}>{{ option.name | escape }}</option>
                            {%- endfor -%}
                          </select>
                          {% render 'icon-caret' %}
                        </div>
                      </div>
                      <noscript>
                        <button type="submit" class="facets__button-no-js button">{{ 'products.facets.sort_button' | t }}</button>
                      </noscript>
                    </div>
                  {%- endif -%}
                </form>
              </facet-filters-form>
            {%- endif -%}

            <div class="template-search__results collection{% if section.settings.filter_type != 'vertical' %} page-width{% endif %}">

              <div class="loading-overlay gradient {{ section.settings.main_background_color }}"></div>

              <ul class="grid product-grid grid--{{ section.settings.columns_mobile }}-col-tablet-down grid--{{ section.settings.columns_desktop }}-col-desktop grid-style-{{ section.settings.grid_style }}" id="product-grid" data-id="{{ section.id }}" role="list">
                {%- for item in search.results -%}
                  {% assign lazy_load = false %}
                  {%- if forloop.index > 2 -%}
                    {%- assign lazy_load = true -%}
                  {%- endif -%}

                  <li class="grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                    {% if settings.animations_reveal_on_scroll %}
                      data-cascade style="--animation-order: {{ forloop.index }};"
                    {% endif %}>
                    {%- case item.object_type -%}

                      {%- when 'product' -%}
                        {%- capture product_settings -%}{%- if section.settings.product_show_vendor -%}vendor,{%- endif -%}title,price{%- endcapture -%}

												{%- assign placeholder_image = 'product-1' -%}
                        {% render 'card-product',
                          card_product: item,
                          media_aspect_ratio: section.settings.image_ratio,
                          show_secondary_image: section.settings.show_secondary_image,
                          show_vendor: section.settings.show_vendor,
                          show_rating: section.settings.show_rating,
                          show_quick_add: settings.enable_quick_add,
                          lazy_load: lazy_load
													placeholder_image: placeholder_image
                        %}

                      {%- when 'article' -%}
                        {% render 'article-card',
                          article: item,
                          show_image: true,
                          show_date: section.settings.article_show_date,
                          show_author: section.settings.article_show_author,
                          show_comments: section.settings.article_show_comments,
                          author_prefix: section.settings.author_prefix,
                          show_badge: section.settings.show_badge,
                          media_aspect_ratio: article_image_ratio,
                          lazy_load: lazy_load,
						  						show_badge_bottom: false

                        %}
                        
                      {%- when 'page' -%}
                        <div class="article-card-wrapper page card-wrapper">
                          <div class="card card--card card--text ratio" style="--ratio-percent: 100%;">
                            <div class="card__content">
                              <div class="card__information">
                                <h3 class="card__heading {% if settings.mood_type == 'mood4' %} h5 {% elsif settings.mood_type == 'mood5' %} h4 {% endif %}">
                                  <a href="{{ item.url }}" class="full-unstyled-link">
                                    {{ item.title | truncate: 50 | escape }}
                                  </a>
                                </h3>
                              </div>
                              
                              <div class="card__badge top left">
                                <span class="badge text-color-{{ settings.sale_text_color }} background--sold-out">
                                  {{ 'templates.search.page' | t }}
                                </span>
                              </div>
                            </div>
                          </div>
                        </div>
                    {%- endcase -%}
                  </li>
                {%- endfor -%}
              </ul>

              {%- if paginate.pages > 1 -%}
                {% render 'pagination', paginate: paginate %}
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

  </div>
{% endpaginate %}

{% schema %}
{
  "name": "t:sections.main-search.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Banner settings"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
		{
          "value": "h4",
          "label": "Extra small"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__3.label"
        }
      ],
      "default": "h2",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "select",
      "id": "text_color",
      "options": [
        {
          "value": "main",
          "label": "t:settings_schema.colors.settings.colors_text.label"
        },
        {
          "value": "secondary",
          "label": "t:settings_schema.colors.settings.colors_secondary_text.label"
        },
        {
          "value": "heading",
          "label": "t:settings_schema.colors.settings.colors_heading.label"
        },
        {
          "value": "heading-secondary",
          "label": "t:settings_schema.colors.settings.colors_secondary_heading.label"
        }
      ],
      "default": "heading-secondary",
      "label": "t:sections.all.colors.label_heading",
      "info": "t:sections.all.colors.has_cards_info"
    },
    {
      "type": "image_picker",
      "id": "overlay_image",
      "label": "Banner left overlay"
    },
    {
      "type": "image_picker",
      "id": "overlay_image_right",
      "label": "Banner right overlay"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "default": true,
      "label": "t:sections.all.padding.full_width"
    },
    {
      "type": "select",
      "id": "background_color",
      "options": [
        {
          "value": "color-main-bg",
          "label": "t:settings_schema.colors.settings.colors_background_main.label"
        },
        {
          "value": "color-bg-1",
          "label": "t:settings_schema.colors.settings.colors_background_section_1.label"
        },
        {
          "value": "color-bg-2",
          "label": "t:settings_schema.colors.settings.colors_background_section_2.label"
        },
        {
          "value": "color-bg-3",
          "label": "t:settings_schema.colors.settings.colors_background_section_3.label"
        },
        {
          "value": "color-bg-4",
          "label": "t:settings_schema.colors.settings.colors_background_section_4.label"
        },
        {
          "value": "color-bg-5",
          "label": "t:settings_schema.colors.settings.colors_background_section_5.label"
        }
      ],
      "default": "color-bg-2",
      "label": "t:settings_schema.colors.settings.background_colors.content",
      "info": "t:sections.all.colors.has_cards_info"
    },
    {
      "type": "color_background",
      "id": "colors_background_section_gradient",
      "label": "t:settings_schema.colors.settings.colors_background_section_gradient.label"
    },
    {
      "type": "range",
      "id": "banner_padding_top",
      "min": 0,
      "max": 180,
      "step": 2,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 60
    },
    {
      "type": "range",
      "id": "banner_padding_bottom",
      "min": 0,
      "max": 180,
      "step": 2,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 60
    },
    {
      "type": "header",
      "content": "Grid settings"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4,
      "label": "t:sections.main-search.settings.columns_desktop.label"
    },
    {
      "type": "select",
      "id": "grid_style",
      "options": [
        {
          "value": "grid",
          "label": "Grid"
        },
        {
          "value": "collage",
          "label": "Collage"
        }
      ],
      "default": "collage",
      "label": "Grid style"
    },
    {
      "type": "checkbox",
      "id": "grid_navigation",
      "default": true,
      "label": "Show grid navigation"
    },
    {
      "type": "header",
      "content": "t:sections.main-search.settings.header__1.content"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:sections.main-search.settings.image_ratio.options__1.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.main-search.settings.image_ratio.options__2.label"
        },
        {
          "value": "tallview",
          "label": "Tall view"
        },
        {
          "value": "square",
          "label": "t:sections.main-search.settings.image_ratio.options__3.label"
        },
        {
          "value": "landscape",
          "label": "Landscape"
        }
      ],
      "default": "portrait",
      "label": "t:sections.main-search.settings.image_ratio.label"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "default": true,
      "label": "t:sections.main-search.settings.show_secondary_image.label"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": false,
      "label": "t:sections.main-search.settings.show_vendor.label"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "default": false,
      "label": "t:sections.main-search.settings.show_rating.label",
      "info": "t:sections.main-search.settings.show_rating.info"
    },
    {
      "type": "header",
      "content": "t:sections.main-search.settings.header__2.content",
      "info": "t:sections.main-search.settings.header__2.info"
    },
    {
      "type": "checkbox",
      "id": "article_show_date",
      "default": true,
      "label": "t:sections.main-search.settings.article_show_date.label"
    },
    {
      "type": "checkbox",
      "id": "article_show_author",
      "default": false,
      "label": "t:sections.main-search.settings.article_show_author.label"
    },
	{
      "type": "checkbox",
      "id": "show_badge",
      "default": true,
      "label": "Show badge"
    },
    {
      "type": "checkbox",
      "id": "article_show_comments",
      "default": false,
      "label": "t:sections.featured-blog.settings.show_comments.label"
    },
    {
      "type": "inline_richtext",
      "id": "author_prefix",
      "label": "Author prefix",
      "default": "By"
    },
    {
      "type": "header",
      "content": "t:sections.main-collection-product-grid.settings.header__1.content"
