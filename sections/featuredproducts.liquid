{%- style -%}
  .featured-collections-wrapper {
    background-color: #f2f0f5;
    padding: 50px 40px;
    font-family: inherit;
  }

  .featured-collections-wrapper .swym-wishlist-collections-v2-container{
    z-index: 2;
  }
  .fc-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 40px;
    flex-wrap: wrap;
    gap: 20px;
  }
  @media (max-width: 900px) {
    .fc-header {
      flex-direction: column;
      align-items: flex-start;
    }
    .featured-collections-wrapper {
      padding: 40px 20px;
    }
  }
  .fc-title-area {
    max-width: 600px;
  }
  @media (max-width: 768px) {
    .fc-title-area {
      text-align: center;
      width: 100%;
      margin: 0 auto;
    }
  }
  .fc-title {
    font-size: 52px;
    font-weight: 700;
    margin: 0 0 10px 0;
    color: #111;
    letter-spacing: 0.5px;
  }
  @media (max-width: 768px) {
    .fc-title {
      font-size: 32px;
    }
  }
  .fc-title .highlight {
    color: #6c4c87; /* purple */
    font-family: 'sag' !important; /* Curly font for highlight */
  }
  .fc-subtitle {
    font-size: 22px;
    color: #606060;
    margin: 0;
    line-height: 1.5;
  }
  @media (max-width: 768px) {
    .fc-subtitle {
      font-size: 16px;
    }
  }
  .fc-tabs {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  @media (max-width: 768px) {
    .fc-tabs {
      flex-wrap: nowrap;
      overflow-x: auto;
      scrollbar-width: none;
      -ms-overflow-style: none;
      padding-bottom: 5px;
      width: 100%;
    }
    .fc-tabs::-webkit-scrollbar {
      display: none;
    }
  }
  .fc-tab-btn {
    border: 1px solid #6e4b7e;
    background: transparent;
    color: #6e4b7e;
    padding: 8px 16px;
    border-radius: 50px;
    font-size: 20px;
    font-weight: 400;
    cursor: pointer;
    transition: all 0.3s;
    white-space: nowrap;
  }
  @media (max-width: 768px) {
    .fc-tab-btn {
      font-size: 16px;
      padding: 6px 14px;
    }
  }
  .fc-tab-btn.active,
  .fc-tab-btn:hover {
    background: rgba(108, 76, 135, 0.08); /* slight fill on hover/active to match image "tubes" which look outlined */
  }

  /* Wrapper and Grid styling for products */
  .fc-slider-wrapper {
    display: none;
  }
  .fc-slider-wrapper.active {
    display: block;
    animation: fadeIn 0.4s ease-in-out;
  }
  .fc-grid-container {
    display: flex;
    flex-wrap: nowrap;
    scroll-snap-type: x mandatory;
    gap: 20px;
    position: relative;
    overflow-x: auto;
    scrollbar-width: none;
    overflow-x: auto;
    scrollbar-width: none !important;
    -ms-overflow-style: none !important;
    -webkit-overflow-scrolling: touch;
    align-items: stretch;
    padding-bottom: 20px;
  }
  .fc-grid-container::-webkit-scrollbar {
    display: none !important;
    width: 0 !important;
    height: 0 !important;
  }


  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 1400px) {
    .fc-grid-container {
      gap: 16px;
    }
  }
  @media (max-width: 1100px) {
    .fc-grid-container {
      gap: 16px;
    }
  }

  .fc-card {
    flex: 0 0 calc((100% - 80px) / 5);
    scroll-snap-align: center;
    flex-shrink: 0;
  }

  @media (max-width: 1400px) {
    .fc-card {
      flex-basis: calc((100% - 48px) / 4);
    }
  }

  @media (max-width: 1100px) {
    .fc-card {
      flex-basis: calc((100% - 32px) / 3);
    }
  }

  @media (max-width: 900px) {
    .fc-card {
      flex-basis: calc((100% - 16px) / 2);
    }
  }

  @media (max-width: 768px) {
    .fc-grid-container {
      gap: 16px;
      padding-bottom: 0px;
    }
    .fc-card {
      flex: 0 0 85%;
    }
  }
  .fc-dots-container {
    display: none;
    justify-content: center;
    align-items: center;
    gap: 8px;
    margin-top: 24px;
  }
  @media (max-width: 768px) {
    .fc-dots-container {
      display: flex;
    }
  }
  .fc-dot {
    width: 8px;
    height: 8px;
    background-color: #d1d1d1;
    border-radius: 50%;
    transition: all 0.3s ease;
    cursor: pointer;
  }
  .fc-dot.active {
    width: 28px;
    border-radius: 10px;
    background-color: #a0a0a0;
  }

  /* Product Card styling matching exactly */
  .fc-card {
    background: #fff;
    border-radius: 20px;
    padding: 0;
    display: flex;
    flex-direction: column;
    position: relative;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    overflow: hidden;
  }

  .fc-card-img-wrap {
    background: #fcfcfc;
    border-radius: 20px 20px 0 0;
    aspect-ratio: 1 / 1;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    margin-bottom: 0;
    overflow: hidden;
  }

  .fc-card-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    display: block;
    box-sizing: border-box;
    mix-blend-mode: multiply; /* Helps white background merge cleanly */
    transition: opacity 0.25s ease;
    z-index: 1;
  }

  .fc-card-img--secondary {
    opacity: 0;
  }

  .fc-card-img-wrap:hover .fc-card-img--secondary {
    opacity: 1;
  }

  .fc-card-img-wrap:hover .fc-card-img--primary {
    opacity: 0;
  }

  .fc-card-img-wrap .placeholder-svg {
    max-width: 100%;
    max-height: 100%;
    z-index: 1;
  }

  .fc-card-bottom {
    padding: 10px;
  }

  .fc-card-badges {
    position: absolute;
    top: 10px;
    left: 10px;
    right: 10px;
    display: flex;
    justify-content: flex-start;
    gap: 8px;
    flex-wrap: wrap;
    align-items: flex-start;
    z-index: 2;
  }
  .badge-main {
    background: #f28eaa;
    color: #fff;
    padding: 4px 10px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
  }
  .badge-main.best-seller {
    background: #6e4b7e;
  }
  .badge-main.top-pick {
    background: #f5c242;
  }
  .badge-main.eco-choice {
    background: #6fb5e5;
  }
  .badge-main.editors-pick {
    background: #42b883;
  }

  .fc-card-category {
    font-size: 12px;
    font-weight: 600;
    color: #f1bb4e; /* Yellow */
    margin-bottom: 8px;
    display: flex;
    gap: 8px;
    align-items: center;
    text-transform: uppercase;
  }
  .fc-card-category span {
    color: #999;
    font-weight: 500;
    text-transform: none;
  }

  .fc-card-title {
    font-size: 22px;
    font-weight: 600;
    color: #111;
    margin: 0 0 10px 0;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    min-height: 40px; /* Aligns items across row */
  }

  .fc-card-reviews {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 1.2rem;
    color: #222;
    font-weight: 700;
    margin-bottom: 12px;
  }
  .fc-card-reviews svg {
    width: 16px;
    height: 16px;
    fill: #f5c242;
  }
  .fc-card-reviews span {
    color: #888;
    font-weight: 500;
  }

  .fc-card-price {
    font-size: 2.2rem;
    font-weight: 800;
    color: #111;
    margin-bottom: 6px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .fc-card-price s {
    font-size: 1.4rem;
    color: #999;
    font-weight: 500;
  }

  .fc-card-buyback {
    font-size: 14px;
    color: #9e86c6; /* Light purple */
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 10px;
    letter-spacing: 0.5px;
  }

  .fc-card-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .fc-card:hover .fc-card-link {
    color: inherit;
  }

  .fc-card form {
    margin-top: auto;
    padding: 0 10px 10px;
  }

  .fc-card-btn {
    display: block;
    width: 100%;
    text-align: center;
    background: #6c4c87;
    color: #fff;
    padding: 14px;
    border-radius: 50px;
    font-weight: 500;
    font-size: 22px;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: background 0.2s;
    margin-top: auto;
  }
  .fc-card-btn:hover {
    background: #503766;
  }

  /* Footer Button */
  .fc-footer {
    text-align: center;
    margin-top: 30px;
  }
  .fc-view-all {
    display: inline-block;
    border: 1px solid #6c4c87;
    color: #6c4c87;
    padding: 12px 40px;
    border-radius: 50px;
    font-size: 22px;
    font-weight: 600;
    text-decoration: none;
    background: transparent;
    transition: background 0.2s;
  }
  @media (max-width: 768px) {
    .fc-view-all {
      font-size: 16px;
      padding: 10px 30px;
      width: 100%;
    }

    .fc-card-btn{
      font-size: 16px;
      padding: 10px;
    }
    .fc-footer{
      margin-top: 5px;
    }
  }
  .fc-view-all:hover {
    background: rgba(108, 76, 135, 0.05);
  }

  /* SVG Icons */
  .placeholder-svg {
    max-width: 100px;
    max-height: 100px;
    fill: #ccc;
  }

  .fc-empty-state {
    background: #fff;
    border-radius: 16px;
    padding: 16px;
    color: #666;
    font-size: 16px;
  }

  .fc-app-blocks {
    margin-top: 20px;
  }
{%- endstyle -%}

<div class="featured-collections-wrapper" id="FC-{{ section.id }}">
  {% assign has_collection_tabs = false %}
  {% assign first_collection_url = routes.all_products_collection_url %}

  <div class="fc-header">
    <div class="fc-title-area">
      <h2 class="fc-title">
        {{ section.settings.heading }}
        <span class="highlight">{{ section.settings.highlight_text }}</span>
        {{ section.settings.heading_suffix }}
      </h2>
      <p class="fc-subtitle">{{ section.settings.description }}</p>
    </div>

    <div class="fc-tabs">
      {% assign collection_tab_index = 0 %}
      {% assign first_collection_tab_rendered = false %}
      {% for block in section.blocks %}
        {% if block.type == 'collection' %}
          {% assign collection = collections[block.settings.collection] %}
          {% if collection != blank %}
            {% assign collection_tab_index = collection_tab_index | plus: 1 %}
            {% assign has_collection_tabs = true %}
            {% if first_collection_tab_rendered == false %}
              {% assign first_collection_url = collection.url %}
            {% endif %}

            <button
              class="fc-tab-btn {% if first_collection_tab_rendered == false %}active{% endif %}"
              data-target="FC-wrapper-{{ block.id }}"
              data-collection-url="{{ collection.url }}"
            >
              {% if collection.title != blank %}
                {{ collection.title }}
              {% else %}
                Collection {{ collection_tab_index }}
              {% endif %}
            </button>

            {% if first_collection_tab_rendered == false %}
              {% assign first_collection_tab_rendered = true %}
            {% endif %}
          {% endif %}
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <div class="fc-grids">
    {% assign first_collection_wrapper_rendered = false %}
    {% for block in section.blocks %}
      {% if block.type == 'collection' %}
        {% assign collection = collections[block.settings.collection] %}
        {% if collection != blank %}
          <div
            class="fc-slider-wrapper {% if first_collection_wrapper_rendered == false %}active{% endif %}"
            id="FC-wrapper-{{ block.id }}"
            {{ block.shopify_attributes }}
          >
            <div class="fc-grid-container" id="FC-grid-{{ block.id }}">
              {% if collection.products.size > 0 %}
                {% for product in collection.products limit: 5 %}
                  {% assign product_url = product.url | within: collection %}
                  {% assign current_variant = product.selected_or_first_available_variant %}
                  {% assign secondary_image = blank %}
                  {% if product.images.size > 1 %}
                    {% assign secondary_image = product.images[1] %}
                  {% endif %}
                  <div class="fc-card">
                    <a href="{{ product_url }}" class="fc-card-link" aria-label="{{ product.title | escape }}">
                      <div class="fc-card-img-wrap">
                        {% if product.metafields.custom.tags != blank %}
                          <div class="fc-card-badges">
                            {% assign badges_shown = 0 %}
                            {% if product.metafields.custom.tags.type contains 'list.' %}
                              {% assign badge_items = product.metafields.custom.tags.value %}
                              {% for badge_item in badge_items %}
                                {% if badges_shown < 2 %}
                                  {% assign badge_text = badge_item.label | default: badge_item.name | default: badge_item.title | default: badge_item.value | default: badge_item | strip %}
                                  {% if badge_text != blank %}
                                    {% assign badge_class = 'badge-main' %}
                                    {% assign badge_key = badge_text | downcase | replace: '-', ' ' %}
                                    {% if badge_key contains 'best seller' %}
                                      {% assign badge_class = 'badge-main best-seller' %}
                                    {% elsif badge_key contains 'top pick' %}
                                      {% assign badge_class = 'badge-main top-pick' %}
                                    {% elsif badge_key contains 'eco' %}
                                      {% assign badge_class = 'badge-main eco-choice' %}
                                    {% elsif badge_key contains 'editor' %}
                                      {% assign badge_class = 'badge-main editors-pick' %}
                                    {% endif %}
                                    <span class="{{ badge_class }}">{{ badge_text }}</span>
                                    {% assign badges_shown = badges_shown | plus: 1 %}
                                  {% endif %}
                                {% endif %}
                              {% endfor %}
                            {% else %}
                              {% assign badge_items = product.metafields.custom.tags.value | default: product.metafields.custom.tags | split: ',' %}
                              {% for badge_item in badge_items limit: 2 %}
                                {% assign badge_text = badge_item | strip %}
                                {% if badge_text != blank %}
                                  {% assign badge_class = 'badge-main' %}
                                  {% assign badge_key = badge_text | downcase | replace: '-', ' ' %}
                                  {% if badge_key contains 'best seller' %}
                                    {% assign badge_class = 'badge-main best-seller' %}
                                  {% elsif badge_key contains 'top pick' %}
                                    {% assign badge_class = 'badge-main top-pick' %}
                                  {% elsif badge_key contains 'eco' %}
                                    {% assign badge_class = 'badge-main eco-choice' %}
                                  {% elsif badge_key contains 'editor' %}
                                    {% assign badge_class = 'badge-main editors-pick' %}
                                  {% endif %}
                                  <span class="{{ badge_class }}">{{ badge_text }}</span>
                                {% endif %}
                              {% endfor %}
                            {% endif %}
                          </div>
                        {% endif %}

                        {% if product.featured_image %}
                          <img
                            class="fc-card-img fc-card-img--primary"
                            src="{{ product.featured_image | image_url: width: 400 }}"
                            alt="{{ product.title | escape }}"
                            loading="lazy"
                            width="{{ product.featured_image.width }}"
                            height="{{ product.featured_image.height }}"
                          >

                          {% if secondary_image != blank %}
                            <img
                              class="fc-card-img fc-card-img--secondary"
                              src="{{ secondary_image | image_url: width: 400 }}"
                              alt="{{ product.title | escape }}"
                              loading="lazy"
                              width="{{ secondary_image.width }}"
                              height="{{ secondary_image.height }}"
                            >
                          {% endif %}
                        {% else %}
                          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                        {% endif %}
                      </div>

                      {% assign card_primary = product.type | default: product.vendor %}
                      {% assign card_secondary = blank %}
                      {% if product.type != blank and product.vendor != blank and product.vendor != product.type %}
                        {% assign card_secondary = product.vendor %}
                      {% endif %}

                      {% assign variant_price = current_variant.price | default: product.price %}
                      {% assign variant_compare = current_variant.compare_at_price | default: product.compare_at_price %}

                      <div class="fc-card-bottom">
                        {% if card_primary != blank %}
                          <div class="fc-card-category">
                            {{ card_primary }}
                            {% if card_secondary != blank %}
                              <span>{{ card_secondary }}</span>
                            {% endif %}
                          </div>
                        {% endif %}

                        <h3 class="fc-card-title">{{ product.title }}</h3>

                        {% if product.metafields.reviews.rating.value != blank %}
                          {% assign card_rating = product.metafields.reviews.rating.value.rating | default: product.metafields.reviews.rating.value %}
                          {% assign card_rating_count = product.metafields.reviews.rating_count.value | default: product.metafields.reviews.rating_count | default: 0 %}
                          <div class="fc-card-reviews">
                            <svg viewBox="0 0 24 24">
                              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path>
                            </svg>
                            {{ card_rating | round: 1 }} <span>({{ card_rating_count }} Reviews)</span>
                          </div>
                        {% endif %}

                        <div class="fc-card-price">
                          {{ variant_price | money }}
                          {% if variant_compare > variant_price %}
                            <s>{{ variant_compare | money }}</s>
                          {% endif %}
                        </div>

                        {% assign bb = variant_price | times: 60 | divided_by: 100 %}
                        <div class="fc-card-buyback">You’ll get {{ bb | money }} back when you’re done </div>
                      </div>
                    </a>

                    {% if current_variant != blank %}
                      <form method="post" action="{{ routes.cart_add_url }}">
                        <input type="hidden" name="id" value="{{ current_variant.id }}">
                        <button type="submit" class="fc-card-btn" {% unless current_variant.available %}disabled{% endunless %}>
                          {% if current_variant.available %}
                            Add to Cart
                          {% else %}
                            Sold Out
                          {% endif %}
                        </button>
                      </form>
                    {% endif %}
                  </div>
                {% endfor %}
              {% else %}
                <p class="fc-empty-state">No products found in this collection.</p>
              {% endif %}
            </div>
            <div class="fc-dots-container" id="FC-dots-{{ block.id }}"></div>
          </div>
          {% if first_collection_wrapper_rendered == false %}
            {% assign first_collection_wrapper_rendered = true %}
          {% endif %}
        {% endif %}
      {% endif %}
    {% endfor %}

    {% unless has_collection_tabs %}
      <p class="fc-empty-state">No collection selected yet.</p>
    {% endunless %}
  </div>

  {% for block in section.blocks %}
    {% if block.type == '@app' %}
      <div class="fc-app-blocks" {{ block.shopify_attributes }}>
        {% render block %}
      </div>
    {% endif %}
  {% endfor %}

  <div class="fc-footer">
    <a href="{{ first_collection_url }}" class="fc-view-all" id="FC-view-all-{{ section.id }}">{{ section.settings.view_all_text }}</a>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const root = document.getElementById('FC-{{ section.id }}');
    if (!root) return;

    const tabs = root.querySelectorAll('.fc-tab-btn[data-target]');
    const wrappers = root.querySelectorAll('.fc-slider-wrapper');
    const viewAllButton = root.querySelector('.fc-view-all');

    const syncViewAllHref = (tab) => {
      if (!viewAllButton || !tab) return;
      const collectionUrl = tab.getAttribute('data-collection-url');
      if (collectionUrl) {
        viewAllButton.setAttribute('href', collectionUrl);
      }
    };

    tabs.forEach((tab) => {
      tab.addEventListener('click', function (e) {
        e.preventDefault();

        tabs.forEach((t) => t.classList.remove('active'));
        this.classList.add('active');
        syncViewAllHref(this);

        wrappers.forEach((w) => w.classList.remove('active'));

        const targetId = this.getAttribute('data-target');
        if (targetId) {
          const targetWrapper = document.getElementById(targetId);
          if (targetWrapper) {
            targetWrapper.classList.add('active');
            // Re-trigger scroll to force dot sync for newly visible flex container
            const targetGrid = targetWrapper.querySelector('.fc-grid-container');
            if (targetGrid) {
              targetGrid.dispatchEvent(new Event('scroll'));
            }
          }
        }
      });
    });

    const activeTab = root.querySelector('.fc-tab-btn.active');
    if (activeTab) {
      syncViewAllHref(activeTab);
    }

    // Mobile Carousel Dot logic - runs for all wrappers
    wrappers.forEach((wrapper) => {
      const grid = wrapper.querySelector('.fc-grid-container');
      const dotsContainer = wrapper.querySelector('.fc-dots-container');
      if (!grid || !dotsContainer) return;

      const cards = grid.querySelectorAll('.fc-card');
      if (cards.length === 0) return;

      // Always clear first to avoid duplicates on re-render
      dotsContainer.innerHTML = '';

      // Build one dot per card
      cards.forEach((_, idx) => {
        const dot = document.createElement('div');
        dot.className = 'fc-dot' + (idx === 0 ? ' active' : '');
        dot.dataset.index = idx;
        dotsContainer.appendChild(dot);
      });

      const dots = dotsContainer.querySelectorAll('.fc-dot');

      const setActiveDot = (index) => {
        dots.forEach((dot, i) => dot.classList.toggle('active', i === index));
      };

      const updateActiveDot = () => {
        const gridCenter = grid.scrollLeft + grid.clientWidth / 2;
        let closestIndex = 0;
        let minDist = Infinity;
        cards.forEach((card, index) => {
          const cardCenter = card.offsetLeft + card.offsetWidth / 2;
          const dist = Math.abs(gridCenter - cardCenter);
          if (dist < minDist) {
            minDist = dist;
            closestIndex = index;
          }
        });
        setActiveDot(closestIndex);
      };

      grid.addEventListener('scroll', updateActiveDot, { passive: true });
      window.addEventListener('resize', updateActiveDot, { passive: true });

      // Dot click scrolls to that card
      dots.forEach((dot, index) => {
        dot.addEventListener('click', () => {
          const card = cards[index];
          if (card) {
            const left = card.offsetLeft - (grid.clientWidth - card.offsetWidth) / 2;
            grid.scrollTo({ left: Math.max(0, left), behavior: 'smooth' });
          }
        });
      });

      // Init first dot as active right away
      setActiveDot(0);
    });
  });
</script>

{% schema %}
{
  "name": "ucts Tabs",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading Part 1",
      "default": "Our "
    },
    {
      "type": "text",
      "id": "highlight_text",
      "label": "Highlighted Word",
      "default": "Top"
    },
    {
      "type": "text",
      "id": "heading_suffix",
      "label": "Heading Part 2",
      "default": " Picks"
    },
