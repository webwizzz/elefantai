{{ 'section-collection-list.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}

{%- style -%}
	#shopify-section-{{ section.id }} {
		--padding-top: {{ section.settings.padding_top }}px;
		--padding-bottom: {{ section.settings.padding_bottom }}px;

		{% if section.settings.enable_border_radius %}
			--custom-card-radius: {{ section.settings.border_radius }}px;
		{% endif %}
	}

	{% if section.settings.colors_background_section_gradient != blank %}
    #shopify-section-{{ section.id }} .section-responsive-padding {
      background: {{ section.settings.colors_background_section_gradient }};
    }
  {% endif %}
  
{%- endstyle -%}

{%- liquid
  assign columns_mobile_int = section.settings.columns_mobile | plus: 0
  assign show_mobile_slider = false
  if section.settings.swipe_on_mobile and section.blocks.size > columns_mobile_int
    assign show_mobile_slider = true
  endif

  if section.settings.image_overlay != blank or section.settings.image_overlay_2 != blank or section.settings.image_overlay_3 != blank or section.settings.shape_type != 'none'
    assign section_overlay = true
  endif
-%}


<div class="gradient section-responsive-padding {{ section.settings.background_color }}{% if section_overlay == true %} section-overlay{% endif %}">

  {%- if section.settings.image_overlay != blank or section.settings.image_overlay_2 != blank or section.settings.image_overlay_3 != blank -%}
    {% render 'section-overlay' %}
  {%- endif -%}

  {%- if section.settings.shape_type != 'none' -%}
    {% render 'shape',
      position: section.settings.shape_position, 
      type: section.settings.shape_type, 
      color: section.settings.shape_color,
      width: section.settings.shape_width
    %}
  {%- endif -%}

  <div class="collection-list-wrapper {% if section.settings.full_width == false %} page-width {% endif %} isolate{% if show_mobile_slider and section.settings.full_width  == false %} page-width-desktop{% endif %}{% if section.settings.title == blank %} no-heading{% endif %}{% if section.settings.show_view_all == false or section.blocks.size > collections.size %} no-mobile-link{% endif %}">

    {%- if section.settings.title != blank -%}
			{%- if section.settings.full_width -%}
				<div class="page-width">
			{%- endif -%}

      <div class="title-wrapper-with-link {{ section.settings.heading_align }} {{ section.settings.text_bottom_space }} {% if show_mobile_slider %} title-wrapper--self-padded-tablet-down{% else %} title-wrapper--self-padded-mobile{% endif %}">

        <h2 class="title inline-richtext {{ section.settings.heading_size }} text-color-{{ section.settings.heading_color }} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          {{ section.settings.title }}
        </h2>

        {%- if section.settings.show_view_all and section.blocks.size < collections.size and show_mobile_slider -%}
          <a href="{{ routes.collections_url }}" id="ViewAll-{{ section.id }}" class="link underlined-link large-up-hide{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %} {%- if settings.mood_type == 'mood6' -%} link-with-icon{% endif %}" aria-labelledby="ViewAll-{{ section.id }} SectionHeading-{{ section.id }}">
            {{- 'sections.collection_list.view_all' | t -}} 
            {%- if settings.mood_type == 'mood6' -%}
              {% render 'icon-arrow-mood6' %}
            {%- endif -%}
          </a>
        {%- endif -%}
      </div>

			{%- if section.settings.full_width -%}
				</div>
			{%- endif -%}
    {%- endif -%}

    <slider-component class="slider-mobile-gutter{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      <ul class="collection-list contains-card contains-card--collection{% if settings.card_style == 'standard' %} contains-card--standard{% endif %} grid grid--{{ section.settings.columns_desktop }}-col-desktop grid--{{ section.settings.columns_mobile }}-col-tablet-down{% if section.settings.swipe_on_mobile %} slider slider--tablet grid--peek{% endif %} collection-list--{{ section.blocks.size }}-items" id="Slider-{{ section.id }}" role="list">

        {%- liquid
          assign columns = section.blocks.size
          if columns > 3
            assign columns = 3
          endif
        -%}

        {%- for block in section.blocks -%}

          <li id="Slide-{{ section.id }}-{{ forloop.index }}" class="collection-list__item grid__item{% if show_mobile_slider %} slider__slide{% endif %}{% if block.settings.collection.featured_image == nil %} collection-list__item--no-media{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" {{ block.shopify_attributes }} {% if settings.animations_reveal_on_scroll %} data-cascade style="--animation-order: {{ forloop.index }};" {% endif %}>						
						{% if block.settings.background != blank or block.settings.icon != blank %}
							{%- style -%}
								#Slide-{{ section.id }}-{{ forloop.index }} {
									{% if block.settings.background != blank and block.settings.background != 'rgba(0,0,0,0)' %}
										--bg-clr: {{ block.settings.background }};
									{% endif %}
									{% if block.settings.icon != blank %}
										--mc-icon-width: {{ block.settings.icon_width }}%;
										--mc-icon-width-mb: {{ block.settings.icon_width_mobile }}%;
										--mc-icon-top: {{ block.settings.icon_vertical }}%;
										--mc-icon-top-mb: {{ block.settings.icon_vertical_mobile }}%;
										--mc-icon-left: {{ block.settings.icon_horizontal }}%;
										--mc-icon-left-mb: {{ block.settings.icon_horizontal_mobile }}%;
									{% endif %}
								}
							{%- endstyle -%}
						{% endif %}

						{% if block.settings.icon != blank %}
							{% liquid
								assign classes = 'block-image-overlay'
							%}
							
							{%- assign widths = '198, 230' -%}
	
							{%- capture sizes -%}
								(min-width: {{ settings.page_width }}px) 100vw,
								(min-width: 750px) calc(100vw - 130px), calc(100vw - 50px)
							{%- endcapture -%}
						
							{{
								block.settings.icon
								| image_url: width: 230
								| image_tag: loading: 'lazy', sizes: sizes, widths: widths, class: classes, alt: 'background shape'
							}}
						{% endif %}

            {% render 'card-collection',
              card_collection: block.settings.collection,
							layout: block.settings.layout,
              media_aspect_ratio: section.settings.image_ratio,
							collection_heading_size: section.settings.collection_heading_size,
							collection_heading_weight: section.settings.collection_heading_weight,
              collection_text_color: section.settings.collection_text_color,
							bg_color: block.settings.background,
              columns: columns
            %}

          </li>
        {%- endfor -%}
      </ul>
      {%- if show_mobile_slider -%}
        <div class="slider-buttons no-js-hidden">
          <button type="button" class="slider-button slider-button--prev" name="previous" aria-label="{{ 'general.slider.previous_slide' | t }}">
            {% render 'icon-caret' %}
          </button>

          <div class="slider-counter caption">
            <span class="slider-counter--current">1</span>
            <span aria-hidden="true"> / </span>
            <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
            <span class="slider-counter--total">{{ section.blocks.size }}</span>
          </div>

          <button type="button" class="slider-button slider-button--next" name="next" aria-label="{{ 'general.slider.next_slide' | t }}">
            {% render 'icon-caret' %}
          </button>

        </div>
      {%- endif -%}
    </slider-component>

    {%- if section.settings.show_view_all and section.blocks.size < collections.size -%}
      <div class="center {{ section.settings.top_space }} collection-list-view-all{% if show_mobile_slider %} small-hide medium-hide{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" {% if settings.animations_reveal_on_scroll %} data-cascade{% endif %}>

        <a href="{{ routes.collections_url }}" class="button" id="ViewAllButton-{{ section.id }}" aria-labelledby="ViewAllButton-{{ section.id }} SectionHeading-{{ section.id }}">
          {{- 'sections.collection_list.view_all' | t -}}
        </a>

      </div>
    {%- endif -%}
  </div>

</div>

{% schema %}
