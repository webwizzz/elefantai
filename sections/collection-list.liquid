				},
				{
					"value": "400",
					"label": "t:sections.all.heading_weight.options__2.label"
				},
				{
					"value": "500",
					"label": "t:sections.all.heading_weight.options__3.label"
				},
				{
					"value": "600",
					"label": "t:sections.all.heading_weight.options__4.label"
				},
				{
					"value": "700",
					"label": "t:sections.all.heading_weight.options__5.label"
				},
				{
					"value": "800",
					"label": "t:sections.all.heading_weight.options__6.label"
				}
			],
			"default": "700",
			"label": "Heading weight"
		},
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 3,
      "label": "t:sections.collection-list.settings.columns_desktop.label"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "default": false,
      "label": "t:sections.collection-list.settings.show_view_all.label"
    },
		{
			"type": "select",
			"id": "top_space",
			"options": [
				{
					"value": "",
					"label": "Small"
				},
				{
					"value": "mt-lg-6",
					"label": "Large"
				}
			],
			"default": "",
			"label": "Button top space desktop"
		},
		{
			"type": "checkbox",
			"id": "enable_border_radius",
			"label": "Enable custom border radius"
		},
		{
			"type": "range",
			"id": "border_radius",
			"min": 0,
			"max": 300,
			"step": 5,
			"unit": "px",
			"label": "Border radius",
			"default": 100
		},	
    {
      "type": "header",
      "content": "t:sections.collection-list.settings.header_mobile.content"
    },
    {
