{{ 'section-testimonials.css' | asset_url | stylesheet_tag }}
{{ 'swiper.css' | asset_url | stylesheet_tag }}

{%- style -%}
	#shopify-section-{{ section.id }} {
		--padding-top: {{ section.settings.padding_top }}px;
		--padding-bottom: {{ section.settings.padding_bottom }}px;

		--arrows-clr: {{ section.settings.arrows_btn_color.red }}, {{ section.settings.arrows_btn_color.green }}, {{ section.settings.arrows_btn_color.blue }};
		--arrows-clr-hover: {{ section.settings.arrows_btn_color_hover.red }}, {{ section.settings.arrows_btn_color_hover.green }}, {{ section.settings.arrows_btn_color_hover.blue }};
		--arrows-bg: {{ section.settings.arrows_btn_bg_color.red }}, {{ section.settings.arrows_btn_bg_color.green }}, {{ section.settings.arrows_btn_bg_color.blue }};
		--arrows-bg-hover: {{ section.settings.arrows_btn_bg_color_hover.red }}, {{ section.settings.arrows_btn_bg_color_hover.green }}, {{ section.settings.arrows_btn_bg_color_hover.blue }} ;
	}

	{% if section.settings.colors_background_section_gradient != blank %}
    #shopify-section-{{ section.id }} .testimonials.gradient {
      background: {{ section.settings.colors_background_section_gradient }};
    }
  {% endif %}

  {% if section.settings.side_item_bg_enable %}  
    #shopify-section-{{ section.id }} .side-active {
      background-color: {{ section.settings.side_item_bg }};
    }
  {% endif %}

  {% if section.settings.slide_item_bg_enable %}  
    #shopify-section-{{ section.id }} .swiper-slide {
      background-color: {{ section.settings.slide_item_bg }};
    }
  {% endif %}

  {% if section.settings.text != blank %}
		#shopify-section-{{ section.id }} a:has(.replace-color) {
			color: {{ section.settings.text_color_2 }};
		}
  {% endif %}

{%- endstyle -%}

{%- liquid
  if section.settings.image_overlay != blank or section.settings.image_overlay_2 != blank or section.settings.image_overlay_3 != blank or section.settings.shape_type != 'none'
    assign section_overlay = true
  endif
-%}

<div class="testimonials align-{{ section.settings.heading_alignment }} gradient section-responsive-padding {% if section.settings.heading == blank %} no-heading{% endif %} {{ section.settings.background_color }}{% if section_overlay == true %} section-overlay{% endif %}">

  {%- if section.settings.image_overlay != blank or section.settings.image_overlay_2 != blank or section.settings.image_overlay_3 != blank -%}
    {% render 'section-overlay' %}
  {%- endif -%}

  {%- if section.settings.shape_type != 'none' -%}
    {% render 'shape',
      position: section.settings.shape_position, 
      type: section.settings.shape_type, 
      color: section.settings.shape_color,
      width: section.settings.shape_width
    %}
  {%- endif -%}
  
  {% if section.settings.heading != blank or section.settings.show_btns%}
    <div class="testimonials-wrap page-width isolate {{ section.settings.text_bottom_space }}">
      {%- if section.settings.heading != blank -%}
        <h2 class="testimonials__title inline-richtext {{ section.settings.heading_size }} text-color-{{ section.settings.text_color }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-rotate-in{% endif %}">
          {% if section.settings.text_heading != blank %}
            {% assign word_list = section.settings.text_heading | split: ', ' %}
            {% assign text_to_replace = section.settings.heading | split: '' %}
            {% assign content = '' %}
            {% assign result = '' %}
            {% assign inside_tag = false %}

            {% for char in text_to_replace %}
              {% if inside_tag %}
                {% if char == '>' %}
                  {% assign inside_tag = false %}
                {% endif %}
                {% assign result = result | append: char %}
              {% else %}
                {% if char == '<' or forloop.last %}
                  {% assign inside_tag = true %}
                  {% if forloop.last %}
                    {% assign content = content | append: char %}
                  {% endif %}
                  {% for word in word_list %}
                    {% assign replace_text = '<<<' | append: section.settings.text_color_2 | append: '">' | append: word | append: '>>>' %}
                    {% assign content = content | replace: word, replace_text %}
                  {% endfor %}

                  {% assign content = content | replace: '<<<', '<span class="replace-color" style="color:' %}
                  {% assign content = content | replace: '>>>', '</span>' %}
                  {% assign result = result | append: content %}
                  {% assign content = '' %}
                  {% if forloop.last != true %}
                    {% assign result = result | append: char %}
                  {% endif %}
                {% else %}
                  {% assign content = content | append: char %}
                {% endif %}
              {% endif %}

            {% endfor %}
      
            {{ result }}
          {% else %}
            {{ section.settings.heading }}
          {% endif %}  
        </h2>
      {%- endif -%}
      
      {% if section.blocks.size > 1 and section.settings.show_btns %}
        <div class="slider-navigation small-hide">
          <div class="slider-arrow slider-arrow-prev {% if section.settings.arrows_outline %} slider-arrow--transparent {% endif %}" tabindex="0" role="button" aria-label="Previous slide"> 
            {% if  settings.mood_type == 'kawai' %}
              {% render 'icon-arrow-red' %}
            {% else %}
              {% render 'icon-arrow-slider' %}
            {% endif %}
          </div>

          <div class="slider-arrow slider-arrow-next {% if section.settings.arrows_outline %} slider-arrow--transparent {% endif %}" tabindex="0" role="button" aria-label="Next slide">
            {% if  settings.mood_type == 'kawai' %}
              {% render 'icon-arrow-red' %}
            {% else %}
              {% render 'icon-arrow-slider' %}
            {% endif %}
          </div>
        </div>
      {% endif %}
    </div>
  {% endif %}

	<div class="testimonials__slider-wrapper page-width {% if section.settings.full_width == true %} page-width--desktop-full {% endif %}">

    {% if section.settings.columns_desktop <= 1 %} 
      <div class="side-block-items {% if settings.animations_reveal_on_scroll %}scroll-trigger animate--slide-in{% endif %}">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'side_block'%}
              <h4 class="side-block-item {{ block.settings.side_category | downcase }} {{ block.settings.side_block_background_color }} skew-{{ block.settings.skew_block }} {{ block.settings.text_align }}" {{ block.shopify_attributes }} data-side-category="{{ block.settings.side_category | downcase }}">
                {{ block.settings.side_block_text }}
              </h4>
          {% endcase %}
        {% endfor %}
      </div>
    {% endif %}

    <div class="testimonials__slider-box {% if section.settings.columns_desktop <= 1 %}desktop-display-one-slide{% endif %}">
      {% if section.blocks.size > 1 and section.settings.show_btns_in_slider %}
        <div class="slider-arrow slider-arrow-prev small-hide {% if section.settings.arrows_outline %} slider-arrow--transparent {% endif %} {% if settings.mood_type == 'mood5' %}button{% endif %}" tabindex="0" aria-label="Previous slide" role="button">
          {% if  settings.mood_type == 'kawai' %}
            {% render 'icon-arrow-red' %}
          {% else %}
            {% render 'icon-arrow-slider' %}
          {% endif %}
        </div>
      {% endif %}

      <div class="swiper testimonials-slider-{{ section.id }} testimonials-slider" data-section-id="{{ section.id }}" data-columns-desktop="{{ section.settings.columns_desktop }}" data-centered-slides="{{ section.settings.center_slide }}" data-slider-init="{% if section.blocks.size > 1 %}true{% else %}false{% endif %}">
        <div class="swiper-wrapper grid--{{ section.settings.columns_desktop }}-col">

          {%- for block in section.blocks -%}
            {% case block.type %}

              {% when "testimonial" %}
                {% if block.settings.enable_border_radius or block.settings.icon != blank %}
                  {%- style -%}
                    #Slide-{{ section.id }}-{{ forloop.index }} {
                      {% if block.settings.enable_border_radius %}
                        --custom-radius: {{ block.settings.border_radius }}%;
                      {% endif %}
                      {% if block.settings.icon != blank %}
                        --mc-icon-width: {{ block.settings.icon_width }}%;
                        --mc-icon-width-mb: {{ block.settings.icon_width_mobile }}%;
                        --mc-icon-top: {{ block.settings.icon_vertical }}%;
                        --mc-icon-top-mb: {{ block.settings.icon_vertical_mobile }}%;
                        --mc-icon-left: {{ block.settings.icon_horizontal }}%;
                        --mc-icon-left-mb: {{ block.settings.icon_horizontal_mobile }}%;
                      {% endif %}
                    }
                  {%- endstyle -%}
                {% endif %}

                <div id="Slide-{{ section.id }}-{{ forloop.index }}" class="swiper-slide {{ block.settings.testimonial_category | downcase }} slide-{{ forloop.index }}{% if section.blocks.size < 2 %} swiper-slide-active{% endif %}" data-testimonial-category="{{ block.settings.testimonial_category | downcase }}">

                  <div class="testimonial-item {{ block.settings.content_alignment }} {% if section.settings.testimonial_background != 'rgba(0,0,0,0)' and section.settings.center_slide %} bg {% endif %}" {% if section.settings.center_slide %} {% if section.blocks.size < 2 %}style="background-color: {{ section.settings.testimonial_background }};" {% else %}style="--active-background: {{ section.settings.testimonial_background }};"{% endif %} {% endif %} {{ block.shopify_attributes }}>

                    {%- if block.settings.image != blank -%}
                      <div class="testimonial-item__image-wrapper">
                        {% if block.settings.icon != blank %}
                          {% liquid
                            assign classes = 'block-image-overlay'
                            assign widths = '198, 230'
                          %}
                          {%- capture sizes -%}
                            (min-width: {{ settings.page_width }}px) 100vw,
                            (min-width: 750px) calc(100vw - 130px), calc(100vw - 50px)
                          {%- endcapture -%}

                          {{
                            block.settings.icon
                            | image_url: width: 230, format: 'webp' 
                            | image_tag: loading: 'lazy', sizes: sizes, widths: widths, class: classes, alt: 'background shape'
                          }}
                        {% endif %}

                        {% if  block.settings.image_ratio != 'small' %}
                          <div class="media media--transparent media--{{ block.settings.image_ratio }}" {% if block.settings.image_ratio == 'adapt' %}style="padding-bottom: {{ 1 | divided_by: block.settings.image.aspect_ratio | times: 100 }}%;"{% endif %} >
                            {%- liquid
                              assign number_of_columns = section.settings.columns_desktop
                              assign number_of_columns_mobile = 1
                            -%}
                            {% capture sizes %}
                              (min-width: {{ settings.page_width }}px) calc({{ settings.page_width }}px /  {{ number_of_columns }}),
                              (min-width: 990px) calc(100vw * / {{ number_of_columns }}),
                              (min-width: 750px) calc(100vw * / {{ number_of_columns_mobile }}),
                              calc(100vw / {{ number_of_columns_mobile }})
                            {% endcapture %}
                            {{
                              block.settings.image
                              | image_url: width: 600, format: 'webp' 
                              | image_tag:
                                loading: 'lazy',
                                alt: block.settings.image.alt,
                                widths: '50, 75, 100, 150, 200, 300, 400, 500, 750, 1000, 1250, 1500, 1750, 2000, 2250, 2500, 2750, 3000, 3200',
                                sizes: sizes,
                                class: 'testimonial-item__image'
                            }}
                          </div>
                        {%- endif -%}

                        {% if block.settings.image_ratio == 'small' and settings.mood_type != 'mood6' %}
                          <div class="media media--transparent media--{{ block.settings.image_ratio }} {% if block.settings.with_border %} with-border {% endif %}" {% if block.settings.image_ratio == 'adapt' %}style="padding-bottom: {{ 1 | divided_by: block.settings.image.aspect_ratio | times: 100 }}%;"{% endif %} >
                            {%- liquid
                              assign number_of_columns = section.settings.columns_desktop
                              assign number_of_columns_mobile = 1
                            -%}
                            {% capture sizes %}
                              (min-width: {{ settings.page_width }}px) calc({{ settings.page_width }}px /  {{ number_of_columns }}),
                              (min-width: 990px) calc(100vw * / {{ number_of_columns }}),
                              (min-width: 750px) calc(100vw * / {{ number_of_columns_mobile }}),
                              calc(100vw / {{ number_of_columns_mobile }})
                            {% endcapture %}
                            {{
                              block.settings.image
                              | image_url: width: 600, format: 'webp' 
                              | image_tag:
                                loading: 'lazy',
                                alt: block.settings.image.alt,
                                widths: '50, 75, 100, 150, 200, 300, 400, 500, 750, 1000, 1250, 1500, 1750, 2000, 2250, 2500, 2750, 3000, 3200',
                                sizes: sizes,
                                class: 'testimonial-item__image'
                            }}
                          </div>
                        {%- endif -%}
                      </div>
                    {%- endif -%}

                    <div class="testimonial-item__content" tabindex="0">
                      {% if block.settings.show_rating == true %}
                        <div class="star-rating" style="--star-rating: {{ block.settings.star_rating }}; --color-star: {{ block.settings.star_color }}; --color-star-secondary: {{ block.settings.star_color_secondary }};"> </div> 
                      {% endif %}

                      {% if  block.settings.testimonail_title != blank %}
                        <h3 class="testimonial-title text-color-{{ block.settings.title_color }} {{ block.settings.title_size }}">
                          {{ block.settings.testimonail_title }}
                        </h3>
                      {% endif %}

                      {% if block.settings.testimonail_description != blank %}
                        <div class="testimonial-description rte text-color-{{ block.settings.description_color }} text-body--{{ block.settings.description_size }}">
                          {{ block.settings.testimonail_description }}
                        </div>
                      {% endif %}

                      {% if  settings.mood_type != 'mood6' %}
                        <p class="testimonial-author {{ block.settings.author_size }} text-color-{{ block.settings.author_color }} text-weight-{{ block.settings.author_weight }}">
                          {{ block.settings.testimonail_author }}
                        </p>
                        <p class="testimonial-city {{ block.settings.city_size }} text-color-{{ block.settings.city_color }} text-weight-{{ block.settings.city_weight }}">
                          {{ block.settings.testimonail_city }}
                        </p>
                      {% endif %}

                      {% if settings.mood_type == 'mood6' %}
                        <div class="testimonial-content-wrap {{ block.settings.content_alignment }}">
                          {% if block.settings.image_ratio == 'small' and block.settings.image != blank %}	
                            <div class="media media--transparent media--{{ block.settings.image_ratio }} {% if block.settings.with_border %}  with-border {% endif %}" {% if block.settings.image_ratio == 'adapt' %}style="padding-bottom: {{ 1 | divided_by: block.settings.image.aspect_ratio | times: 100 }}%;"{% endif %} >
                              {%- liquid
                                assign number_of_columns = section.settings.columns_desktop
                                assign number_of_columns_mobile = 1
                              -%}
                              {% capture sizes %}
                                (min-width: {{ settings.page_width }}px) calc({{ settings.page_width }}px /  {{ number_of_columns }}),
                                (min-width: 990px) calc(100vw * / {{ number_of_columns }}),
                                (min-width: 750px) calc(100vw * / {{ number_of_columns_mobile }}),
                                calc(100vw / {{ number_of_columns_mobile }})
                              {% endcapture %}
                              {{
                                block.settings.image
                                | image_url: width: 600, format: 'webp' 
                                | image_tag:
                                loading: 'lazy',
                                alt: block.settings.image.alt,
                                widths: '50, 75, 100, 150, 200, 300, 400, 500, 750, 1000, 1250, 1500, 1750, 2000, 2250, 2500, 2750, 3000, 3200',
                                sizes: sizes,
                                class: 'testimonial-item__image'
                              }}
                            </div>
                          {% endif %}

                          <div class="testimonial-bottom-content">
                            <p class="testimonial-author {{ block.settings.author_size }} text-color-{{ block.settings.author_color }} text-weight-{{ block.settings.author_weight }}">
                              {{ block.settings.testimonail_author }}
                            </p>
                            <p class="testimonial-city {{ block.settings.city_size }} text-color-{{ block.settings.city_color }} text-weight-{{ block.settings.city_weight }}">
                              {{ block.settings.testimonail_city }}
                            </p>
                          </div>

                        </div>
                      {% endif %}
                    </div>
                  </div>
                </div>

            {% endcase %}
          {%- endfor -%}
        </div>

        {% if section.blocks.size > 1 %}
          <div class="slider-navigation large-up-hide medium-hide">
            <div class="slider-arrow slider-arrow-prev {% if section.settings.arrows_outline %} slider-arrow--transparent {% endif %}" tabindex="0" role="button">
              {% if  settings.mood_type == 'kawai' %}
                {% render 'icon-arrow-red' %}
              {% else %}
                {% render 'icon-arrow-slider' %}
              {% endif %}
            </div>
            <div class="slider-arrow slider-arrow-next {% if section.settings.arrows_outline %} slider-arrow--transparent {% endif %}" tabindex="0" role="button">
              {% if  settings.mood_type == 'kawai' %}
                {% render 'icon-arrow-red' %}
              {% else %}
                {% render 'icon-arrow-slider' %}
              {% endif %}
            </div>
          </div>
        {% endif %}
      </div>

      {% if section.blocks.size > 1 and section.settings.show_btns_in_slider %}
        <div class="slider-arrow slider-arrow-next small-hide {% if section.settings.arrows_outline %} slider-arrow--transparent {% endif %} {% if settings.mood_type == 'mood5' %}button{% endif %}" tabindex="0" role="button" aria-label="Next slide">
          {% if  settings.mood_type == 'kawai' %}
            {% render 'icon-arrow-red' %}
          {% else %}
            {% render 'icon-arrow-slider' %}
          {% endif %}
        </div>
      {% endif %}
    </div>
	</div>
</div>

{% if section.blocks.size > 1 %}
  <script src="{{ 'slider-testimonials.js' | asset_url }}" defer="defer"></script>
{% endif %}

{% schema %}
{
  "name": "Testimonials slider",
  "tag": "section",
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "custom.additions"
    ]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "<strong>Testimonials</strong>",
      "label": "t:sections.featured-blog.settings.heading.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
		{
          "value": "h4",
          "label": "Extra small"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__3.label"
        }
      ],
      "default": "h2",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "select",
      "id": "text_color",
      "options": [
        {
          "value": "main",
          "label": "t:settings_schema.colors.settings.colors_text.label"
        },
        {
          "value": "secondary",
          "label": "t:settings_schema.colors.settings.colors_secondary_text.label"
        },
        {
          "value": "heading",
          "label": "t:settings_schema.colors.settings.colors_heading.label"
        },
        {
          "value": "heading-secondary",
          "label": "t:settings_schema.colors.settings.colors_secondary_heading.label"
        }
      ],
      "default": "heading",
      "label": "t:sections.all.colors.label_heading",
      "info": "t:sections.all.colors.has_cards_info"
    },
	{
      "type": "text",
      "id": "text_heading",
      "label": "Color-changing text",
      "info": "Case-sensitive. To change the colors of words that are not next to each other, use a comma. For example 'shipping, shop'"
    },
    {
      "type": "color",
      "id": "text_color_2",
      "label": "Custom color"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left",
      "label": "Content alignment"
    },
		{
      "type": "select",
      "id": "text_bottom_space",
      "options": [
        {
          "value": "",
          "label": "Small"
        },
        {
          "value": "mb-lg-6",
          "label": "Large"
        }
      ],
      "default": "",
      "label": "Text bottom space desktop"
    },
		{
      "type": "header",
      "content": "Slider settings"
    },
		{
			"type": "checkbox",
			"id": "full_width",
			"label": "Full width",
			"default": false
		},
		{
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 5,
      "step": 0.1,
      "default": 3,
      "label": "t:sections.featured-blog.settings.columns_desktop.label"
    },
		{
			"type": "checkbox",
			"id": "center_slide",
			"label": "Center slide",
			"default": true
		},
		{
			"type": "color",
			"id": "testimonial_background",
			"label": "Active testimonial background color",
			"default": "#ffffff",
			"info": "Work with center slide"
		},
    	{
			"type": "checkbox",
			"id": "side_item_bg_enable",
			"label": "Enable custom background color for side block",
			"default": false
		},
		{
			"type": "color",
			"id": "side_item_bg",
			"label": "Active side block background color",
			"default": "#efe6d9"
		},
		{
			"type": "checkbox",
			"id": "slide_item_bg_enable",
			"label": "Enable custom background color for block",
			"default": false
		},
		{
			"type": "color",
			"id": "slide_item_bg",
			"label": "Block background color",
			"default": "#efe6d9"
		},
		{
      "type": "header",
      "content": "Arrows settings"
    },
		{
			"type": "checkbox",
			"id": "show_btns",
			"label": "Show slider buttons on desktop in title",
			"default": true
		},
    {
			"type": "checkbox",
			"id": "show_btns_in_slider",
			"label": "Show slider buttons on desktop in slider",
			"default": false
		},
		{
      "type": "color",
      "id": "arrows_btn_color",
      "default": "#101010",
      "label": "Arrows color"
    },
    {
      "type": "color",
      "id": "arrows_btn_color_hover",
      "default": "#FFD265",
      "label": "Arrows color hover"
    },
    {
      "type": "color",
      "id": "arrows_btn_bg_color",
      "default": "#FFD265",
      "label": "Arrows background"
    },
    {
      "type": "color",
      "id": "arrows_btn_bg_color_hover",
      "default": "#101010",
      "label": "Arrows background hover"
    },
		{
			"type": "checkbox",
			"id": "arrows_outline",
			"label": "Enable outline on hover",
			"default": false
		},
    {
      "type": "header",
      "content": "Section overlay"
    },
    {
      "type": "image_picker",
      "id": "image_overlay",
      "label": "Image overlay"
    },
    {
      "type": "range",
      "id": "image_overlay_width",
      "min": 1,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Image width",
      "default": 10
    },
    {
      "type": "range",
      "id": "image_overlay_vertical",
      "min": 1,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Image vertical position",
      "default": 20
    },
    {
      "type": "range",
      "id": "image_overlay_horizontal",
      "min": 1,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Image horizontal position",
      "default": 20
    },
    {
      "type": "range",
      "id": "image_overlay_width_mobile",
      "min": 1,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Image width mobile",
      "default": 10
    },
    {
      "type": "range",
      "id": "image_overlay_vertical_mobile",
      "min": 1,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Image vertical position mobile",
      "default": 20
    },
    {
      "type": "range",
      "id": "image_overlay_horizontal_mobile",
      "min": 1,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Image horizontal position mobile",
