							{% if description_has_data or specifications_has_data or buyback_has_data %}
								{% assign has_any_tabs = true %}
							{% endif %}

							{% if has_any_tabs %}
								{{ 'component-product-meta-tabs.css' | asset_url | stylesheet_tag }}
