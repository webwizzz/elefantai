<div
  id="MainProduct-{{ section.id }}"
  class="page-width section-responsive-padding {% if section.settings.secondary_background_color != "none" %} product-background-secondary{% endif %}"
  data-section="{{ section.id }}"
>
  {{ 'section-main-product.css' | asset_url | stylesheet_tag }}
  {{ 'component-accordion.css' | asset_url | stylesheet_tag }}
  {{ 'component-price.css' | asset_url | stylesheet_tag }}
  {{ 'component-slider.css' | asset_url | stylesheet_tag }}
  {{ 'component-rating.css' | asset_url | stylesheet_tag }}
  {{ 'component-loading-overlay.css' | asset_url | stylesheet_tag }}
  {{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}

  {%- style -%}
    #shopify-section-{{ section.id }} {
    	--padding-top: {{ section.settings.padding_top }}px;
    	--padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    #shopify-section-{{ section.id }} .product__divider {
      width: 100%;
      line-height: 0;
    }

    #shopify-section-{{ section.id }} .product__divider-line {
      margin: 0;
      border: 0;
      border-top-style: solid;
      border-top-width: var(--divider-thickness, 1px);
      border-top-color: var(--divider-color, rgba(var(--color-base-text), 0.15));
    }

    {% if section.settings.colors_background_section_gradient != blank %}
    	#shopify-section-{{ section.id }} {
    		background: {{ section.settings.colors_background_section_gradient }};
    	}
    {% else %}
    	#shopify-section-{{ section.id }} {
    		background: rgb(var({{ section.settings.background_color }}));
    	}
    {% endif %}
  {%- endstyle -%}

  <script src="{{ 'product-info.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>

  {% if section.settings.image_zoom == 'hover' %}
    <script id="EnableZoomOnHover-main" src="{{ 'magnify.js' | asset_url }}" defer="defer"></script>
  {% endif %}

  {%- if request.design_mode -%}
    <script src="{{ 'theme-editor.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}

  {%- assign first_3d_model = product.media | where: 'media_type', 'model' | first -%}

  {%- if first_3d_model -%}
    {{ 'component-product-model.css' | asset_url | stylesheet_tag }}
    <link
      id="ModelViewerStyle"
      rel="stylesheet"
      href="https://cdn.shopify.com/shopifycloud/model-viewer-ui/assets/v1.0/model-viewer-ui.css"
      media="print"
      onload="this.media='all'"
    >
    <link
      id="ModelViewerOverride"
      rel="stylesheet"
      href="{{ 'component-model-viewer-ui.css' | asset_url }}"
      media="print"
      onload="this.media='all'"
    >
  {%- endif -%}

  {%- assign variant_images = product.images | where: 'attached_to_variant?', true | map: 'src' -%}

  {% if section.settings.image_overlay != blank %}
    {%- capture sizes -%}
		(min-width: {{ settings.page_width }}px) 100vw,
		(min-width: 750px) 100vw, 100vw
	{%- endcapture -%}
    {% liquid
      assign widths = '198, 230, 320, 432, 550, 642, 700, 900, 1284, 1440, 1600, 1800, 1900, 2000'
      assign classes = 'section-image-overlay quick-add-hidden '
    %}
    {{
      section.settings.image_overlay
      | image_url: width: 2000
      | image_tag: loading: 'lazy', sizes: sizes, widths: widths, class: classes, alt: 'background shape'
    }}
  {%- endif -%}

  {% if section.settings.secondary_background_color != 'none' %}
    <div class="product-wrapp {{ section.settings.secondary_background_color }}">
  {% endif %}

  {% assign breadcrumb_block = section.blocks | where: 'type', 'breadcrumb' | first %}
  {% if breadcrumb_block != blank %}
    <div
      class="breadcrumb-section breadcrumb-section-product quick-add-hidden text-color-{{ breadcrumb_block.settings.breadcrumb_color }} text-color-{{ breadcrumb_block.settings.breadcrumb_color_hover }}-hover"
      {{ breadcrumb_block.shopify_attributes }}
    >
      {% render 'breadcrumb', active_color: breadcrumb_block.settings.breadcrumb_color_hover %}
    </div>
  {% endif %}

  <div class="product main-product product--{{ section.settings.media_size }} product--{{ section.settings.gallery_layout }} product--mobile-{{ section.settings.mobile_thumbnails }} grid grid--1-col {% if product.media.size > 0 %}grid--2-col-tablet{% else %}product--no-media{% endif %}{% if product.gift_card? %} gift-card-product{% endif %}{% if section.settings.secondary_background_color != "none" %} {{ section.settings.secondary_background_color }} background-secondary{% endif %}">
    {% if product.media.size > 0 and section.settings.global_media_position == 'left' %}
      <div class="grid__item product__media-wrapper {% if section.settings.gallery_layout != "dots" %}{% if section.settings.media_position != "bottom" %} thumbnail-aside{% endif %} thumbnail--{{ section.settings.media_position }}{% endif %}{% if section.settings.enable_sticky_info %} product__column-sticky{% endif %}">
        {% if settings.mood_type == 'mood4' %}
          <div class="product__gallery-wrapper">
            <div class="product__media-container">
        {% endif %}

        {% render 'product-media-gallery', variant_images: variant_images, product: product %}

        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'buy_buttons' -%}
              {% if block.settings.block_position == 'under_media' %}
                {%- assign product_form_id = 'product-form-' | append: section.id -%}
                {%- render 'buy-buttons',
                  block: block,
                  product: product,
                  product_form_id: product_form_id,
                  section_id: section.id,
                  classes: section.settings.secondary_background_color,
                  show_pickup_availability: block.settings.show_availability,
                  show_quantity: block.settings.hide_quantity,
                  full_width: block.settings.full_width
                -%}
              {% endif %}
          {%- endcase -%}
        {%- endfor -%}

        {% if settings.mood_type == 'mood4' %}
          </div>
          </div>
        {% endif %}

        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'collapsible_tab' -%}
              {% if block.settings.collapsible_row_position == 'under_media' %}
                <div class="product__accordion accordion under-product quick-add-hidden" {{ block.shopify_attributes }}>
                  <details
                    id="Details-{{ block.id }}-{{ section.id }}"
                    {% if block.settings.default_open %}
                      open
                    {% endif %}
                  >
                    <summary>
                      <div class="summary__title">
                        {% render 'icon-accordion', icon: block.settings.icon %}

                        <h2 class="accordion__title inline-richtext {{ block.settings.heading_size }}">
                          {{ block.settings.heading | default: block.settings.page.title }}
                        </h2>
                      </div>
                      <span class="accordion__title-icon"> </span>
                    </summary>
                    <div class="accordion__content rte" id="ProductAccordion-{{ block.id }}-{{ section.id }}">
                      <div>
                        {{ block.settings.content }}

                        {{ block.settings.page.content }}

                        {% if block.settings.product_content == true %}
                          {{ product.description }}
                        {% endif %}
                      </div>
                      {%- if block.settings.image != blank -%}
                        {{
                          block.settings.image
                          | image_url: width: 445
                          | image_tag: loading: 'lazy', alt: block.settings.image.alt, class: 'accordion__image'
                        }}
                      {% endif %}
                    </div>
                  </details>
                </div>
              {% endif %}

            {%- when 'complementary' -%}
              {% if block.settings.block_position == 'under_media' %}
                <product-recommendations
                  class="complementary-products quick-add-hidden no-js-hidden{% if block.settings.make_collapsible_row %} is-accordion{% endif %}{% if block.settings.enable_quick_add %} complementary-products-contains-quick-add{% endif %}"
                  data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ block.settings.product_list_limit }}&intent=complementary"
                  {{ block.shopify_attributes }}
                >
                  {%- if recommendations.performed and recommendations.products_count > 0 -%}
                    <aside
                      aria-label="{{ 'accessibility.complementary_products' | t }}"
                      class="{% if block.settings.background_color != "none" %}{{ block.settings.background_color }} recommendations-background{% endif %}{% if block.settings.make_collapsible_row %} product__accordion accordion{% endif %}"
                    >
                      <div class="complementary-products__container">
                        {%- if block.settings.make_collapsible_row -%}
                          <details id="Details-{{ block.id }}-{{ section.id }}" open>
                            <summary>
                        {%- endif %}

                        {% if block.settings.block_heading != blank %}
                          <div class="summary__title">
                            {%- if block.settings.make_collapsible_row -%}
                              {% render 'icon-accordion', icon: block.settings.icon %}

                              <h2 class="accordion__title {{ block.settings.heading_size }}">
                                {{ block.settings.block_heading }}
                              </h2>
                            {%- else -%}
                              <h2 class="accordion__title {{ block.settings.heading_size }}">
                                {{ block.settings.block_heading }}
                              </h2>
                            {%- endif -%}
                          </div>
                        {% endif %}

                        {%- if block.settings.make_collapsible_row -%}
                          </summary>
                        {%- endif -%}

                        <slideshow-component class="slider-mobile-gutter">
                          {%- assign number_of_slides = recommendations.products_count
                            | plus: 0.0
                            | divided_by: block.settings.products_per_page
                            | ceil
                          -%}
                          <div
                            id="Slider-{{ block.id }}"
                            class="contains-card contains-card--product complementary-slider grid grid--1-col slider slider--everywhere"
                            role="list"
                            {% if number_of_slides > 1 %}
                              aria-label="{{ 'general.slider.name' | t }}"
                            {% endif %}
                          >
                            {%- for i in (1..number_of_slides) -%}
                              <div
                                id="Slide-{{ block.id }}-{{ forloop.index }}"
                                class="complementary-slide complementary-slide--{{ settings.card_style }} grid__item slider__slide slideshow__slide"
                                tabindex="-1"
                                role="group"
                                {% if number_of_slides > 1 %}
                                  aria-roledescription="{{ 'sections.slideshow.slide' | t }}"
                                  aria-label="{{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}"
                                {% endif %}
                              >
                                <ul class="list-unstyled" role="list">
                                  {%- for product in recommendations.products
                                    limit: block.settings.products_per_page
                                    offset: continue
                                  -%}
                                    <li>
                                      {% render 'complimentary-product',
                                        card_product: product,
                                        media_aspect_ratio: block.settings.image_ratio,
                                        lazy_load: false,
                                        show_quick_add: block.settings.enable_quick_add,
                                        section_id: section.id,
                                        horizontal_class: block.settings.enable_horizontal,
                                        horizontal_quick_add: true
                                      %}
                                    </li>
                                  {%- endfor -%}
                                </ul>
                              </div>
                            {%- endfor -%}
                          </div>

                          <div class="slider-buttons no-js-hidden pagination--{{block.settings.pagination_style }} {% if number_of_slides == 1 %} unvisible {% endif %}">
                            <button
                              type="button"
                              class="slider-button slider-button--prev {% if  settings.mood_type == 'mood6' %} slider-arrow {% endif %}"
                              name="previous"
                              aria-label="{{ 'general.slider.previous_slide' | t }}"
                            >
                              {% if settings.mood_type == 'mood6' %}
                                {% render 'icon-arrow-slider' %}
                              {% else %}
                                {% render 'icon-caret' %}
                              {% endif %}
                            </button>
                            <div class="slider-counter slider-counter--{{ block.settings.pagination_style }}{% if block.settings.pagination_style == 'counter' or block.settings.pagination_style == 'numbers' %} caption{% endif %}">
                              {%- if block.settings.pagination_style == 'counter' -%}
                                <span class="slider-counter--current">1</span>
                                <span aria-hidden="true"> / </span>
                                <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
                                <span class="slider-counter--total">{{ number_of_slides }}</span>
                              {%- else -%}
                                <div class="slideshow__control-wrapper">
                                  {%- for i in (1..number_of_slides) -%}
                                    <button
                                      class="slider-counter__link slider-counter__link--{{ block.settings.pagination_style }} link"
                                      aria-label="{{ 'sections.slideshow.load_slide' | t }} {{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}"
                                      aria-controls="Slider-{{ block.id }}"
                                    >
                                      {%- if block.settings.pagination_style == 'numbers' -%}
                                        {{ forloop.index -}}
                                      {%- else -%}
                                        <span class="dot"></span>
                                      {%- endif -%}
                                    </button>
                                  {%- endfor -%}
                                </div>
                              {%- endif -%}
                            </div>
                            <button
                              type="button"
                              class="slider-button slider-button--next {% if  settings.mood_type == 'mood6' %} slider-arrow {% endif %}"
                              name="next"
                              aria-label="{{ 'general.slider.next_slide' | t }}"
                            >
                              {% if settings.mood_type == 'mood6' %}
                                {% render 'icon-arrow-slider' %}
                              {% else %}
                                {% render 'icon-caret' %}
                              {% endif %}
                            </button>
                          </div>
                        </slideshow-component>

                        {%- if block.settings.make_collapsible_row -%}
                          </details>
                        {%- endif -%}
                      </div>
                    </aside>
                  {%- endif -%}
                  {{ 'component-card.css' | asset_url | stylesheet_tag }}
                  {{ 'component-complementary-products.css' | asset_url | stylesheet_tag }}
                  {%- if block.settings.enable_quick_add -%}
                    {{ 'quick-add.css' | asset_url | stylesheet_tag }}
                    <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
                  {%- endif -%}
                </product-recommendations>
              {% endif %}

            {%- when 'text' -%}
              {% if block.settings.block_position == 'under_media' %}
                <div
                  class="product__text rte quick-add-hidden text-color-{{ block.settings.text_color }} {{ block.settings.text_style }} text-weight-{{ block.settings.text_weight }}"
                  {{ block.shopify_attributes }}
                >
                  {{- block.settings.text -}}
                </div>
                {% if block.settings.subtext != blank %}
                  <div
                    class="product__subtext rte text-color-{{ block.settings.subtext_color }} {{ block.settings.subtext_style }}"
                    {{ block.shopify_attributes }}
                  >
                    {{- block.settings.subtext -}}
                  </div>
                {% endif %}
              {% endif %}

            {%- when 'video' -%}
              {% if block.settings.block_position == 'under_media' %}
                {%- render 'block-video',
                  block: block,
                  forloop: forloop,
                  classes: 'quick-add-hidden',
                  section_id: section.id
                -%}
              {% endif %}

            {%- when 'image' -%}
              {% if block.settings.block_position == 'under_media' %}
                {%- render 'block-image', block: block, forloop: forloop, section_id: section.id -%}
              {% endif %}

            {%- when 'divider' -%}
              {% if block.settings.block_position == 'under_media' %}
                <div
                  class="product__divider quick-add-hidden"
                  style="--divider-color: {{ block.settings.divider_color }}; --divider-thickness: {{ block.settings.divider_thickness }}px;"
                  {{ block.shopify_attributes }}
                >
                  <hr class="product__divider-line">
                </div>
              {% endif %}

            {%- when 'effective_price_cta' -%}
              {% if block.settings.block_position == 'under_media' %}
                {%- liquid
                  assign base_price = product.selected_or_first_available_variant.price
                  assign buyback_percent = block.settings.buyback_percent | default: 60
                  assign remaining_percent = 100 | minus: buyback_percent
                  assign effective_price = base_price | times: remaining_percent | divided_by: 100
                  assign effective_price_cta_link = block.settings.button_link | strip
                  assign effective_price_cta_first_char = effective_price_cta_link | slice: 0, 1

                  if effective_price_cta_link == '#selback_value' or effective_price_cta_link == '#sellback-value'
                    assign effective_price_cta_link = '#selback-value'
                  endif

                  if product != blank
                    if effective_price_cta_link == blank
                      assign effective_price_cta_link = product.url | append: '#selback-value'
                    elsif effective_price_cta_first_char == '#'
                      assign effective_price_cta_link = product.url | append: effective_price_cta_link
                    endif
                  endif
                -%}
                <div
                  id="EffectivePrice-{{ block.id }}-{{ section.id }}"
                  class="product-effective-price quick-add-hidden"
                  data-effective-price-section="{{ section.id }}"
                  data-effective-price-block-id="{{ block.id }}"
                  {{ block.shopify_attributes }}
                >
                  <div class="product-effective-price__text-wrap">
                    <p class="product-effective-price__value">
                      {{ block.settings.price_prefix }} <span data-effective-price-value>{{ effective_price | money_without_trailing_zeros }}</span>
                    </p>
                    {% if block.settings.caption != blank %}
                      <p class="product-effective-price__caption">{{ block.settings.caption }}</p>
                    {% endif %}
                  </div>

                  {% if block.settings.button_label != blank %}
                    {% if effective_price_cta_link != blank %}
                      <a href="{{ effective_price_cta_link }}" class="product-effective-price__button">
                        {{ block.settings.button_label }}
                      </a>
                    {% else %}
                      <span class="product-effective-price__button" role="button" aria-disabled="true">
                        {{ block.settings.button_label }}
                      </span>
                    {% endif %}
                  {% endif %}
                </div>
              {% endif %}
          {%- endcase -%}
        {%- endfor -%}
      </div>
    {% endif %}

    <div class="product__info-wrapper grid__item{% if settings.page_width > 1400 and section.settings.media_size == "small" %} product__info-wrapper--extra-padding{% endif %}{% if section.settings.info_background_color != "none" %} info-wrapper-background-secondary {{ section.settings.info_background_color }}{% endif %}{% if section.settings.enable_sticky_info %} product__column-sticky{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      <product-info
        id="ProductInfo-{{ section.id }}"
        data-section="{{ section.id }}"
        data-url="{{ product.url }}"
        class="product__info-container{% if section.settings.info_background_color != "none" %} info-background-secondary{% endif %}"
      >
        {%- assign product_form_id = 'product-form-' | append: section.id -%}
        {%- assign product_meta_tabs_markup = '' -%}

        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when '@app' -%}
              {% render block %}

            {%- when 'text' -%}
              {% if block.settings.block_position == 'sidebar' or product.media.size <= 0 %}
                <div
                  class="product__text rte text-color-{{ block.settings.text_color }} {{ block.settings.text_style }} text-weight-{{ block.settings.text_weight }}"
                  {{ block.shopify_attributes }}
                >
                  {{- block.settings.text -}}
                </div>
                {% if block.settings.subtext != blank %}
                  <div
                    class="product__subtext rte text-color-{{ block.settings.subtext_color }} {{ block.settings.subtext_style }}"
                    {{ block.shopify_attributes }}
                  >
                    {{- block.settings.subtext -}}
                  </div>
                {% endif %}
              {% endif %}

            {%- when 'title' -%}
              {% if block.settings.title_price_badge %}
                {% assign badge_names = settings.badge_names | split: ',' %}
                {% for tag in product.tags %}
                  {% assign tag_handleize = tag | handleize %}
                  {% for badge in badge_names %}
                    {% assign badge_handleize = badge | handleize %}
                    {% if tag_handleize == badge_handleize %}
                      <span class="badge text-color-{{ settings.badge_text_color }} background--default">
                        {{- badge | escape -}}
                      </span>
                    {% endif %}
                  {% endfor %}
                {% endfor %}
              {% endif %}

              <div
                class="product__title {{ block.settings.heading_size }} text-color-{{ block.settings.heading_color }} text-weight-{{ block.settings.heading_weight }}"
                {{ block.shopify_attributes }}
              >
                <h1>
                  {{ product.title | escape }}

                  {% if block.settings.show_vendor %}
                    <span class="product__title-vendor">{{ product.vendor }}</span>
                  {% endif %}
                </h1>
              </div>

              {%- if settings.product_info != blank and block.settings.title_product_type -%}
                <div class="card-product-info">
                  {% liquid
                    assign product_info_metafield_name = settings.product_info | handleize | replace: '-', '_'
                    assign product_info_metafield_value = product.metafields.custom[product_info_metafield_name]
                  %}
                  {% if product_info_metafield_value != blank %}
                    <span class="card-product_info">
                      {{ product_info_metafield_value }}
                    </span>
                  {% endif %}
                </div>
              {% endif %}

            {%- when 'buyback' -%}
              {{ 'component-buyback.css' | asset_url | stylesheet_tag }}
              <div
                class="product-buyback {{ block.settings.block_position }}"
                style="--buyback-accent: {{ block.settings.accent_color }}; --buyback-bg: {{ block.settings.background_color }}; --buyback-title-color: {{ block.settings.title_color }}; --buyback-emphasis-color: {{ block.settings.emphasis_color }};"
                {{ block.shopify_attributes }}
              >
                <div class="product-buyback__left">{{ block.settings.percent }}</div>
                <div class="product-buyback__text">
                  <div class="product-buyback__titles">
                    <div class="product-buyback__title">{{ block.settings.title_main }}</div>
                    <div class="product-buyback__emphasis">{{ block.settings.title_emphasis }}</div>
                  </div>
                  {% if block.settings.description != blank %}
                    <div class="product-buyback__desc">{{ block.settings.description }}</div>
                  {% endif %}
                </div>
              </div>

            {%- when 'price' -%}
              <div
                class="no-js-hidden price-wrapp"
                id="price-{{ section.id }}"
                role="status"
                {{ block.shopify_attributes }}
              >
                {%- render 'price',
                  product: product,
                  use_variant: true,
                  show_badges: true,
                  price_class: block.settings.price_size,
                  price_class_weight: block.settings.price_weight,
                  sale_price_weight: block.settings.sale_price_weight,
                  price_badge: block.settings.price_badge,
                  price_badge_top: true
                -%}

                {%- if cart.taxes_included or shop.shipping_policy.body != blank -%}
                  <div class="product__tax caption rte">
                    {%- if cart.taxes_included -%}
                      {{ 'products.product.include_taxes' | t }}
                    {%- endif -%}
                    {%- if shop.shipping_policy.body != blank -%}
                      {{ 'products.product.shipping_policy_html' | t: link: shop.shipping_policy.url }}
                    {%- endif -%}
                  </div>
                {%- endif -%}
              </div>

              <div {{ block.shopify_attributes }}>
                {%- assign product_form_installment_id = 'product-form-installment-' | append: section.id -%}
                {%- form 'product', product, id: product_form_installment_id, class: 'installment' -%}
                  <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                  {{ form | payment_terms }}
                {%- endform -%}
              </div>

            {%- when 'inventory' -%}
              <p
                class="product__inventory {{ block.settings.heading_size }} no-js-hidden{% if product.selected_or_first_available_variant.inventory_management != 'shopify' %} visibility-hidden{% endif %}{% if block.settings.show_inventory_progress %} inventory-progress{% endif %}"
                {{ block.shopify_attributes }}
                id="Inventory-{{ section.id }}"
                role="status"
              >
                {%- if product.selected_or_first_available_variant.inventory_management == 'shopify' -%}
                  {%- if product.selected_or_first_available_variant.inventory_quantity
                      <= block.settings.inventory_threshold
                    and block.settings.show_inventory_low
                  -%}
                    {%- if product.selected_or_first_available_variant.inventory_quantity > 0 -%}
                      {%- if product.selected_or_first_available_variant.inventory_quantity
                          <= block.settings.inventory_threshold
                      -%}
                        {% if block.settings.inventory_icon != blank %}
                          {{
                            block.settings.inventory_icon
                            | image_url: width: 20
                            | image_tag:
                              loading: 'lazy',
                              sizes: '20px',
                              widths: '20',
                              alt: block.settings.inventory_icon.alt
                          }}
                        {%- else -%}
                          <svg width="15" height="15" aria-hidden="true">
                            <circle cx="7.5" cy="7.5" r="7.5" fill="rgba(207, 46, 38, 0.3)"/>
