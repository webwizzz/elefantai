																					<span class="product-tag">{{ text_node.value }}</span>
																				{%- endif -%}
																			{%- endfor -%}
																		{%- endif -%}
																	{%- endfor -%}
																{%- endif -%}
															{%- endfor -%}
														{%- endif -%}
