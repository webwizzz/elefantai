											<li class="product-meta-tabs__item">
												<span class="product-meta-tabs__item-icon-wrap product-meta-tabs__item-icon-wrap--star">
													{% if feature_icon != blank %}
														{{ feature_icon | image_url: width: 32 | image_tag: class: 'product-meta-tabs__item-icon', alt: feature_text }}
													{% else %}
														<span class="product-meta-tabs__item-icon-fallback product-meta-tabs__item-icon-fallback--star">&#9733;</span>
													{% endif %}
												</span>
												<span>{{ feature_text }}</span>
											</li>
										{% endif %}
									{% endfor %}
								{% endif %}
							{% endcapture %}
							{% assign why_kids_items = why_kids_items | strip %}

							{% capture specifications_rows %}
