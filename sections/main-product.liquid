											{% if description_has_data %}
												<button id="{{ tabs_id }}-tab-description" type="button" class="product-meta-tabs__tab{% if first_visible_tab == 'description' %} is-active{% endif %}" role="tab" aria-selected="{% if first_visible_tab == 'description' %}true{% else %}false{% endif %}" aria-controls="{{ tabs_id }}-panel-description" data-target="#{{ tabs_id }}-panel-description">{{ block.settings.description_tab_label }}</button>
											{% endif %}
											{% if specifications_has_data %}
												<button id="{{ tabs_id }}-tab-specification" type="button" class="product-meta-tabs__tab{% if first_visible_tab == 'specification' %} is-active{% endif %}" role="tab" aria-selected="{% if first_visible_tab == 'specification' %}true{% else %}false{% endif %}" aria-controls="{{ tabs_id }}-panel-specification" data-target="#{{ tabs_id }}-panel-specification">{{ block.settings.specification_tab_label }}</button>
											{% endif %}
											{% if buyback_has_data %}
												<button id="{{ tabs_id }}-tab-buyback" type="button" class="product-meta-tabs__tab{% if first_visible_tab == 'buyback' %} is-active{% endif %}" role="tab" aria-selected="{% if first_visible_tab == 'buyback' %}true{% else %}false{% endif %}" aria-controls="{{ tabs_id }}-panel-buyback" data-target="#{{ tabs_id }}-panel-buyback">{{ block.settings.buyback_tab_label }}</button>
