								{% assign first_visible_tab = '' %}
								{% if description_has_data %}
									{% assign first_visible_tab = 'description' %}
								{% elsif specifications_has_data %}
									{% assign first_visible_tab = 'specification' %}
								{% elsif buyback_has_data %}
									{% assign first_visible_tab = 'buyback' %}
