          {% endif %}

        {%- when 'text' -%}
          {% if block.settings.block_position != 'sidebar' %}
            {% if block.settings.block_position == 'under_media' %}
              {% assign classes = 'medium-hide large-up-hide quick-add-hidden' %}
            {% else %}
              {% assign classes = ' ' %}
            {% endif %}

            <div class="{{ classes }}">
              <div
                class="product__text rte text-color-{{ block.settings.text_color }} {{ block.settings.text_style }} text-weight-{{ block.settings.text_weight }}"
                {{ block.shopify_attributes }}
              >
                {{- block.settings.text -}}
              </div>
              {% if block.settings.subtext != blank %}
                <div
                  class="product__subtext rte text-color-{{ block.settings.subtext_color }} {{ block.settings.subtext_style }}"
                  {{ block.shopify_attributes }}
                >
                  {{- block.settings.subtext -}}
                </div>
              {% endif %}
            </div>
          {% endif %}

        {%- when 'video' -%}
          {% if block.settings.block_position != 'sidebar' %}
            {% if block.settings.block_position == 'under_media' %}
              {% assign classes = 'medium-hide large-up-hide quick-add-hidden' %}
            {% else %}
              {% assign classes = ' ' %}
            {% endif %}

            {%- render 'block-video', block: block, forloop: forloop, classes: classes, section_id: section.id -%}
          {% endif %}

        {%- when 'divider' -%}
          {% if block.settings.block_position != 'sidebar' %}
            {% if block.settings.block_position == 'under_media' %}
              {% assign divider_classes = 'medium-hide large-up-hide quick-add-hidden' %}
            {% else %}
              {% assign divider_classes = '' %}
            {% endif %}

            <div
              class="product__divider {{ divider_classes }}"
              style="--divider-color: {{ block.settings.divider_color }}; --divider-thickness: {{ block.settings.divider_thickness }}px;"
              {{ block.shopify_attributes }}
            >
              <hr class="product__divider-line">
            </div>
          {% endif %}

        {%- when 'effective_price_cta' -%}
          {% if block.settings.block_position != 'sidebar' %}
            {% if block.settings.block_position == 'under_media' %}
              {% assign effective_price_classes = 'medium-hide large-up-hide quick-add-hidden' %}
            {% else %}
              {% assign effective_price_classes = '' %}
            {% endif %}

            {%- liquid
              assign base_price = product.selected_or_first_available_variant.price
              assign buyback_percent = block.settings.buyback_percent | default: 60
              assign remaining_percent = 100 | minus: buyback_percent
              assign effective_price = base_price | times: remaining_percent | divided_by: 100
              assign effective_price_cta_link = block.settings.button_link | strip
              assign effective_price_cta_first_char = effective_price_cta_link | slice: 0, 1

              if effective_price_cta_link == '#selback_value' or effective_price_cta_link == '#sellback-value'
                assign effective_price_cta_link = '#selback-value'
              endif

              if product != blank
                if effective_price_cta_link == blank
                  assign effective_price_cta_link = product.url | append: '#selback-value'
                elsif effective_price_cta_first_char == '#'
                  assign effective_price_cta_link = product.url | append: effective_price_cta_link
                endif
              endif
            -%}
            <div
              id="EffectivePrice-{{ block.id }}-{{ section.id }}"
              class="product-effective-price {{ effective_price_classes }}"
              data-effective-price-section="{{ section.id }}"
              data-effective-price-block-id="{{ block.id }}"
              {{ block.shopify_attributes }}
            >
              <div class="product-effective-price__text-wrap">
                <p class="product-effective-price__value">
                  {{ block.settings.price_prefix }} <span data-effective-price-value>{{ effective_price | money_without_trailing_zeros }}</span>
                </p>
                {% if block.settings.caption != blank %}
                  <p class="product-effective-price__caption">{{ block.settings.caption }}</p>
                {% endif %}
              </div>

              {% if block.settings.button_label != blank %}
                {% if effective_price_cta_link != blank %}
                  <a href="{{ effective_price_cta_link }}" class="product-effective-price__button">
                    {{ block.settings.button_label }}
                  </a>
                {% else %}
                  <span class="product-effective-price__button" role="button" aria-disabled="true">
                    {{ block.settings.button_label }}
                  </span>
                {% endif %}
              {% endif %}
            </div>
          {% endif %}
      {%- endcase -%}
    {%- endfor -%}
  {% endif %}

  {% render 'product-media-modal', variant_images: variant_images %}

  {% assign popups = section.blocks | where: 'type', 'popup' %}

  {%- for block in popups -%}
    <modal-dialog id="PopupModal-{{ block.id }}" class="product-popup-modal" {{ block.shopify_attributes }}>
      <div
        role="dialog"
        aria-label="{{ block.settings.text }}"
        aria-modal="true"
        class="product-popup-modal__content"
        tabindex="-1"
      >
        <button
          id="ModalClose-{{ block.id }}"
          type="button"
          class="product-popup-modal__toggle"
          aria-label="{{ 'accessibility.close' | t }}"
        >
          {% render 'icon-close' %}
        </button>
        <div class="product-popup-modal__content-info rte">
          {{ block.settings.page.content }}
        </div>
      </div>
    </modal-dialog>
  {%- endfor -%}

  {% if section.settings.secondary_background_color != 'none' %}
    </div>
  {% endif %}

  {%- if product.media.size > 0 -%}
    <script src="{{ 'product-modal.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'media-gallery.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}

  {%- if first_3d_model -%}
    <script type="application/json" id="ProductJSON-{{ product.id }}">
      {{ product.media | where: 'media_type', 'model' | json }}
    </script>
    <script src="{{ 'product-model.js' | asset_url }}" defer></script>
  {%- endif -%}

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      function isIE() {
        const ua = window.navigator.userAgent;
        const msie = ua.indexOf('MSIE ');
        const trident = ua.indexOf('Trident/');
        return msie > 0 || trident > 0;
      }

      if (!isIE()) return;
      const hiddenInput = document.querySelector('#{{ product_form_id }} input[name="id"]');
      const noScriptInputWrapper = document.createElement('div');
      const variantSwitcher =
        document.querySelector('variant-radios[data-section="{{ section.id }}"]') ||
        document.querySelector('variant-selects[data-section="{{ section.id }}"]');
      noScriptInputWrapper.innerHTML = document.querySelector(
        '.product-form__noscript-wrapper-{{ section.id }}'
      ).textContent;
      variantSwitcher.outerHTML = noScriptInputWrapper.outerHTML;

      document.querySelector('#Variants-{{ section.id }}').addEventListener('change', function (event) {
        hiddenInput.value = event.currentTarget.value;
      });
    });
  </script>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      if (typeof subscribe !== 'function' || typeof PUB_SUB_EVENTS === 'undefined') return;

      const sectionId = '{{ section.id }}';

      subscribe(PUB_SUB_EVENTS.variantChange, function (event) {
        if (!event || !event.data || event.data.sectionId !== sectionId || !event.data.html) return;

        const blocks = document.querySelectorAll(`[data-effective-price-section="${sectionId}"]`);
        blocks.forEach(function (block) {
          const blockId = block.getAttribute('data-effective-price-block-id');
          const sourceBlock = event.data.html.getElementById(`EffectivePrice-${blockId}-${sectionId}`);
          if (!sourceBlock) return;

          const sourceValue = sourceBlock.querySelector('[data-effective-price-value]');
          const destinationValue = block.querySelector('[data-effective-price-value]');
          if (sourceValue && destinationValue) {
            destinationValue.textContent = sourceValue.textContent;
          }
        });
      });
    });
  </script>

  {%- liquid
    if product.selected_or_first_available_variant.featured_media
      assign seo_media = product.selected_or_first_available_variant.featured_media
    else
      assign seo_media = product.featured_media
    endif
  -%}

  <script type="application/ld+json">
    {
    	"@context": "http://schema.org/",
    	"@type": "Product",
    	"name": {{ product.title | json }},
    	"url": {{ request.origin | append: product.url | json }},
    	{% if seo_media -%}
    		"image": [
    			{{ seo_media | image_url: width: 1920 | prepend: "https:" | json }}
    		],
    	{%- endif %}
    	"description": {{ product.description | strip_html | json }},
    	{% if product.selected_or_first_available_variant.sku != blank -%}
    		"sku": {{ product.selected_or_first_available_variant.sku | json }},
    	{%- endif %}
    	"brand": {
    		"@type": "Brand",
    		"name": {{ product.vendor | json }}
    	},
    	"offers": [
    		{%- for variant in product.variants -%}
    			{
    				"@type" : "Offer",
    				{%- if variant.sku != blank -%}
    					"sku": {{ variant.sku | json }},
    				{%- endif -%}
    				{%- if variant.barcode.size == 12 -%}
    					"gtin12": {{ variant.barcode }},
    				{%- endif -%}
    				{%- if variant.barcode.size == 13 -%}
    					"gtin13": {{ variant.barcode }},
    				{%- endif -%}
    				{%- if variant.barcode.size == 14 -%}
    					"gtin14": {{ variant.barcode }},
    				{%- endif -%}
    				"availability" : "http://schema.org/{% if variant.available %}InStock{% else %}OutOfStock{% endif %}",
    				"price" : {{ variant.price | divided_by: 100.00 | json }},
    				"priceCurrency" : {{ cart.currency.iso_code | json }},
    				"url" : {{ request.origin | append: variant.url | json }}
    			}{% unless forloop.last %},{% endunless %}
    		{%- endfor -%}
    	]
    }
  </script>
</div>

