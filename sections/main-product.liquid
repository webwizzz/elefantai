                        | default: skill['bg-color'].value
                        | default: '#f2f4f7'
                      %}
                      <li class="product-skills-learned__item" style="--skill-bg: {{ skill_bg }};">
                        {% if skill_icon != blank %}
                          <span class="product-skills-learned__icon-wrap">
                            {{
                              skill_icon
                              | image_url: width: 64
                              | image_tag: class: 'product-skills-learned__icon', alt: skill_title
                            }}
                          </span>
                        {% endif %}
                        {% if skill_title != blank %}
                          <span class="product-skills-learned__title">{{ skill_title }}</span>
