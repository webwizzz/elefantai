										{% assign specification_description = specification.description.value | default: specification.description %}
										{% if specification_title != blank or specification_description != blank %}
											<li class="product-meta-tabs__spec-row">
												<span class="product-meta-tabs__spec-title">{{ specification_title }}</span>
												<span class="product-meta-tabs__spec-value">{{ specification_description }}</span>
											</li>
										{% endif %}
									{% endfor %}
								{% endif %}
							{% endcapture %}
							{% assign specifications_rows = specifications_rows | strip %}

							{% capture buyback_stacks %}
								{% for i in (1..6) %}
									{% assign stack_title_key = 'stack_' | append: i | append: '_title' %}
									{% assign stack_description_key = 'stack_' | append: i | append: '_description' %}
									{% assign stack_icon_key = 'stack_' | append: i | append: '_icon' %}
									{% assign stack_color_key = 'stack_' | append: i | append: '_icon_color' %}

									{% assign stack_title = block.settings[stack_title_key] %}
									{% assign stack_description = block.settings[stack_description_key] %}
									{% assign stack_icon = block.settings[stack_icon_key] %}
									{% assign stack_color = block.settings[stack_color_key] %}

									{% if stack_title != blank %}
										<li class="product-meta-tabs__stack">
											<div class="product-meta-tabs__stack-icon" style="--stack-color: {{ stack_color }};">
												{% if stack_icon != blank %}
													{{ stack_icon | image_url: width: 56 | image_tag: class: 'product-meta-tabs__stack-icon-image', alt: stack_title }}
												{% else %}
													<span class="product-meta-tabs__stack-icon-fallback">{{ i }}</span>
												{% endif %}
											</div>
											<div>
												<h4 class="product-meta-tabs__stack-title">{{ stack_title }}</h4>
												{% if stack_description != blank %}
													<p class="product-meta-tabs__stack-description">{{ stack_description }}</p>
												{% endif %}
											</div>
										</li>
									{% endif %}
								{% endfor %}
