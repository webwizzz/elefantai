													{{- 'products.product.inventory_low_stock_show_count' | t: quantity: product.selected_or_first_available_variant.inventory_quantity -}}
												{%- else -%}
													{{- 'products.product.inventory_low_stock' | t -}}
												{%- endif -%}
												{% if block.settings.show_inventory_progress %}
													{% assign percentage_remaining = product.selected_or_first_available_variant.inventory_quantity | times: 100 | divided_by: block.settings.inventory_threshold_start %}
													<span class="inventory_progress_bar low">
														<span style="width: {{ percentage_remaining }}%; max-width: 100%; min-width: 0;"></span>
													</span>
												{% endif %}
											{%- else -%}
												{% if block.settings.inventory_icon != blank %}
													{{
														block.settings.inventory_icon
														| image_url: width: 20
														| image_tag: loading: 'lazy', sizes: '20px', widths: '20', alt: block.settings.inventory_icon.alt
													}}
												{%- else -%}
													<svg width="15" height="15" aria-hidden="true">
														<circle cx="7.5" cy="7.5" r="7.5" fill="rgb(62,214,96, 0.3)"/>
														<circle cx="7.5" cy="7.5" r="5" stroke="rgb(255, 255, 255)" stroke-width="1" fill="rgb(62,214,96)"/>
													</svg>
												{% endif %}
												{%- if block.settings.show_inventory_quantity -%}
													{{- 'products.product.inventory_in_stock_show_count' | t: quantity: product.selected_or_first_available_variant.inventory_quantity -}}
												{%- else -%}
														{{- 'products.product.inventory_in_stock' | t -}}
												{%- endif -%}
												{% if block.settings.show_inventory_progress %}
													{% assign percentage_remaining = product.selected_or_first_available_variant.inventory_quantity | times: 100 | divided_by: block.settings.inventory_threshold_start %}
													<span class="inventory_progress_bar">
														<span style="width: {{ percentage_remaining }}%; max-width: 100%; min-width: 0;"></span>
													</span>
												{% endif %}
											{%- endif -%}
										{%- else -%}
											{%- if product.selected_or_first_available_variant.inventory_policy == 'continue' -%}
												<svg width="15" height="15" aria-hidden="true">
