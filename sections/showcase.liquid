{{ 'section-showcase.css' | asset_url | stylesheet_tag }}
{{ 'section-multicolumn.css' | asset_url | stylesheet_tag }}
{{ 'swiper.css' | asset_url | stylesheet_tag }}

{%- style -%}
	#shopify-section-{{ section.id }} {
		--padding-top: {{ section.settings.padding_top }}px;
		--padding-bottom: {{ section.settings.padding_bottom }}px;
		--margin-bottom: {{ section.settings.margin_bottom }}px;
	}

  {% if section.settings.colors_background_section_gradient != blank %}
    #shopify-section-{{ section.id }} .multicolumn.showcase {
      background: {{ section.settings.colors_background_section_gradient }};
    }
  {% endif %}

  {% if section.settings.title != blank %}
		#shopify-section-{{ section.id }} a:has(.replace-color) {
			color: {{ section.settings.text_color_2 }};
		}
	{% endif %}
{%- endstyle -%}

{%- liquid
  if section.settings.image_overlay != blank or section.settings.image_overlay_2 != blank or section.settings.image_overlay_3 != blank or section.settings.shape_type != 'none'
    assign section_overlay = true
  endif
-%}

<showcase-slider
	class="multicolumn showcase gradient section-responsive-padding section-responsive-margin-b {{ section.settings.background_color }}{% if section_overlay == true %} section-overlay{% endif %} layout--{{ section.settings.layout }}">

  {%- if section.settings.image_overlay != blank or section.settings.image_overlay_2 != blank or section.settings.image_overlay_3 != blank -%}
    {% render 'section-overlay' %}
  {%- endif -%} 

  {%- if section.settings.shape_type != 'none' -%}
    {% render 'shape',
      position: section.settings.shape_position, 
      type: section.settings.shape_type, 
      color: section.settings.shape_color,
      width: section.settings.shape_width
    %}
  {%- endif -%}

  <div class="isolate{% if section.settings.full_width %} full-width{% else %} page-width{% endif %}">

    {%- if section.settings.title != blank or section.settings.text != blank -%}
      <div class="title-wrapper {% if section.settings.icon_on_title  %}icons-in-title{% else %}{{ section.settings.heading_align }}{% endif %} {{ section.settings.text_bottom_space }}{% if section.settings.show_social and section.settings.under_section != true %} with-social {% endif %}">

	  {% if section.settings.show_social and section.settings.under_section != true %}
		<div class="title-wrapper-with-social">
		{%- endif -%}	
        {%- if section.settings.title != blank -%}
          <h2 class="title inline-richtext {{ section.settings.heading_size }} text-color-{{ section.settings.text_color }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-rotate-in{% endif %}">
            {% if section.settings.text_heading != blank %}
              {% assign word_list = section.settings.text_heading | split: ', ' %}
              {% assign text_to_replace = section.settings.title | split: '' %}
              {% assign content = '' %}
              {% assign result = '' %}
              {% assign inside_tag = false %}
      
              {% for char in text_to_replace %}
                {% if inside_tag %}
                  {% if char == '>' %}
                    {% assign inside_tag = false %}
                  {% endif %}
                  {% assign result = result | append: char %}
                {% else %}
                  {% if char == '<' or forloop.last %}
                    {% assign inside_tag = true %}
                    {% if forloop.last %}
                      {% assign content = content | append: char %}
                    {% endif %}
                    {% for word in word_list %}
                      {% assign replace_text = '<<<' | append: section.settings.text_color_2 | append: '">' | append: word | append: '>>>' %}
                      {% assign content = content | replace: word, replace_text %}
                    {% endfor %}
      
                    {% assign content = content | replace: '<<<', '<span class="replace-color" style="color:' %}
                    {% assign content = content | replace: '>>>', '</span>' %}
                    {% assign result = result | append: content %}
                    {% assign content = '' %}
                    {% if forloop.last != true %}
                      {% assign result = result | append: char %}
                    {% endif %}
                  {% else %}
                    {% assign content = content | append: char %}
                  {% endif %}
                {% endif %}
      
              {% endfor %}
        
              {{ result }}
            {% else %}
              {{ section.settings.title }}
            {% endif %}
          </h2>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <div class="description rte {{ section.settings.text_body_size }} text-color-{{ section.settings.description_color }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
            {{ section.settings.text -}}
          </div>
        {%- endif -%}
			{% if section.settings.show_social and section.settings.under_section != true %}
			</div>
			{%- endif -%}	

	

        {% if section.settings.show_social and section.settings.under_section != true %}
          <div class="section-social {{ section.settings.social_top_space }} {{ section.settings.social_label_size }} text-weight-{{ section.settings.social_label_weight }} {{ section.settings.heading_align }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
				{%- if section.settings.social_label != blank -%}
            <p class="inline-richtext text-color-{{ section.settings.social_label_color }}">
              {{ section.settings.social_label }}
            </p>
				{%- endif -%}	
            <ul class="footer__list-social list-unstyled list-social text-color-{{ section.settings.social_color }} text-color-{{ section.settings.social_color_hover }}-hover">
              {%- if settings.social_linkedin_link != blank -%}
                <li class="list-social__item">
                  <a href="{{ settings.social_linkedin_link }}" class="link list-social__link focus-inset" target="_blank" rel="noopener">
                    {%- render 'icon-linkedin' -%}
                    <span class="visually-hidden">{{ 'general.social.links.linkedin' | t }}</span>
                  </a>
                </li>
              {%- endif -%}
              {%- if settings.social_facebook_link != blank -%}
                <li class="list-social__item">
                  <a href="{{ settings.social_facebook_link }}" class="link list-social__link focus-inset" target="_blank" rel="noopener">
                    {%- render 'icon-facebook' -%}
                    <span class="visually-hidden">{{ 'general.social.links.facebook' | t }}</span>
                  </a>
                </li>
              {%- endif -%}
              {%- if settings.social_twitter_link != blank -%}
                <li class="list-social__item">
                  <a href="{{ settings.social_twitter_link }}" class="link list-social__link focus-inset" target="_blank" rel="noopener">
                    {%- render 'icon-twitter' -%}
                    <span class="visually-hidden">{{ 'general.social.links.twitter' | t }}</span>
                  </a>
                </li>
              {%- endif -%}
              {%- if settings.social_instagram_link != blank -%}
                <li class="list-social__item">
                  <a href="{{ settings.social_instagram_link }}" class="link list-social__link focus-inset" target="_blank" rel="noopener">
                    {%- render 'icon-instagram' -%}
                    <span class="visually-hidden">{{ 'general.social.links.instagram' | t }}</span>
                  </a>
                </li>
              {%- endif -%}
              {%- if settings.social_youtube_link != blank -%}
                <li class="list-social__item">
                  <a href="{{ settings.social_youtube_link }}" class="link list-social__link focus-inset" target="_blank" rel="noopener">
                    {%- render 'icon-youtube' -%}
                    <span class="visually-hidden">{{ 'general.social.links.youtube' | t }}</span>
                  </a>
                </li>
              {%- endif -%}
              {%- if settings.social_tiktok_link != blank -%}
                <li class="list-social__item">
                  <a href="{{ settings.social_tiktok_link }}" class="link list-social__link focus-inset" target="_blank" rel="noopener">
                    {%- render 'icon-tiktok' -%}
                    <span class="visually-hidden">{{ 'general.social.links.tiktok' | t }}</span>
                  </a>
                </li>
              {%- endif -%}
              {%- if settings.social_pinterest_link != blank -%}
                <li class="list-social__item">
                  <a href="{{ settings.social_pinterest_link }}" class="link list-social__link focus-inset" target="_blank" rel="noopener">
                    {%- render 'icon-pinterest' -%}
                    <span class="visually-hidden">{{ 'general.social.links.pinterest' | t }}</span>
                  </a>
                </li>
              {%- endif -%}
              {%- if settings.social_snapchat_link != blank -%}
                <li class="list-social__item">
                  <a href="{{ settings.social_snapchat_link }}" class="link list-social__link focus-inset" target="_blank" rel="noopener">
                    {%- render 'icon-snapchat' -%}
                    <span class="visually-hidden">{{ 'general.social.links.snapchat' | t }}</span>
                  </a>
                </li>
              {%- endif -%}
              {%- if settings.social_tumblr_link != blank -%}
                <li class="list-social__item">
                  <a href="{{ settings.social_tumblr_link }}" class="link list-social__link focus-inset" target="_blank" rel="noopener">
                    {%- render 'icon-tumblr' -%}
                    <span class="visually-hidden">{{ 'general.social.links.tumblr' | t }}</span>
                  </a>
                </li>
              {%- endif -%}
              {%- if settings.social_vimeo_link != blank -%}
                <li class="list-social__item">
                  <a href="{{ settings.social_vimeo_link }}" class="link list-social__link focus-inset" target="_blank" rel="noopener">
                    {%- render 'icon-vimeo' -%}
                    <span class="visually-hidden">{{ 'general.social.links.vimeo' | t }}</span>
                  </a>
                </li>
              {%- endif -%}
            </ul>
          </div>
        {% endif %}
      </div>
    {%- endif -%}

    <div class="swiper case-slider-{{ section.id }} case-slider" data-id="{{ section.id }}" data-slides="{{ section.blocks.size }}">
      <div class="swiper-wrapper blocks-size-{{ section.blocks.size }}">
        {%- for block in section.blocks -%}
          <div class="swiper-slide column-width-{{ block.settings.column_width }} slide-{{ forloop.index }}" {{ block.shopify_attributes }}>
						{% if block.settings.enable_border_radius %}
              {%- style -%}
								#shopify-section-{{ section.id }} .slide-{{ forloop.index }} {
									--sh-border-radius: {{ block.settings.border_radius }}px;
								}
							{%- endstyle -%}
            {% endif %}
            {% if block.settings.link != blank %}
              <a href="{{ block.settings.link }}" target="_blank">
            {% endif %}

            <div class="media media--transparent  {% if block.settings.column_width == "square" %}image--square{% else %}image--portrait{% endif %} {% if block.settings.image == blank %} empty-case{% endif %}">
              {% if block.settings.image != blank %}
                {% capture sizes %}
                  (min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 20 | divided_by: 3 }}px,
                  (min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)
                {% endcapture %}

                {{
                  block.settings.image
                  | image_url: width: 600, format: 'webp' 
                  | image_tag:
                    loading: 'lazy',
                    widths: '50, 75, 100, 150, 200, 300, 400, 450, 500, 550, 600, 750, 1000, 1250, 1500, 1750',
                    sizes: sizes,
                    class: 'multicolumn-card__image'
                }}
              {% else %}
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
              {% endif %}
            </div>

            {% if block.settings.link != blank %}
              </a>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>

    {% if section.settings.show_social and section.settings.under_section == true %}
      <div class="section-social  {{ section.settings.social_top_space }} {{ section.settings.social_label_size }} text-weight-{{ section.settings.social_label_weight }} {{ section.settings.heading_align }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
		{%- if section.settings.social_label != blank -%}
        <p class="inline-richtext text-color-{{ section.settings.social_label_color }}">
          {{ section.settings.social_label }}
        </p>
		{%- endif -%}
        <ul class="footer__list-social list-unstyled list-social text-color-{{ section.settings.social_color }} text-color-{{ section.settings.social_color_hover }}-hover">
          {%- if settings.social_linkedin_link != blank -%}
            <li class="list-social__item">
              <a href="{{ settings.social_linkedin_link }}" class="link list-social__link focus-inset" target="_blank" rel="noopener">
                {%- render 'icon-linkedin' -%}
                <span class="visually-hidden">{{ 'general.social.links.linkedin' | t }}</span>
              </a>
            </li>
          {%- endif -%}
          {%- if settings.social_facebook_link != blank -%}
            <li class="list-social__item">
              <a href="{{ settings.social_facebook_link }}" class="link list-social__link focus-inset" target="_blank" rel="noopener">
                {%- render 'icon-facebook' -%}
                <span class="visually-hidden">{{ 'general.social.links.facebook' | t }}</span>
              </a>
            </li>
          {%- endif -%}
          {%- if settings.social_twitter_link != blank -%}
            <li class="list-social__item">
              <a href="{{ settings.social_twitter_link }}" class="link list-social__link focus-inset" target="_blank" rel="noopener">
                {%- render 'icon-twitter' -%}
                <span class="visually-hidden">{{ 'general.social.links.twitter' | t }}</span>
              </a>
            </li>
          {%- endif -%}
          {%- if settings.social_instagram_link != blank -%}
            <li class="list-social__item">
              <a href="{{ settings.social_instagram_link }}" class="link list-social__link focus-inset" target="_blank" rel="noopener">
                {%- render 'icon-instagram' -%}
                <span class="visually-hidden">{{ 'general.social.links.instagram' | t }}</span>
              </a>
            </li>
          {%- endif -%}
          {%- if settings.social_youtube_link != blank -%}
            <li class="list-social__item">
              <a href="{{ settings.social_youtube_link }}" class="link list-social__link focus-inset" target="_blank" rel="noopener">
                {%- render 'icon-youtube' -%}
                <span class="visually-hidden">{{ 'general.social.links.youtube' | t }}</span>
              </a>
            </li>
          {%- endif -%}
          {%- if settings.social_tiktok_link != blank -%}
            <li class="list-social__item">
              <a href="{{ settings.social_tiktok_link }}" class="link list-social__link focus-inset" target="_blank" rel="noopener">
                {%- render 'icon-tiktok' -%}
                <span class="visually-hidden">{{ 'general.social.links.tiktok' | t }}</span>
              </a>
            </li>
          {%- endif -%}
          {%- if settings.social_pinterest_link != blank -%}
            <li class="list-social__item">
              <a href="{{ settings.social_pinterest_link }}" class="link list-social__link focus-inset" target="_blank" rel="noopener">
                {%- render 'icon-pinterest' -%}
                <span class="visually-hidden">{{ 'general.social.links.pinterest' | t }}</span>
              </a>
            </li>
          {%- endif -%}
          {%- if settings.social_snapchat_link != blank -%}
            <li class="list-social__item">
              <a href="{{ settings.social_snapchat_link }}" class="link list-social__link focus-inset" target="_blank" rel="noopener">
                {%- render 'icon-snapchat' -%}
                <span class="visually-hidden">{{ 'general.social.links.snapchat' | t }}</span>
              </a>
            </li>
          {%- endif -%}
          {%- if settings.social_tumblr_link != blank -%}
            <li class="list-social__item">
              <a href="{{ settings.social_tumblr_link }}" class="link list-social__link focus-inset" target="_blank" rel="noopener">
                {%- render 'icon-tumblr' -%}
                <span class="visually-hidden">{{ 'general.social.links.tumblr' | t }}</span>
              </a>
            </li>
          {%- endif -%}
          {%- if settings.social_vimeo_link != blank -%}
            <li class="list-social__item">
              <a href="{{ settings.social_vimeo_link }}" class="link list-social__link focus-inset" target="_blank" rel="noopener">
                {%- render 'icon-vimeo' -%}
                <span class="visually-hidden">{{ 'general.social.links.vimeo' | t }}</span>
              </a>
            </li>
          {%- endif -%}
        </ul>
      </div>
    {% endif %}
  </div>
</showcase-slider>

<script src="{{ 'slider-showcase.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Showcase",
  "class": "section",
  "tag": "section",
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "custom.additions"
    ]
  },
  "settings": [
		{
      "type": "select",
      "id": "layout",
      "options": [
        {
          "value": "default",
          "label": "Default"
        },
        {
          "value": "shift",
          "label": "Shift"
        }
      ],
      "default": "default",
      "label": "Layout",
			"info": "Visible when add shape divider"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "<strong>Heading for social images</strong>",
      "label": "t:sections.all.heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h4",
          "label": "Extra Small"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__3.label"
        }
      ],
      "default": "h2",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "select",
      "id": "text_color",
      "options": [
        {
          "value": "main",
          "label": "t:settings_schema.colors.settings.colors_text.label"
        },
        {
          "value": "secondary",
          "label": "t:settings_schema.colors.settings.colors_secondary_text.label"
        },
        {
          "value": "heading",
          "label": "t:settings_schema.colors.settings.colors_heading.label"
        },
        {
          "value": "heading-secondary",
          "label": "t:settings_schema.colors.settings.colors_secondary_heading.label"
        }
      ],
      "default": "heading",
      "label": "t:sections.all.colors.label_heading",
      "info": "t:sections.all.colors.has_cards_info"
    },
    {
      "type": "text",
      "id": "text_heading",
      "label": "Color-changing text",
      "info": "Case-sensitive. To change the colors of words that are not next to each other, use a comma. For example 'shipping, shop'"
    },
    {
      "type": "color",
      "id": "text_color_2",
      "label": "Custom color"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "t:sections.all.description"
    },
    {
      "type": "select",
      "id": "text_body_size",
      "options": [
        {
          "value": "text-body--small",
          "label": "Small"
        },
        {
          "value": "text-body--medium",
          "label": "Medium"
        },
        {
          "value": "text-body--large",
          "label": "Large"
        }
      ],
      "default": "text-body--large",
      "label": "Text size"
    },
    {
      "type": "select",
      "id": "description_color",
      "options": [
        {
          "value": "main",
          "label": "t:settings_schema.colors.settings.colors_text.label"
        },
        {
          "value": "secondary",
          "label": "t:settings_schema.colors.settings.colors_secondary_text.label"
        },
        {
          "value": "heading",
          "label": "t:settings_schema.colors.settings.colors_heading.label"
        },
        {
          "value": "heading-secondary",
          "label": "t:settings_schema.colors.settings.colors_secondary_heading.label"
        }
      ],
      "default": "main",
      "label": "t:sections.all.colors.label_text",
      "info": "t:sections.all.colors.has_cards_info"
    },
		{
      "type": "select",
      "id": "heading_align",
      "options": [
        {
          "value": "left",
          "label": "t:sections.all.heading_align.options__1.label"
        },
        {
          "value": "center",
          "label": "t:sections.all.heading_align.options__2.label"
        },
        {
          "value": "right",
          "label": "t:sections.all.heading_align.options__3.label"
        }
      ],
      "default": "center",
      "label": "t:sections.all.heading_align.label__2"
    },
		{
      "type": "select",
      "id": "text_bottom_space",
      "options": [
        {
          "value": "",
          "label": "Small"
        },
        {
          "value": "mb-lg-6",
          "label": "Large"
        }
      ],
      "default": "",
      "label": "Text bottom space desktop"
    }, 
    {
      "type": "header",
      "content": "t:sections.footer.settings.header__2.content",
      "info": "t:sections.footer.settings.header__2.info"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "default": false,
      "label": "t:sections.footer.settings.show_social.label"
    },
    {
      "type": "inline_richtext",
      "id": "social_label",
      "default": "Follow Us",
      "label": "Social label"
    },
		{
      "type": "select",
      "id": "social_label_size",
      "options": [
        {
          "value": "h6",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h5",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h4",
          "label": "t:sections.all.heading_size.options__3.label"
        }
      ],
      "default": "h4",
      "label": "Social label size"
    },
    {
      "type": "select",
      "id": "social_label_color",
      "options": [
        {
          "value": "main",
          "label": "t:settings_schema.colors.settings.colors_text.label"
        },
        {
          "value": "secondary",
          "label": "t:settings_schema.colors.settings.colors_secondary_text.label"
        },
        {
          "value": "heading",
          "label": "t:settings_schema.colors.settings.colors_heading.label"
        },
        {
          "value": "heading-secondary",
          "label": "t:settings_schema.colors.settings.colors_secondary_heading.label"
        }
      ],
      "default": "main",
      "label": "Social label color",
      "info": "t:sections.all.colors.has_cards_info"
    },
		{
      "type": "select",
      "id": "social_label_weight",
      "options": [
        {
          "value": "300",
          "label": "t:sections.all.heading_weight.options__1.label"
        },
        {
          "value": "400",
          "label": "t:sections.all.heading_weight.options__2.label"
        },
        {
          "value": "500",
          "label": "t:sections.all.heading_weight.options__3.label"
        },
        {
          "value": "600",
          "label": "t:sections.all.heading_weight.options__4.label"
        },
        {
          "value": "700",
          "label": "t:sections.all.heading_weight.options__5.label"
        },
        {
          "value": "800",
          "label": "t:sections.all.heading_weight.options__6.label"
        }
      ],
      "default": "600",
      "label": "Social label weight"
    },
    {
      "type": "select",
      "id": "social_color",
      "options": [
        {
          "value": "main",
          "label": "t:settings_schema.colors.settings.colors_text.label"
        },
        {
          "value": "secondary",
          "label": "t:settings_schema.colors.settings.colors_secondary_text.label"
        },
        {
          "value": "heading",
          "label": "t:settings_schema.colors.settings.colors_heading.label"
        },
        {
          "value": "heading-secondary",
          "label": "t:settings_schema.colors.settings.colors_secondary_heading.label"
        }
      ],
      "default": "main",
      "label": "Social icons color",
      "info": "t:sections.all.colors.has_cards_info"
    },
    {
      "type": "select",
      "id": "social_color_hover",
      "options": [
        {
          "value": "main",
          "label": "t:settings_schema.colors.settings.colors_text.label"
        },
