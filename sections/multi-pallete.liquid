{{ 'multipallete.css' | asset_url | stylesheet_tag }}

{%- style -%}
	.section-{{ section.id }}-padding {
		padding-top: {{ section.settings.padding_top | times: 0.53 | round: 0 }}px;
		padding-bottom: {{ section.settings.padding_bottom | times: 0.53 | round: 0 }}px;
	}

	@media screen and (min-width: 750px) and (max-width: 1024px) {
    .section-{{ section.id }}-padding {
			padding-top: {{ section.settings.padding_top | times: 0.67 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.67 | round: 0 }}px;
    }
  }

  @media screen and (min-width: 1025px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

	{% if section.settings.colors_background_section_gradient != blank %}
    .section-{{ section.id }}-padding {
      background: {{ section.settings.colors_background_section_gradient }};
    }
  {% endif %}

{%- endstyle -%}

{%- liquid
  if section.settings.image_overlay != blank or section.settings.image_overlay_2 != blank or section.settings.image_overlay_3 != blank or section.settings.shape_type != 'none'
    assign section_overlay = true
  endif
-%}

<div class="gradient isolate section-{{ section.id }}-padding {{ section.settings.background_color }}{% if section_overlay == true %} section-overlay{% endif %}">

  {%- if section.settings.image_overlay != blank or section.settings.image_overlay_2 != blank or section.settings.image_overlay_3 != blank -%}
    {% render 'section-overlay' %}
  {%- endif -%}

  {%- if section.settings.shape_type != 'none' -%}
    {% render 'shape',
      position: section.settings.shape_position, 
      type: section.settings.shape_type, 
      color: section.settings.shape_color,
      width: section.settings.shape_width
    %}
  {%- endif -%}
  
  <div class="page-width">
    
    {%- if section.settings.heading != blank or section.settings.text != blank -%}
      <div class="title-wrapper {{ section.settings.heading_align }} {{ section.settings.text_bottom_space }}">
        {%- if section.settings.heading != blank -%}
          <h2 class="title inline-richtext {{ section.settings.heading_size }} text-color-{{ section.settings.heading_color }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-rotate-in{% endif %}">
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <div class="description rte {{ section.settings.text_body_size }} text-color-{{ section.settings.text_color }} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
            {{ section.settings.text -}}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="multipallete multipallete-{{ section.blocks.size }}">

      {%- for block in section.blocks -%}
        <div class="multipallete__item multipallete__item--{{ forloop.index }} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--zoom-in{% endif %}" {% if settings.animations_reveal_on_scroll %} data-cascade style="--animation-order: {{ forloop.index }};"{% endif %} {{ block.shopify_attributes }}>

          {% if block.settings.background_color != blank %}
            <div class="multipallete-background" style="background-color: {{ block.settings.background_color }};"> </div>
          {% endif %}

          {% if block.settings.pallet_link != blank %}
            <a href="{{ block.settings.pallet_link }}" class="multipallete-link">
              {{- shop.name }} - {{ block.settings.pallet_label | escape -}}
            </a>
          {% endif %}

          {% if block.settings.pallet_image != blank %}
            {%- assign widths = '165, 360, 450, 500' -%}
            {%- capture sizes -%}
              (min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 3 }}px,
              (min-width: 750px) calc((100vw - 130px)), 
              calc((100vw - 50px))
            {%- endcapture -%}

            {{
              block.settings.pallet_image
              | image_url: width: 500, format: 'webp' 
              | image_tag: loading: 'lazy', 
              sizes: sizes, 
              widths: widths, 
              alt: block.settings.pallet_image.alt
            }}
          {% endif %}

          <div class="multipallete-label multipallete-label-{{ forloop.index }}">
            <h3 class="h4" style="color: {{ block.settings.label_color }};">
              {{- block.settings.pallet_label | escape -}}
            </h3>
          </div>
        </div>

      {%- endfor -%}

    </div>
  </div>

</div>

