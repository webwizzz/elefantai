{{ 'multicollage.css' | asset_url | stylesheet_tag }}

{%- style -%}
  @media screen and (max-width: 749px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.53 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.53 | round: 0 }}px;
    }
  }

	@media screen and (min-width: 750px) and (max-width: 1024px) {
    .section-{{ section.id }}-padding {
			padding-top: {{ section.settings.padding_top | times: 0.67 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.67 | round: 0 }}px;
    }
  }

  @media screen and (min-width: 1025px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

	{% if section.settings.colors_background_section_gradient != blank %}
    .section-{{ section.id }}-padding {
      background: {{ section.settings.colors_background_section_gradient }};
    }
  {% endif %}

  {% if section.settings.text != blank %}
		#shopify-section-{{ section.id }} a:has(.replace-color) {
			color: {{ section.settings.text_color_2 }};
		}
	{% endif %}

{%- endstyle -%}


{%- liquid
  if section.settings.image_overlay != blank or section.settings.image_overlay_2 != blank or section.settings.image_overlay_3 != blank or section.settings.shape_type != 'none'
    assign section_overlay = true
  endif
-%}

{%- liquid
  assign fetch_priority = 'auto'
  if section.index == 1
    assign fetch_priority = 'high'
  endif
-%}

<div class="gradient isolate section-{{ section.id }}-padding {{ section.settings.background_color }}{% if section_overlay == true %} section-overlay{% endif %}">

  {%- if section.settings.image_overlay != blank or section.settings.image_overlay_2 != blank or section.settings.image_overlay_3 != blank -%}
    {% render 'section-overlay' %}
  {%- endif -%}

  {%- if section.settings.shape_type != 'none' -%}
    {% render 'shape',
      position: section.settings.shape_position, 
      type: section.settings.shape_type, 
      color: section.settings.shape_color,
      width: section.settings.shape_width
    %}
  {%- endif -%}

  <div class="page-width{% if section.settings.heading == blank %} no-heading{% endif %}">
    
		{%- if section.settings.heading != blank or section.settings.text != blank -%}
      <div class="title-wrapper {{ section.settings.heading_align }} {{ section.settings.text_bottom_space }}">
        {%- if section.settings.heading != blank -%}
          <h2 class="title inline-richtext {{ section.settings.heading_size }} text-color-{{ section.settings.heading_color }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-rotate-in{% endif %}">
            {% if section.settings.text_heading != blank %}
              {% assign word_list = section.settings.text_heading | split: ', ' %}
              {% assign text_to_replace = section.settings.heading | split: '' %}
              {% assign content = '' %}
              {% assign result = '' %}
              {% assign inside_tag = false %}

              {% for char in text_to_replace %}
                {% if inside_tag %}
                  {% if char == '>' %}
                    {% assign inside_tag = false %}
                  {% endif %}
                  {% assign result = result | append: char %}
                {% else %}
                  {% if char == '<' or forloop.last %}
                    {% assign inside_tag = true %}
                    {% if forloop.last %}
                      {% assign content = content | append: char %}
                    {% endif %}
                    {% for word in word_list %}
                      {% assign replace_text = '<<<' | append: section.settings.text_color_2 | append: '">' | append: word | append: '>>>' %}
                      {% assign content = content | replace: word, replace_text %}
                    {% endfor %}

                    {% assign content = content | replace: '<<<', '<span class="replace-color" style="color:' %}
                    {% assign content = content | replace: '>>>', '</span>' %}
                    {% assign result = result | append: content %}
                    {% assign content = '' %}
                    {% if forloop.last != true %}
                      {% assign result = result | append: char %}
                    {% endif %}
                  {% else %}
                    {% assign content = content | append: char %}
                  {% endif %}
                {% endif %}

              {% endfor %}
        
              {{ result }}
            {% else %}
              {{ section.settings.heading }}
            {% endif %}  
          </h2>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <div class="description rte {{ section.settings.text_body_size }} text-color-{{ section.settings.text_color }} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
            {{ section.settings.text -}}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="collage{% if section.settings.mobile_layout == 'collage' %} collage--mobile{% endif %} multicolage multicolage-{{ section.blocks.size }}">
      {%- for block in section.blocks -%}

        <div class="collage__item collage__item--{{ block.type }} collage__item--{{ forloop.index }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" {{ block.shopify_attributes }} {% if settings.animations_reveal_on_scroll %} data-cascade style="--animation-order: {{ forloop.index }};"{% endif %}>

          {%- case block.type -%}

            {%- when 'collection' -%}

              {%- if block.settings.collection != blank -%}
                <a href="{{ block.settings.collection.url }}" class="card-wrapper">
                  <style>
                    #shopify-section-{{ section.id }} .card-label-{{ forloop.index }}:before {
                      background-color: rgba({{ block.settings.label_color.red }}, {{ block.settings.label_color.green }}, {{ block.settings.label_color.blue }}, 1);
                    }
                  </style>

                  {%- assign widths = '165, 320, 360, 400, 535, 750, 1070, 1200' -%}
                  {%- capture sizes -%}
                    (min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 2 }}px,
                    (min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)
                  {%- endcapture -%}

                  {% if forloop.index == 2 %}
                    {% assign image_width = 1200 %}
                  {% else %}
                    {% assign image_width = 500 %}
                  {% endif %}

                  {% liquid
                    assign loading = 'lazy' 
                    if forloop.index == 1 and fetch_priority == 'high' 
                      assign loading = 'eager'
                    endif
                  %}

                  {% if block.settings.custom_image != blank %}
                    {{
                      block.settings.custom_image
                      | image_url: width: image_width
                      | image_tag: loading: loading, 
                      fetchpriority: fetch_priority,
                      sizes: sizes, 
                      widths: widths, 
                      alt: block.settings.custom_image.alt
                    }}
                  {% elsif block.settings.collection.featured_image != blank %}
                    {{
                      block.settings.collection.featured_image
                      | image_url: width: image_width
                      | image_tag: loading: loading, 
                      fetchpriority: fetch_priority,
                      sizes: sizes, 
                      widths: widths, 
                      alt: block.settings.collection.featured_image.alt
                    }}
                  {% else %}
                    {%- assign placeholder_image = 'collection-' | append: forloop.rindex -%}
                    {{ placeholder_image | placeholder_svg_tag: 'placeholder-svg placeholder' }}
                  {% endif %}

                  <div class="card-label button card-label-{{ forloop.index }}">
                    <h3 class="{{ block.settings.heading_size }}">
                      {{- block.settings.collection.title | escape -}}
                    </h3>
                  </div>
                </a>
              {%- else -%}
                <div class="card-wrapper card-empty">
                  {%- assign placeholder_image = 'collection-' | append: forloop.rindex -%}

                  {{ placeholder_image | placeholder_svg_tag: 'placeholder-svg placeholder' }}

                  <style>
                    #shopify-section-{{ section.id }} .card-label-{{ forloop.index }}:before {
                      background-color: rgba({{ block.settings.label_color.red }}, {{ block.settings.label_color.green }}, {{ block.settings.label_color.blue }}, 1);
                    }
                  </style>

                  <div class="card-label button card-label-{{ forloop.index }}">
                    <h3 class="{{ block.settings.heading_size }}">
                      {{ 'onboarding.collection_title' | t }}
                    </h3>
                  </div>
                </div>
              {%- endif -%}

							{% if block.settings.icon != blank %}
								{{
									block.settings.icon
									| image_url: width: 103
									| image_tag: loading: 'lazy', class: 'collage__item--icon', alt: block.settings.icon.alt
								}}
							{% endif %}

          {%- endcase -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

