{%- liquid
  assign variants_available_arr = product.variants | map: 'available'
  assign variants_option1_arr = product.variants | map: 'option1'
  assign variants_option2_arr = product.variants | map: 'option2'
  assign variants_option3_arr = product.variants | map: 'option3'
  assign option_section_id = section_id | default: section.id
  assign option_product_form_id = product_form_id | default: 'product-form-' | append: option_section_id
  assign selected_variant_for_options = selected_variant | default: product.selected_or_first_available_variant
  assign selected_value_for_option = option.selected_value

  case option.position
    when 1
      assign selected_value_for_option = selected_variant_for_options.option1
    when 2
      assign selected_value_for_option = selected_variant_for_options.option2
    when 3
      assign selected_value_for_option = selected_variant_for_options.option3
  endcase
  assign selected_value_text = selected_value_for_option | append: ''
-%}

{%- for value in option.values -%}
  {%- liquid
    assign option_disabled = true
    assign value_text = value | append: ''

		assign swatch = value.swatch
		assign swatch_value = value
		if swatch.image
			assign image_url = swatch.image | image_url: width: 50, format: 'webp' 
			assign swatch_value = 'url(' | append: image_url | append: '); background-position: center !important'
		elsif swatch.color
			assign swatch_value = 'rgb(' | append: swatch.color.rgb | append: ')'
		endif


    for option1_name in variants_option1_arr
      case option.position
        when 1
          if variants_option1_arr[forloop.index0] == value_text and variants_available_arr[forloop.index0]
            assign option_disabled = false
          endif
        when 2
          if option1_name == selected_variant_for_options.option1 and variants_option2_arr[forloop.index0] == value_text and variants_available_arr[forloop.index0]
            assign option_disabled = false
          endif
        when 3
          if option1_name == selected_variant_for_options.option1 and variants_option2_arr[forloop.index0] == selected_variant_for_options.option2 and variants_option3_arr[forloop.index0] == value_text and variants_available_arr[forloop.index0]
            assign option_disabled = false
          endif
      endcase
    endfor
  -%}

  {%- if block.settings.picker_type == 'button' -%}
    <input type="radio" id="{{ option_section_id }}-{{ option.position }}-{{ forloop.index0 }}" name="{{ option.name }}" value="{{ value | escape }}" form="{{ option_product_form_id }}" {% if selected_value_text == value_text %} checked{% endif %}{% if option_disabled %} class="disabled"{% endif %}>

    {% if swatches_variant == true %}
      {%- liquid
        assign current_variant = nil
        for variant in product.variants
          case option.position
            when 1
              if variant.option1 == value_text
                assign current_variant = variant
                break
              endif
            when 2
              if variant.option1 == selected_variant_for_options.option1 and variant.option2 == value_text
                assign current_variant = variant
                break
              endif
            when 3
              if variant.option1 == selected_variant_for_options.option1 and variant.option2 == selected_variant_for_options.option2 and variant.option3 == value_text
                assign current_variant = variant
                break
              endif
          endcase
        endfor
      -%}
      <label class="custom-condition-card custom-card--{{ value | escape | downcase | replace: " ", "-" }}" for="{{ option_section_id }}-{{ option.position }}-{{ forloop.index0 }}">
        <div class="custom-condition-card__icon">
          {% if value == 'Brand New' %}
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="20" cy="20" r="20" fill="#f4ecfc"/>
              <!-- Star -->
              <path d="M20 14L21.41 17.59L25.26 17.84L22.28 20.3L23.23 24.04L20 21.99L16.77 24.04L17.72 20.3L14.74 17.84L18.59 17.59L20 14Z" fill="#663399"/>
              <!-- Dashes -->
              <line x1="20" y1="8" x2="20" y2="10" stroke="#663399" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="20" y1="30" x2="20" y2="32" stroke="#663399" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="8" y1="20" x2="10" y2="20" stroke="#663399" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="30" y1="20" x2="32" y2="20" stroke="#663399" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="11.51" y1="11.51" x2="12.93" y2="12.93" stroke="#663399" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="27.07" y1="27.07" x2="28.49" y2="28.49" stroke="#663399" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="11.51" y1="28.49" x2="12.93" y2="27.07" stroke="#663399" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="27.07" y1="12.93" x2="28.49" y2="11.51" stroke="#663399" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          {% elsif value == 'Refurbished' %}
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="20" cy="20" r="20" fill="#e8f8ec"/>
              <path d="M13 19C13 15.134 16.134 12 20 12C23.155 12 25.823 14.086 26.708 17M26.708 17L23.708 16M26.708 17L26.708 14" stroke="#49c67a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M27 21C27 24.866 23.866 28 20 28C16.845 28 14.177 25.914 13.292 23M13.292 23L16.292 24M13.292 23L13.292 26" stroke="#49c67a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          {% else %}
            <span class="fallback-color" style="display:inline-block; width:100%; height:100%; border-radius:50%; background:{{ swatch_value | escape }};"></span>
          {% endif %}
        </div>
        <div class="custom-condition-card__content">
          <div class="custom-condition-card__title">{{ value }}</div>
          <div class="custom-condition-card__price">{{ current_variant.price | money_without_trailing_zeros }}</div>
          <div class="custom-condition-card__desc">
            {% if value == 'Brand New' %}
              Best Condition
            {% elsif value == 'Refurbished' %}
              {% assign savings = product.price_max | minus: current_variant.price %}
              Save {{ savings | money_without_trailing_zeros }} upfront
            {% endif %}
          </div>
        </div>
        <span class="visually-hidden">{{ 'products.product.variant_sold_out_or_unavailable' | t }}</span>
      </label>
    {% else %}
      <label class="color--{{ value | escape | downcase | replace: " ", "-" }}" for="{{ option_section_id }}-{{ option.position }}-{{ forloop.index0 }}" style="background:{{ swatch_value | escape }}; color:{{ swatch_value | escape }};">
        {{ value -}}
        <span class="visually-hidden">{{ 'products.product.variant_sold_out_or_unavailable' | t }}</span>
      </label>
    {% endif %}

  {%- elsif block.settings.picker_type == 'dropdown' -%}
    <option value="{{ value | escape }}" {% if selected_value_text == value_text %} selected="selected"{% endif %}>
      {% if option_disabled -%}
        {{- 'products.product.value_unavailable' | t: option_value: value -}}
      {%- else -%}
        {{- value -}}
      {%- endif %}
    </option>
  {%- endif -%}
{%- endfor -%}