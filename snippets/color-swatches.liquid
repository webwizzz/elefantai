{% style %}
	{% assign colorSwatchesList = settings.swatches_textarea | newline_to_br | strip_newlines | split: '<br />' %}
	{% for colorSwatchesItem in colorSwatchesList %}
		{% liquid
				assign colorSwatchesValue = colorSwatchesItem | split: ':'
				assign colorSwatchesName = colorSwatchesValue[0] | escape | downcase | replace: " ", "-"
				assign colorSwatchesColor = colorSwatchesValue[1] 
				assign colorSwatchesColor = colorSwatchesColor | replace: "#", ""
		%}

		.card-variant__item.color--{{ colorSwatchesName }},
		.variant-color label.color--{{ colorSwatchesName }} {
			background: #{{- colorSwatchesColor | replace: " ", "" -}}!important;
			color: #{{- colorSwatchesColor -}}!important;
		}
	{% endfor %}
{% endstyle %}